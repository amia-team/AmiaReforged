<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">AmiaReforged.AdminPanel</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="encounters">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Encounters
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="area-upload">
                <span class="bi bi-upload" aria-hidden="true"></span> Area Upload
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <a class="nav-link" href="javascript:void(0)" @onclick="ToggleWorldEngine" @onclick:preventDefault>
                <span class="bi bi-globe2" aria-hidden="true"></span> World Engine
                <span class="float-end">@(_worldEngineExpanded ? "▾" : "▸")</span>
            </a>
        </div>

        @if (_worldEngineExpanded)
        {
            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/editor">
                    <span class="bi bi-columns-gap" aria-hidden="true"></span> Editor
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/items">
                    <span class="bi bi-box-seam" aria-hidden="true"></span> Items
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/resource-nodes">
                    <span class="bi bi-tree" aria-hidden="true"></span> Resource Nodes
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/regions">
                    <span class="bi bi-map" aria-hidden="true"></span> Regions
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/area-graph">
                    <span class="bi bi-diagram-3" aria-hidden="true"></span> Area Graph
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/traits">
                    <span class="bi bi-person-badge" aria-hidden="true"></span> Traits
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/glyphs">
                    <span class="bi bi-code" aria-hidden="true"></span> Glyph Scripts
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/industries">
                    <span class="bi bi-gear" aria-hidden="true"></span> Industries
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/interactions">
                    <span class="bi bi-lightning" aria-hidden="true"></span> Interactions
                </NavLink>
            </div>

            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="worldengine/coinhouses">
                    <span class="bi bi-bank" aria-hidden="true"></span> Coinhouses
                </NavLink>
            </div>
        }

        <div class="nav-item px-3">
            <a class="nav-link" href="javascript:void(0)" @onclick="TogglePwEngine" @onclick:preventDefault>
                <span class="bi bi-cpu" aria-hidden="true"></span> PwEngine
                <span class="float-end">@(_pwEngineExpanded ? "▾" : "▸")</span>
            </a>
        </div>

        @if (_pwEngineExpanded)
        {
            <div class="nav-item px-3 ps-5">
                <NavLink class="nav-link" href="pwengine/dependency-graph">
                    <span class="bi bi-diagram-3" aria-hidden="true"></span> Dependency Graph
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool _worldEngineExpanded = false;
    private bool _pwEngineExpanded = false;

    private void ToggleWorldEngine()
    {
        _worldEngineExpanded = !_worldEngineExpanded;
    }

    private void TogglePwEngine()
    {
        _pwEngineExpanded = !_pwEngineExpanded;
    }
}

