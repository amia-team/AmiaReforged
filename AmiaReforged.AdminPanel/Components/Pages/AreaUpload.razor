@page "/area-upload"
@using AmiaReforged.AdminPanel.Configuration
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AreaUploadService UploadService
@inject ILogger<AreaUpload> Logger
@rendermode InteractiveServer

<PageTitle>Area Upload</PageTitle>

<div class="encounters-page">
    <div class="dashboard-header d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0"><span class="bi bi-upload me-2"></span>Area Upload</h3>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger" role="alert">
            @_error
            <button type="button" class="btn-close btn-close-white float-end" @onclick="() => _error = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_success))
    {
        <div class="alert alert-success" role="alert">
            @_success
            <button type="button" class="btn-close btn-close-white float-end" @onclick="() => _success = null"></button>
        </div>
    }

    @if (_targets.Count == 0)
    {
        <div class="section" style="border-left: 3px solid var(--warning);">
            <strong style="color: var(--warning);">No upload targets configured.</strong>
            <p class="mb-0 mt-1" style="color: var(--text-secondary);">
                Set <code style="color: var(--accent);">AREA_UPLOAD_PATH_*</code> environment variables to define upload destinations.
                <br />
                Format: <code style="color: var(--accent);">AREA_UPLOAD_PATH_DEV=Development=/nwn/dev/areas</code>
            </p>
        </div>
    }
    else
    {
        <div class="section">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label" style="color: var(--text-secondary); font-weight: 500;">Upload Target</label>
                    <select class="form-select" value="@_selectedTarget" @onchange="OnTargetChanged" disabled="@_isUploading">
                        <option value="">— Select a destination —</option>
                        @foreach (AreaUploadTarget target in _targets)
                        {
                            <option value="@target.Name">@target.Name (@target.Path)</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label" style="color: var(--text-secondary); font-weight: 500;">Files (.are, .git, .gic)</label>
                    <InputFile OnChange="OnFilesSelected"
                               accept=".are,.git,.gic"
                               multiple
                               class="form-control"
                               disabled="@_isUploading" />
                </div>
            </div>

            @if (_selectedFiles.Count > 0)
            {
                <div class="mt-3">
                    <h6 style="color: var(--accent); font-size: 0.85rem; text-transform: uppercase;">Selected Files (@_selectedFiles.Count)</h6>
                    <div style="max-height: 200px; overflow-y: auto; border: 1px solid var(--border-subtle); border-radius: 6px;">
                        @foreach (IBrowserFile file in _selectedFiles)
                        {
                            <div style="padding: 6px 12px; border-bottom: 1px solid var(--border-subtle); display: flex; justify-content: space-between; align-items: center;">
                                <span style="color: var(--text-primary);">
                                    <span class="bi bi-file-earmark me-1" style="color: var(--text-secondary);"></span>@file.Name
                                </span>
                                <span style="color: var(--text-secondary); font-size: 0.8rem;">@FormatSize(file.Size)</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="mt-3">
                <button class="btn btn-primary"
                        @onclick="UploadFiles"
                        disabled="@(!CanUpload())">
                    @if (_isUploading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        <span>Uploading...</span>
                    }
                    else
                    {
                        <span class="bi bi-cloud-upload me-1"></span>
                        <span>Upload</span>
                    }
                </button>

                @if (_selectedFiles.Count > 0 && !_isUploading)
                {
                    <button class="btn btn-outline-primary ms-2" @onclick="ClearSelection">
                        Clear
                    </button>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_selectedTarget) && _directoryEntries is not null)
        {
            <div class="section">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <h6 style="color: var(--accent); font-size: 0.85rem; text-transform: uppercase; margin: 0;">
                        <span class="bi bi-folder2-open me-1"></span>Directory Contents (@_directoryEntries.Count)
                    </h6>
                    <button class="btn btn-sm btn-outline-primary" @onclick="RefreshDirectoryListing" disabled="@_isUploading">
                        <span class="bi bi-arrow-clockwise me-1"></span>Refresh
                    </button>
                </div>

                @if (_directoryEntries.Count == 0)
                {
                    <div style="color: var(--text-secondary); font-style: italic; padding: 8px 0;">Directory is empty or does not exist yet.</div>
                }
                else
                {
                    <div style="max-height: 300px; overflow-y: auto; border: 1px solid var(--border-subtle); border-radius: 6px;">
                        <table class="table mb-0" style="font-size: 0.9rem;">
                            <thead>
                            <tr>
                                <th>Name</th>
                                <th style="width: 100px; text-align: right;">Size</th>
                                <th style="width: 170px;">Modified</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (DirectoryEntry entry in _directoryEntries)
                            {
                                <tr>
                                    <td>
                                        @if (entry.IsDirectory)
                                        {
                                            <span class="bi bi-folder-fill me-1" style="color: var(--accent);"></span>
                                        }
                                        else
                                        {
                                            <span class="bi bi-file-earmark me-1" style="color: var(--text-secondary);"></span>
                                        }
                                        @entry.Name
                                    </td>
                                    <td style="text-align: right; color: var(--text-secondary);">@(entry.IsDirectory ? "—" : FormatSize(entry.Size))</td>
                                    <td style="color: var(--text-secondary);">@entry.LastModified.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        @if (_lastResult is not null)
        {
            <div class="section" style="padding: 0;">
                <div style="padding: 15px 20px; border-bottom: 1px solid var(--border-subtle); display: flex; align-items: center; gap: 10px;">
                    <h5 style="margin: 0; color: var(--text-primary);">
                        Upload Results — @_lastResult.TargetName
                    </h5>
                    @if (_lastResult.AllSucceeded)
                    {
                        <span class="state-badge running">All Succeeded</span>
                    }
                    else if (_lastResult.SuccessCount > 0)
                    {
                        <span class="state-badge paused">Partial</span>
                    }
                    else
                    {
                        <span class="state-badge stopped">Failed</span>
                    }
                </div>
                <table class="table mb-0">
                    <thead>
                    <tr>
                        <th>File</th>
                        <th style="width: 100px;">Status</th>
                        <th>Details</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (FileUploadResult fileResult in _lastResult.FileResults)
                    {
                        <tr style="@(fileResult.Success ? "" : "border-left: 3px solid var(--danger);")">
                            <td>@fileResult.FileName</td>
                            <td>
                                @if (fileResult.Success)
                                {
                                    <span style="color: var(--success);">
                                        <span class="bi bi-check-circle me-1"></span>OK
                                    </span>
                                }
                                else
                                {
                                    <span style="color: var(--danger);">
                                        <span class="bi bi-x-circle me-1"></span>Failed
                                    </span>
                                }
                            </td>
                            <td style="color: var(--text-secondary);">@(fileResult.Error ?? "—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
                <div style="padding: 10px 20px; border-top: 1px solid var(--border-subtle); color: var(--text-secondary); font-size: 0.85rem;">
                    @_lastResult.SuccessCount succeeded, @_lastResult.FailureCount failed
                    — uploaded to @_lastResult.TargetPath
                </div>
            </div>
        }
    }
</div>

@code {
    private IReadOnlyList<AreaUploadTarget> _targets = Array.Empty<AreaUploadTarget>();
    private string _selectedTarget = string.Empty;
    private List<IBrowserFile> _selectedFiles = new();
    private bool _isUploading;
    private string? _error;
    private string? _success;
    private AreaUploadResult? _lastResult;
    private IReadOnlyList<DirectoryEntry>? _directoryEntries;

    private bool CanUpload()
    {
        return !_isUploading
            && !string.IsNullOrEmpty(_selectedTarget)
            && _selectedFiles.Count > 0;
    }

    protected override void OnInitialized()
    {
        _targets = UploadService.GetTargets();
    }

    private void OnTargetChanged(ChangeEventArgs e)
    {
        _selectedTarget = e.Value?.ToString() ?? string.Empty;
        RefreshDirectoryListing();
    }

    private void RefreshDirectoryListing()
    {
        if (string.IsNullOrEmpty(_selectedTarget))
        {
            _directoryEntries = null;
            return;
        }

        _directoryEntries = UploadService.ListTargetContents(_selectedTarget);
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        _success = null;
        _lastResult = null;

        try
        {
            _selectedFiles = e.GetMultipleFiles(200).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to read selected files: {ex.Message}";
            _selectedFiles.Clear();
        }
    }

    private async Task UploadFiles()
    {
        if (!CanUpload()) return;

        _isUploading = true;
        _error = null;
        _success = null;
        _lastResult = null;
        StateHasChanged();

        try
        {
            _lastResult = await UploadService.UploadFilesAsync(_selectedTarget, _selectedFiles);

            if (_lastResult.AllSucceeded)
            {
                _success = $"Successfully uploaded {_lastResult.SuccessCount} file(s) to {_lastResult.TargetName}.";
            }
            else if (_lastResult.SuccessCount > 0)
            {
                _error = $"{_lastResult.FailureCount} file(s) failed. {_lastResult.SuccessCount} file(s) succeeded.";
            }
            else
            {
                _error = $"All {_lastResult.FailureCount} file(s) failed to upload.";
            }

            _selectedFiles.Clear();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during area upload");
            _error = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _isUploading = false;
            RefreshDirectoryListing();
            StateHasChanged();
        }
    }

    private void ClearSelection()
    {
        _selectedFiles.Clear();
        _lastResult = null;
        _error = null;
        _success = null;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
