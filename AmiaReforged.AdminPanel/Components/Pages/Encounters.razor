        try { _profileGlyphBindings = await GlyphApi.GetBindingsForProfileAsync(profile.Id); }
        catch { _profileGlyphBindings = []; }

        // Reset and load in-place scripts
        ResetScriptState();
        await LoadEncounterScripts(profile.Id);
