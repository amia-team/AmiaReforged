    private void ResetScriptState()
    {
        _showScriptsSection = false;
        _activeScriptTab = "BeforeGroupSpawn";
        _eventGraphJsons = new Dictionary<string, string>();
        _eventScripts = new Dictionary<string, GlyphDefinitionDto?>();
        _scriptNodeSearchFilter = "";
        _scriptEditorReady = false;
        _scriptSelectedNodeInfo = null;

        foreach (var evt in EncounterEventTypes)
        {
            _eventGraphJsons[evt] = "{}";
            _eventScripts[evt] = null;
        }
    }

    private async Task LoadEncounterScripts(Guid profileId)
    {
        try
        {
            if (_nodeCatalog.Count == 0)
            {
                _nodeCatalog = await GlyphApi.GetNodeCatalogAsync();
            }

            // Load bindings for this profile and fetch the definition for each
            var bindings = await GlyphApi.GetBindingsForProfileAsync(profileId);
            foreach (var binding in bindings)
            {
                var def = await GlyphApi.GetDefinitionAsync(binding.GlyphDefinitionId);
                if (def == null) continue;

                string eventType = def.EventType;
                if (_eventGraphJsons.ContainsKey(eventType))
                {
                    _eventGraphJsons[eventType] = def.GraphJson ?? "{}";
                    _eventScripts[eventType] = def;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load encounter scripts for profile {Id}", profileId);
        }
    }

    private async Task ToggleScriptsSection()
    {
        if (_showScriptsSection)
        {
            await CaptureCurrentScriptGraph();
            await DestroyScriptEditor();
            _showScriptsSection = false;
            _scriptSelectedNodeInfo = null;
        }
        else
        {
            _showScriptsSection = true;
            StateHasChanged();

            if (_nodeCatalog.Count == 0)
            {
                try { _nodeCatalog = await GlyphApi.GetNodeCatalogAsync(); }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load node catalog");
                }
            }

            await Task.Delay(100);
            await InitScriptEditor();
        }
    }

    private async Task SwitchScriptTab(string newEventType)
    {
        if (newEventType == _activeScriptTab) return;

        await CaptureCurrentScriptGraph();
        await DestroyScriptEditor();

        _activeScriptTab = newEventType;
        _scriptSelectedNodeInfo = null;
        _scriptNodeSearchFilter = "";
        StateHasChanged();

        await Task.Delay(50);
        await InitScriptEditor();
    }

    private async Task CaptureCurrentScriptGraph()
    {
        if (_scriptEditorModule == null || !_scriptEditorReady) return;

        try
        {
            string json = await _scriptEditorModule.InvokeAsync<string>("getGraphJson");
            _eventGraphJsons[_activeScriptTab] = json;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to capture script graph for {EventType}", _activeScriptTab);
        }
    }

    private async Task InitScriptEditor()
    {
        try
        {
            _scriptEditorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/glyph-editor.js");
            _dotNetRef ??= DotNetObjectReference.Create(this);

            var catalogJson = JsonSerializer.Serialize(_nodeCatalog);
            var graphJson = _eventGraphJsons.GetValueOrDefault(_activeScriptTab, "{}");

            if (string.IsNullOrEmpty(graphJson) || graphJson == "{}")
            {
                graphJson = JsonSerializer.Serialize(new { EventType = _activeScriptTab });
            }

            await _scriptEditorModule.InvokeVoidAsync("initGlyphEditor", "encounter-glyph-canvas", catalogJson, graphJson, _dotNetRef);
            _scriptEditorReady = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Script editor init failed");
            _scriptEditorReady = false;
        }
    }

    private async Task DestroyScriptEditor()
    {
        if (_scriptEditorModule == null) return;

        try
        {
            await _scriptEditorModule.InvokeVoidAsync("destroy");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to destroy script editor");
        }

        _scriptEditorReady = false;
    }

    private async Task ClearCurrentScript()
    {
        _eventGraphJsons[_activeScriptTab] = "{}";
        _scriptSelectedNodeInfo = null;

        await DestroyScriptEditor();
        StateHasChanged();
        await Task.Delay(50);
        await InitScriptEditor();
    }

    // ===== In-Place Script Editor — Save =====

    private async Task SaveEncounterEventScripts()
    {
        if (_selectedProfile == null) return;

        // Capture the current tab's graph before saving
        await CaptureCurrentScriptGraph();

        _isSaving = true;
        try
        {
            foreach (var eventType in EncounterEventTypes)
            {
                string graphJson = _eventGraphJsons.GetValueOrDefault(eventType, "{}");
                bool hasGraph = GraphHasNodes(graphJson);
                GlyphDefinitionDto? existingDef = _eventScripts.GetValueOrDefault(eventType);

                if (hasGraph)
                {
                    if (existingDef != null)
                    {
                        var updated = await GlyphApi.UpdateDefinitionAsync(existingDef.Id,
                            new UpdateGlyphRequest(GraphJson: graphJson, IsActive: true));
                        if (updated != null) _eventScripts[eventType] = updated;
                    }
                    else
                    {
                        // Check for existing binding with this event type to avoid duplicates
                        var existingBindings = await GlyphApi.GetBindingsForProfileAsync(_selectedProfile.Id);
                        GlyphBindingDto? matchingBinding = null;
                        foreach (var b in existingBindings)
                        {
                            if (b.EventType.Equals(eventType, StringComparison.OrdinalIgnoreCase))
                            {
                                matchingBinding = b;
                                break;
                            }
                        }

                        if (matchingBinding != null)
                        {
                            var updated = await GlyphApi.UpdateDefinitionAsync(
                                matchingBinding.GlyphDefinitionId,
                                new UpdateGlyphRequest(GraphJson: graphJson, IsActive: true));
                            if (updated != null) _eventScripts[eventType] = updated;
                        }
                        else
                        {
                            string name = $"{_selectedProfile.Name}/{eventType}";
                            var created = await GlyphApi.CreateDefinitionAsync(new CreateGlyphRequest(
                                Name: name,
                                EventType: eventType,
                                Category: "Encounter",
                                Description: $"Auto-created script for encounter '{_selectedProfile.Name}' — {eventType}",
                                GraphJson: graphJson,
                                IsActive: true));

                            if (created != null)
                            {
                                _eventScripts[eventType] = created;
                                await GlyphApi.CreateBindingAsync(new CreateGlyphBindingRequest(
                                    _selectedProfile.Id, created.Id));
                            }
                        }
                    }
                }
                else if (existingDef != null)
                {
                    await GlyphApi.UpdateDefinitionAsync(existingDef.Id,
                        new UpdateGlyphRequest(IsActive: false));
                    _eventScripts[eventType] = null;
                }
            }

            // Refresh binding list
            _profileGlyphBindings = await GlyphApi.GetBindingsForProfileAsync(_selectedProfile.Id);
            _success = "Event scripts saved.";
        }
        catch (Exception ex)
        {
            _error = $"Failed to save scripts: {ex.Message}";
            Logger.LogError(ex, "Failed to save encounter event scripts");
        }
        finally { _isSaving = false; }
    }

    // ===== In-Place Script Editor — Node Palette & Properties =====

    private async Task AddScriptNode(GlyphNodeCatalogEntryDto node)
    {
        if (_scriptEditorModule == null || !_scriptEditorReady) return;

        try
        {
            var nodeJson = JsonSerializer.Serialize(node);
            await _scriptEditorModule.InvokeVoidAsync("addNode", nodeJson);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to add script node");
        }
    }

    [JSInvokable]
    public Task OnNodeSelectionChanged(string? json)
    {
        if (string.IsNullOrEmpty(json) || json == "null")
        {
            _scriptSelectedNodeInfo = null;
        }
        else
        {
            try
            {
                _scriptSelectedNodeInfo = JsonSerializer.Deserialize<SelectedNodeInfo>(json, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
            }
            catch
            {
                _scriptSelectedNodeInfo = null;
            }
        }

        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private static string GetScriptPinValue(SelectedPinInfo pin) => pin.OverrideValue ?? pin.DefaultValue ?? "";

    private async Task OnScriptPropertyChanged(SelectedPinInfo pin, string value)
    {
        if (_scriptEditorModule == null || _scriptSelectedNodeInfo == null) return;

        try
        {
            await _scriptEditorModule.InvokeVoidAsync("setPropertyOverride", _scriptSelectedNodeInfo.NodeId, pin.Id, value);
            pin.OverrideValue = string.IsNullOrEmpty(value) ? null : value;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to set script property override");
        }
    }

    private static string GetNodeColor(string colorClass)
    {
        return colorClass.ToLowerInvariant() switch
        {
            "event" => "#e74c3c",
            "flow" => "#3498db",
            "action" => "#2ecc71",
            "getter" => "#9b59b6",
            "math" => "#f39c12",
            "logic" => "#1abc9c",
            _ => "#7f8c8d"
        };
    }

    private static string GetEventTabLabel(string eventType) => eventType switch
    {
        "BeforeGroupSpawn" => "Before Spawn",
        "AfterGroupSpawn" => "After Spawn",
        "OnCreatureDeath" => "Death",
        "OnCreatureSpawn" => "Creature Spawn",
        "OnBossSpawn" => "Boss Spawn",
        _ => eventType
    };

    private static string ExtractStringValue(ChangeEventArgs e) => e.Value?.ToString() ?? string.Empty;

    // ===== DTOs for JS Interop =====

    private class SelectedNodeInfo
    {
        public string NodeId { get; set; } = "";
        public string TypeId { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public List<SelectedPinInfo> InputPins { get; set; } = [];
    }

    private class SelectedPinInfo
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string DataType { get; set; } = "";
        public string? DefaultValue { get; set; }
        public string? OverrideValue { get; set; }
        public bool IsConnected { get; set; }
    }

    // ===== IAsyncDisposable =====

    public async ValueTask DisposeAsync()
    {
        await DestroyScriptEditor();

        if (_scriptEditorModule != null)
        {
            try { await _scriptEditorModule.DisposeAsync(); }
            catch { /* ignore during teardown */ }
        }

        _dotNetRef?.Dispose();
    }
}