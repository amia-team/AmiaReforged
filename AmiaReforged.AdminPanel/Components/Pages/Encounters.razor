    // ===== Condition Operator Helpers =====

    /// <summary>
    /// Returns the allowed operators for a given condition type.
    /// </summary>
    private static string[] GetOperatorsForType(SpawnConditionType type) => type switch
    {
        SpawnConditionType.TimeOfDay => ["between"],
        SpawnConditionType.ChaosThreshold => ["==", "!=", ">", ">=", "<", "<="],
        SpawnConditionType.MinPlayerCount => [">="],
        SpawnConditionType.MaxPlayerCount => ["<="],
        SpawnConditionType.RegionTag => ["==", "!=", "contains", "startswith"],
        SpawnConditionType.TriggerTag => ["==", "!=", "contains", "startswith"],
        SpawnConditionType.TriggerLocalVariableInt => ["==", "!=", ">", ">=", "<", "<=", "%"],
        SpawnConditionType.TriggerLocalVariableFloat => ["==", "!=", ">", ">=", "<", "<=", "%"],
        SpawnConditionType.TriggerLocalVariableString => ["==", "!=", "contains", "startswith"],
        SpawnConditionType.AreaLocalVariableInt => ["==", "!=", ">", ">=", "<", "<=", "%"],
        SpawnConditionType.AreaLocalVariableFloat => ["==", "!=", ">", ">=", "<", "<=", "%"],
        SpawnConditionType.AreaLocalVariableString => ["==", "!=", "contains", "startswith"],
        SpawnConditionType.Custom => ["=="],
        _ => ["=="]
    };

    /// <summary>
    /// Returns a placeholder hint for the value field based on condition type.
    /// </summary>
    private static string GetValuePlaceholder(SpawnConditionType type) => type switch
    {
        SpawnConditionType.TimeOfDay => "06:00-18:00",
        SpawnConditionType.ChaosThreshold => "Danger:50",
        SpawnConditionType.MinPlayerCount => "3",
        SpawnConditionType.MaxPlayerCount => "6",
        SpawnConditionType.RegionTag => "region_cordor",
        SpawnConditionType.TriggerTag => "db_spawntrigger",
        SpawnConditionType.TriggerLocalVariableInt => "var_name:1",
        SpawnConditionType.TriggerLocalVariableFloat => "var_name:1.5",
        SpawnConditionType.TriggerLocalVariableString => "var_name:some_value",
        SpawnConditionType.AreaLocalVariableInt => "var_name:1",
        SpawnConditionType.AreaLocalVariableFloat => "var_name:1.5",
        SpawnConditionType.AreaLocalVariableString => "var_name:some_value",
        SpawnConditionType.Custom => "(ignored)",
        _ => ""
    };

    /// <summary>
    /// When condition type changes, auto-select the first valid operator.
    /// </summary>
    private void OnNewConditionTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<SpawnConditionType>(e.Value?.ToString(), out var t))
        {
            _newConditionType = t;
            var ops = GetOperatorsForType(t);
            if (ops.Length > 0 && !ops.Contains(_newConditionOp))
                _newConditionOp = ops[0];
        }
    }

