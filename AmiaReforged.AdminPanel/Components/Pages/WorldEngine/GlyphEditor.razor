@page "/worldengine/glyphs"
@using Microsoft.AspNetCore.Authorization
@using AmiaReforged.AdminPanel.Models
@using AmiaReforged.AdminPanel.Services
@using System.Text.Json
@using System.Text.Json.Serialization
@attribute [Authorize]
@inject GlyphApiService Api
@inject EncounterApiService EncounterApi
@inject TraitApiService TraitApi
@inject IWorldEngineEndpointService EndpointService
@inject IJSRuntime JS
@inject ILogger<GlyphEditor> Logger
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>Glyph Scripts - World Engine</PageTitle>

<div class="encounters-page">
    <div class="dashboard-header">
        <h1>Glyph Visual Scripts</h1>
        <div class="header-actions">
            @if (_endpoints.Count > 0)
            {
                <div class="instance-selector">
                    <label class="instance-label">Server:</label>
                    <select class="form-control form-control-sm" value="@(_selectedEndpoint?.Id.ToString() ?? "")" @onchange="OnEndpointChanged">
                        <option value="">— Select —</option>
                        @foreach (WorldEngineEndpoint ep in _endpoints)
                        {
                            <option value="@ep.Id">@ep.Name</option>
                        }
                    </select>
                </div>
            }
            @if (_selectedEndpoint != null)
            {
                <button class="btn btn-secondary btn-sm" @onclick="RefreshDefinitions">Refresh</button>
                <button class="btn btn-primary btn-sm" @onclick="ShowCreateModal">+ New Script</button>
            }
            <a href="/" class="btn btn-secondary btn-sm">← Dashboard</a>
        </div>
    </div>

    @if (_error != null)
    {
        <div class="alert alert-danger">@_error <button class="btn btn-sm btn-secondary" style="margin-left:10px" @onclick="() => _error = null">Dismiss</button></div>
    }
    @if (_success != null)
    {
        <div class="alert alert-success">@_success <button class="btn btn-sm btn-secondary" style="margin-left:10px" @onclick="() => _success = null">Dismiss</button></div>
    }

    @if (_selectedEndpoint == null)
    {
        <div class="section" style="text-align:center;padding:60px 20px">
            @if (_endpoints.Count == 0)
            {
                <p style="color:var(--text-secondary);font-size:1.1rem">
                    No WorldEngine servers configured. Go to
                    <a href="/encounters">Encounters</a> to add one.
                </p>
            }
            else
            {
                <p style="color:var(--text-secondary);font-size:1.1rem">Select a server from the dropdown above to manage Glyph scripts.</p>
            }
        </div>
    }
    else if (_isLoading)
    {
        <div class="section" style="text-align:center;padding:40px"><em>Loading...</em></div>
    }
    else if (_editingDefinition != null)
    {
        @* ==================== Graph Editor View ==================== *@
        <div class="section">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <button class="btn btn-secondary btn-sm" @onclick="CloseEditor">← Back to List</button>
                    <strong class="ms-3">@_editingDefinition.Name</strong>
                    <span class="badge bg-info ms-2">@_editingDefinition.EventType</span>
                    @if (_editingDefinition.IsActive)
                    {
                        <span class="badge bg-success ms-1">Active</span>
                    }
                </div>
                <div>
                    <button class="btn btn-primary btn-sm" @onclick="SaveGraph" disabled="@_isSaving">
                        @(_isSaving ? "Saving..." : "Save Graph")
                    </button>
                </div>
            </div>

            <div class="row">
                @* Node Palette *@
                <div class="col-md-3">
                    <div class="card" style="background:var(--surface-color);border-color:var(--border-color)">
                        <div class="card-header" style="background:var(--surface-hover);color:var(--text-primary)">
                            <strong>Node Palette</strong>
                            <input type="text" class="form-control form-control-sm mt-2" placeholder="Search nodes..."
                                   @bind="_nodeSearchFilter" @bind:event="oninput" />
                        </div>
                        <div class="card-body p-0" style="max-height:600px;overflow-y:auto">
                            @foreach (IGrouping<string, GlyphNodeCatalogEntryDto> category in FilteredCatalog)
                            {
                                <div class="px-3 py-1" style="background:var(--surface-hover);color:var(--text-secondary);font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em">
                                    @category.Key
                                </div>
                                @foreach (GlyphNodeCatalogEntryDto node in category)
                                {
                                    <div class="px-3 py-2 glyph-node-entry" style="border-bottom:1px solid var(--border-color);cursor:pointer"
                                         draggable="true" ondragstart="event.dataTransfer.setData('application/glyph-node', '@node.TypeId')"
                                         @onclick="() => AddNodeToGraph(node)" title="@node.Description">
                                        <span class="badge me-1" style="background:@GetNodeColor(node.ColorClass)">@node.ColorClass</span>
                                        <span style="color:var(--text-primary)">@node.DisplayName</span>
                                        @if (node.RestrictToEventType != null)
                                        {
                                            <br /><small style="color:var(--text-secondary)">@node.RestrictToEventType only</small>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    @* Property Editor *@
                    @if (_selectedNodeInfo != null)
                    {
                        <div class="card mt-3" style="background:var(--surface-color);border-color:var(--border-color)">
                            <div class="card-header" style="background:var(--surface-hover);color:var(--text-primary)">
                                <strong>Properties</strong>
                                <small class="d-block" style="color:var(--text-secondary)">@_selectedNodeInfo.DisplayName</small>
                            </div>
                            <div class="card-body p-2">
                                @* Node Properties (dropdowns / free-text from definition) *@
                                @{ List<SelectedPropertyInfo> nodeProperties = _selectedNodeInfo.Properties ?? []; }
                                @foreach (SelectedPropertyInfo prop in nodeProperties)
                                {
                                    <div class="mb-2">
                                        <label class="form-label mb-0" style="font-size:0.8rem;color:var(--text-secondary)">@prop.DisplayName</label>
                                        @if (prop.AllowedValues is { Count: > 0 })
                                        {
                                            <select class="form-select form-select-sm"
                                                    value="@prop.CurrentValue"
                                                    @onchange="@(e => OnNodePropertyChanged(prop, e.Value?.ToString() ?? string.Empty))">
                                                @foreach (string opt in prop.AllowedValues)
                                                {
                                                    <option value="@opt" selected="@(opt == prop.CurrentValue)">@opt</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <input type="text" class="form-control form-control-sm"
                                                   value="@prop.CurrentValue"
                                                   @onchange="@(e => OnNodePropertyChanged(prop, e.Value?.ToString() ?? string.Empty))" />
                                        }
                                    </div>
                                }

                                @* Pin Overrides (unconnected input pins) *@
                                @{ List<SelectedPinInfo> editablePins = _selectedNodeInfo.InputPins?.Where(p => !p.IsConnected).ToList() ?? []; }
                                @if (editablePins.Count == 0 && nodeProperties.Count == 0)
                                {
                                    <p class="mb-0" style="color:var(--text-secondary);font-size:0.85rem">No editable properties. Connect or add data input pins.</p>
                                }
                                else
                                {
                                    @foreach (SelectedPinInfo pin in editablePins)
                                    {
                                        <div class="mb-2">
                                            <label class="form-label mb-0" style="font-size:0.8rem;color:var(--text-secondary)">@pin.Name <small>(@pin.DataType)</small></label>
                                            @if (pin.DataType == "Bool")
                                            {
                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input"
                                                           checked="@(GetPinValue(pin) == "true")"
                                                           @onchange="@(e => OnPropertyChanged(pin, e.Value is true ? "true" : "false"))" />
                                                </div>
                                            }
                                            else if (pin.DataType == "Int")
                                            {
                                                <input type="number" class="form-control form-control-sm"
                                                       value="@GetPinValue(pin)" step="1"
                                                       @onchange="@(e => OnPropertyChanged(pin, e.Value?.ToString() ?? string.Empty))" />
                                            }
                                            else if (pin.DataType == "Float")
                                            {
                                                <input type="number" class="form-control form-control-sm"
                                                       value="@GetPinValue(pin)" step="0.1"
                                                       @onchange="@(e => OnPropertyChanged(pin, e.Value?.ToString() ?? string.Empty))" />
                                            }
                                            else
                                            {
                                                <input type="text" class="form-control form-control-sm"
                                                       value="@GetPinValue(pin)"
                                                       @onchange="@(e => OnPropertyChanged(pin, e.Value?.ToString() ?? string.Empty))" />
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }

                    @* Bindings Panel *@
                    @if (_editingDefinition != null)
                    {
                        <div class="card mt-3" style="background:var(--surface-color);border-color:var(--border-color)">
                            <div class="card-header" style="background:var(--surface-hover);color:var(--text-primary)">
                                <strong>Bindings</strong>
                                <small class="d-block" style="color:var(--text-secondary)">Where this script is attached</small>
                            </div>
                            <div class="card-body p-2">
                                @* --- Spawn Profile Bindings --- *@
                                <div style="margin-bottom:8px">
                                    <label style="font-size:0.8rem;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.05em">Spawn Profiles</label>
                                    @if (_definitionBindings?.SpawnProfileBindings.Count > 0)
                                    {
                                        @foreach (GlyphBindingDto b in _definitionBindings.SpawnProfileBindings)
                                        {
                                            <div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid var(--border-color)">
                                                <div>
                                                    <span style="color:var(--text-primary);font-size:0.85rem">@GetProfileName(b.SpawnProfileId)</span>
                                                    <br /><small style="color:var(--text-secondary)">Priority: @b.Priority</small>
                                                </div>
                                                <button class="btn btn-outline-danger btn-sm" style="font-size:0.7rem;padding:1px 6px" @onclick="() => RemoveSpawnBinding(b.Id)">✕</button>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <p style="color:var(--text-secondary);font-size:0.8rem;margin:4px 0">No spawn profile bindings.</p>
                                    }

                                    @if (_showAddSpawnBinding)
                                    {
                                        <div style="margin-top:6px;padding:8px;background:var(--surface-hover);border-radius:6px">
                                            <select class="form-control form-control-sm mb-1" @bind="_newSpawnBindingProfileId">
                                                <option value="">— Select Profile —</option>
                                                @foreach (SpawnProfileDto p in _availableProfiles)
                                                {
                                                    <option value="@p.Id">@p.Name</option>
                                                }
                                            </select>
                                            <input type="number" class="form-control form-control-sm mb-1" @bind="_newSpawnBindingPriority" placeholder="Priority (0)" />
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-success btn-sm" style="font-size:0.75rem" @onclick="AddSpawnBinding" disabled="@_isSaving">Add</button>
                                                <button class="btn btn-secondary btn-sm" style="font-size:0.75rem" @onclick="() => _showAddSpawnBinding = false">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary btn-sm mt-1" style="font-size:0.75rem" @onclick="() => _showAddSpawnBinding = true">+ Attach Profile</button>
                                    }
                                </div>

                                @* --- Trait Bindings --- *@
                                <div>
                                    <label style="font-size:0.8rem;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.05em">Traits</label>
                                    @if (_definitionBindings?.TraitBindings.Count > 0)
                                    {
                                        @foreach (TraitGlyphBindingDto b in _definitionBindings.TraitBindings)
                                        {
                                            <div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid var(--border-color)">
                                                <div>
                                                    <span style="color:var(--text-primary);font-size:0.85rem;font-family:monospace">@b.TraitTag</span>
                                                    <br /><small style="color:var(--text-secondary)">Priority: @b.Priority</small>
                                                </div>
                                                <button class="btn btn-outline-danger btn-sm" style="font-size:0.7rem;padding:1px 6px" @onclick="() => RemoveTraitBinding(b.Id)">✕</button>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <p style="color:var(--text-secondary);font-size:0.8rem;margin:4px 0">No trait bindings.</p>
                                    }

                                    @if (_showAddTraitBinding)
                                    {
                                        <div style="margin-top:6px;padding:8px;background:var(--surface-hover);border-radius:6px">
                                            <input type="text" class="form-control form-control-sm mb-1" @bind="_newTraitBindingTag" placeholder="Trait tag (e.g. trait_cursed)" />
                                            <input type="number" class="form-control form-control-sm mb-1" @bind="_newTraitBindingPriority" placeholder="Priority (0)" />
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-success btn-sm" style="font-size:0.75rem" @onclick="AddTraitBinding" disabled="@_isSaving">Add</button>
                                                <button class="btn btn-secondary btn-sm" style="font-size:0.75rem" @onclick="() => _showAddTraitBinding = false">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary btn-sm mt-1" style="font-size:0.75rem" @onclick="() => _showAddTraitBinding = true">+ Attach Trait</button>
                                    }
                                </div>

                                @* --- Interaction Bindings --- *@
                                <div>
                                    <label style="font-size:0.8rem;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.05em">Interactions</label>
                                    @if (_definitionBindings?.InteractionBindings.Count > 0)
                                    {
                                        @foreach (InteractionGlyphBindingDto b in _definitionBindings.InteractionBindings)
                                        {
                                            <div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid var(--border-color)">
                                                <div>
                                                    <span style="color:var(--text-primary);font-size:0.85rem;font-family:monospace">@b.InteractionTag</span>
                                                    @if (!string.IsNullOrEmpty(b.AreaResRef))
                                                    {
                                                        <br /><small style="color:var(--text-secondary)">Area: @b.AreaResRef</small>
                                                    }
                                                    <br /><small style="color:var(--text-secondary)">Priority: @b.Priority</small>
                                                </div>
                                                <button class="btn btn-outline-danger btn-sm" style="font-size:0.7rem;padding:1px 6px" @onclick="() => RemoveInteractionBinding(b.Id)">✕</button>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <p style="color:var(--text-secondary);font-size:0.8rem;margin:4px 0">No interaction bindings.</p>
                                    }

                                    @if (_showAddInteractionBinding)
                                    {
                                        <div style="margin-top:6px;padding:8px;background:var(--surface-hover);border-radius:6px">
                                            <input type="text" class="form-control form-control-sm mb-1" @bind="_newInteractionBindingTag" placeholder="Interaction tag (e.g. prospecting)" />
                                            <input type="text" class="form-control form-control-sm mb-1" @bind="_newInteractionBindingAreaResRef" placeholder="Area ResRef (optional)" />
                                            <input type="number" class="form-control form-control-sm mb-1" @bind="_newInteractionBindingPriority" placeholder="Priority (0)" />
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-success btn-sm" style="font-size:0.75rem" @onclick="AddInteractionBinding" disabled="@_isSaving">Add</button>
                                                <button class="btn btn-secondary btn-sm" style="font-size:0.75rem" @onclick="() => _showAddInteractionBinding = false">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary btn-sm mt-1" style="font-size:0.75rem" @onclick="() => _showAddInteractionBinding = true">+ Attach Interaction</button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* Graph Canvas *@
                <div class="@(_showContextPanel ? "col-md-7" : "col-md-9")">
                    <div id="glyph-editor-container"
                         style="width:100%;height:650px;background:#1a1a2e;border:2px solid var(--border-color);border-radius:8px;position:relative;overflow:hidden">
                        <div id="glyph-rete-canvas" style="width:100%;height:100%"></div>
                        <div style="position:absolute;bottom:8px;right:12px;display:flex;gap:6px;align-items:center">
                            <button class="btn btn-sm btn-outline-secondary" style="font-size:0.7rem;padding:2px 8px" @onclick="FitAll" title="Fit all nodes in view">Fit All</button>
                            <button class="btn btn-sm btn-outline-secondary" style="font-size:0.7rem;padding:2px 8px" @onclick="ArrangeNodes" title="Auto-arrange node layout">Arrange</button>
                            <span style="color:#666;font-size:0.75rem">Glyph Visual Editor</span>
                        </div>
                    </div>
                </div>

                @* Context Nodes Panel *@
                @if (_showContextPanel)
                {
                    <div class="col-md-2">
                        <div class="card" style="background:var(--surface-color);border-color:var(--border-color)">
                            <div class="card-header d-flex justify-content-between align-items-center" style="background:var(--surface-hover);color:var(--text-primary);padding:8px 12px">
                                <strong style="font-size:0.85rem">📌 Context Nodes</strong>
                                <button class="btn btn-sm p-0" style="color:var(--text-secondary);font-size:0.9rem;line-height:1" @onclick="() => _showContextPanel = false" title="Close">✕</button>
                            </div>
                            <div class="card-body p-0" style="max-height:600px;overflow-y:auto">
                                @foreach (GlyphNodeCatalogEntryDto ctxNode in ContextCatalog)
                                {
                                    <div class="px-3 py-2 glyph-node-entry" style="border-bottom:1px solid var(--border-color);cursor:pointer"
                                         draggable="true" ondragstart="event.dataTransfer.setData('application/glyph-node', '@ctxNode.TypeId')"
                                         @onclick="() => AddNodeToGraph(ctxNode)" title="@ctxNode.Description">
                                        <span class="badge me-1" style="background:@GetNodeColor(ctxNode.ColorClass)">@ctxNode.ColorClass</span>
                                        <span style="color:var(--text-primary);font-size:0.85rem">@ctxNode.DisplayName</span>
                                    </div>
                                }
                                @if (!ContextCatalog.Any())
                                {
                                    <p class="px-3 py-2 mb-0" style="color:var(--text-secondary);font-size:0.8rem">No context nodes available.</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        @* ==================== Definitions List View ==================== *@
        <div class="section">
            <h3 style="color:var(--text-primary)">Glyph Definitions</h3>
            @if (_definitions.Count == 0)
            {
                <p style="color:var(--text-secondary)">No Glyph scripts defined yet. Click "+ New Script" to create one.</p>
            }
            else
            {
                <table class="table table-sm" style="color:var(--text-primary)">
                    <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Event Type</th>
                        <th>Active</th>
                        <th>Updated</th>
                        <th style="width:200px">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (GlyphDefinitionDto def in _definitions)
                    {
                        <tr>
                            <td>@def.Name</td>
                            <td><span class="badge bg-secondary">@def.Category</span></td>
                            <td><span class="badge bg-info">@def.EventType</span></td>
                            <td>
                                @if (def.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@def.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <button class="btn btn-primary btn-sm" @onclick="() => OpenEditor(def)">Edit</button>
                                <button class="btn btn-warning btn-sm" @onclick="() => ToggleActive(def)">
                                    @(def.IsActive ? "Deactivate" : "Activate")
                                </button>
                                <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(def)">Delete</button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    }

    @* ==================== Create / Edit Metadata Modal ==================== *@
    @if (_showCreateModal)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog">
                <div class="modal-content" style="background:var(--surface-color);color:var(--text-primary)">
                    <div class="modal-header" style="border-color:var(--border-color)">
                        <h5 class="modal-title">New Glyph Script</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="() => _showCreateModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" @bind="_createName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select class="form-control" @bind="_createCategory">
                                <option value="Encounter">Encounter</option>
                                <option value="Trait">Trait</option>
                                <option value="Interaction">Interaction</option>
                                <option value="Environmental">Environmental</option>
                                <option value="Narrative">Narrative</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Event Type</label>
                            <select class="form-control" @bind="_createEventType">
                                <option value="">— Select —</option>
                                @foreach (string et in GetEventTypesForCategory(_createCategory))
                                {
                                    <option value="@et">@et</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="2" @bind="_createDescription"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-color:var(--border-color)">
                        <button class="btn btn-secondary" @onclick="() => _showCreateModal = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="CreateDefinition" disabled="@_isSaving">
                            @(_isSaving ? "Creating..." : "Create")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ==================== Delete Confirmation Modal ==================== *@
    @if (_deleteTarget != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-sm">
                <div class="modal-content" style="background:var(--surface-color);color:var(--text-primary)">
                    <div class="modal-header" style="border-color:var(--border-color)">
                        <h5 class="modal-title">Confirm Delete</h5>
                    </div>
                    <div class="modal-body">
                        Delete script <strong>@_deleteTarget.Name</strong> and all its bindings?
                    </div>
                    <div class="modal-footer" style="border-color:var(--border-color)">
                        <button class="btn btn-secondary" @onclick="() => _deleteTarget = null">Cancel</button>
                        <button class="btn btn-danger" @onclick="DeleteDefinition">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // ==================== State ====================
    private List<WorldEngineEndpoint> _endpoints = [];
    private WorldEngineEndpoint? _selectedEndpoint;
    private List<GlyphDefinitionDto> _definitions = [];
    private List<GlyphNodeCatalogEntryDto> _nodeCatalog = [];
    private GlyphDefinitionDto? _editingDefinition;

    private bool _isLoading;
    private bool _isSaving;
    private string? _error;
    private string? _success;

    // Create modal
    private bool _showCreateModal;
    private string _createName = "";
    private string _createCategory = "Encounter";
    private string _createEventType = "";
    private string _createDescription = "";

    // Delete confirmation
    private GlyphDefinitionDto? _deleteTarget;

    // Node palette search
