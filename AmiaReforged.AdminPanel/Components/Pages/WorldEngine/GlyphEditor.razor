    [JSInvokable]
    public Task OnNodeSelectionChanged(string? json)
    {
        if (string.IsNullOrEmpty(json) || json == "null")
        {
            _selectedNodeInfo = null;
        }
        else
        {
            try
            {
                _selectedNodeInfo = JsonSerializer.Deserialize<SelectedNodeInfo>(json, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

                // Diagnostic: log what was deserialized
                if (_selectedNodeInfo != null)
                {
                    Logger.LogInformation(
                        "[GlyphEditor] Deserialized node {NodeId}: InputPins={PinCount}, Properties={PropCount}",
                        _selectedNodeInfo.NodeId,
                        _selectedNodeInfo.InputPins?.Count ?? -1,
                        _selectedNodeInfo.Properties?.Count ?? -1);

                    // Fallback: if Properties is empty, try manual extraction from the raw JSON
                    if ((_selectedNodeInfo.Properties?.Count ?? 0) == 0)
                    {
                        using JsonDocument doc = JsonDocument.Parse(json);
                        if (doc.RootElement.TryGetProperty("properties", out JsonElement propsElem)
                            && propsElem.ValueKind == JsonValueKind.Array
                            && propsElem.GetArrayLength() > 0)
                        {
                            Logger.LogWarning(
                                "[GlyphEditor] Properties array has {Count} elements in JSON but deserialized as 0. Attempting manual parse.",
                                propsElem.GetArrayLength());

                            List<SelectedPropertyInfo> manualProps = [];
                            foreach (JsonElement propElem in propsElem.EnumerateArray())
                            {
                                manualProps.Add(new SelectedPropertyInfo
                                {
                                    Id = propElem.GetProperty("id").GetString() ?? "",
                                    DisplayName = propElem.GetProperty("displayName").GetString() ?? "",
                                    DefaultValue = propElem.GetProperty("defaultValue").GetString() ?? "",
                                    AllowedValues = propElem.TryGetProperty("allowedValues", out JsonElement av)
                                        ? av.EnumerateArray().Select(v => v.GetString() ?? "").ToList()
                                        : [],
                                    CurrentValue = propElem.TryGetProperty("currentValue", out JsonElement cv)
                                        ? cv.GetString() ?? ""
                                        : "",
                                });
                            }
                            _selectedNodeInfo.Properties = manualProps;
                            Logger.LogWarning("[GlyphEditor] Manual parse recovered {Count} properties.", manualProps.Count);
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "[GlyphEditor] Failed to deserialize node selection JSON: {Json}", json);
                _selectedNodeInfo = null;
            }
        }

        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private string GetPinValue(SelectedPinInfo pin)
    {
        return pin.OverrideValue ?? pin.DefaultValue ?? "";
    }

    private async Task OnPropertyChanged(SelectedPinInfo pin, string value)
    {
        if (_editorModule == null || _selectedNodeInfo == null) return;

        try
        {
            await _editorModule.InvokeVoidAsync("setPropertyOverride", _selectedNodeInfo.NodeId, pin.Id, value);
            pin.OverrideValue = string.IsNullOrEmpty(value) ? null : value;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to set property override");
        }
    }

    private async Task OnNodePropertyChanged(SelectedPropertyInfo prop, string value)
    {
        if (_editorModule == null || _selectedNodeInfo == null) return;

        try
        {
            await _editorModule.InvokeVoidAsync("setPropertyOverride", _selectedNodeInfo.NodeId, prop.Id, value);
            prop.CurrentValue = value;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to set node property");
        }
    }

    private static List<string> GetEventTypesForCategory(string category)
    {
        return category switch
        {
            "Encounter" => ["BeforeGroupSpawn", "AfterGroupSpawn", "OnCreatureDeath", "OnCreatureSpawn", "OnBossSpawn"],
            "Trait" => ["OnTraitGranted", "OnTraitRemoved"],
            "Interaction" => ["InteractionPipeline"],
            "Environmental" => ["BeforeGroupSpawn", "AfterGroupSpawn", "OnCreatureDeath", "OnCreatureSpawn", "OnBossSpawn"],
            "Narrative" => ["BeforeGroupSpawn", "AfterGroupSpawn", "OnCreatureDeath", "OnCreatureSpawn", "OnBossSpawn"],
            _ => ["BeforeGroupSpawn", "AfterGroupSpawn", "OnCreatureDeath", "OnCreatureSpawn", "OnBossSpawn"]
        };
    }

