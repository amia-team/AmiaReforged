    {
        return _availableProfiles.FirstOrDefault(p => p.Id == profileId)?.Name ?? profileId.ToString()[..8] + "…";
    }

    private async Task AddSpawnBinding()
    {
        if (_editingDefinition == null || string.IsNullOrEmpty(_newSpawnBindingProfileId)) return;
        if (!Guid.TryParse(_newSpawnBindingProfileId, out Guid profileId)) return;

        _isSaving = true;
        try
        {
            await Api.CreateBindingAsync(new CreateGlyphBindingRequest(profileId, _editingDefinition.Id, _newSpawnBindingPriority));
            await LoadDefinitionBindings(_editingDefinition.Id);
            _showAddSpawnBinding = false;
            _newSpawnBindingProfileId = "";
            _newSpawnBindingPriority = 0;
            _success = "Spawn profile binding added.";
        }
        catch (Exception ex)
        {
            _error = $"Failed to add binding: {ex.Message}";
            Logger.LogError(ex, "Failed to add spawn binding");
        }
        finally { _isSaving = false; }
    }

