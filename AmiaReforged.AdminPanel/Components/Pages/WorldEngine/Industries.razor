                                   @oninput="(e) => OnItemPickerInput(e, productKey)"
                                   @onblur="DismissPickerDelayed" />
                            @if (!string.IsNullOrEmpty(_editRecipe.Products[i].ItemTag) && _activePickerKey != productKey)
                            {
                                <span class="item-picker-tag-badge">@_editRecipe.Products[i].ItemTag</span>
                            }
                            @if (_activePickerKey == productKey)
                            {
                                <div class="item-picker-dropdown">
                                    @if (_itemPickerLoading)
                                    {
                                        <div class="item-picker-status">Searching...</div>
                                    }
                                    else if (_itemPickerResults.Count == 0 && _itemPickerSearch.Length >= 2)
                                    {
                                        <div class="item-picker-status">No items found</div>
                                    }
                                    else if (_itemPickerSearch.Length < 2)
                                    {
                                        <div class="item-picker-status">Type at least 2 characters</div>
                                    }
                                    else
                                    {
                                        @foreach (ItemBlueprintDto item in _itemPickerResults)
                                        {
                                            <div class="item-picker-item" @onmousedown="() => SelectItemForProduct(i, item.ItemTag)" @onmousedown:preventDefault>
                                                <div class="item-picker-name">@item.Name</div>
                                                <div class="item-picker-detail">@item.ItemTag</div>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        </div>
                        <input type="number" class="form-control form-control-sm" style="flex:1" placeholder="Qty" @bind="_editRecipe.Products[i].Quantity" />
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => _editRecipe.Products.RemoveAt(i)">X</button>
                    </div>
                }
                <button class="btn btn-sm btn-outline-secondary" style="margin-top:6px" @onclick="() => _editRecipe.Products.Add(new IndustryProductDto())">+ Product</button>
            </div>
        </div>

        <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px">
            <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveRecipe" disabled="@_isSaving">
                @(_isSaving ? "Saving..." : "Save")
            </button>
        </div>
    </div>
    </div>
}

