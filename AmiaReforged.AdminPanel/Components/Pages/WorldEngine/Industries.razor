    // ==================== Item Picker ====================

    private void OpenItemPicker(string key, string currentValue)
    {
        _activePickerKey = key;
        _itemPickerSearch = currentValue ?? "";
        _itemPickerResults = [];
    }

    private void OnItemPickerInput(ChangeEventArgs e, string key)
    {
        _activePickerKey = key;
        _itemPickerSearch = e.Value?.ToString() ?? "";

        _debounceTimer?.Dispose();

        if (_itemPickerSearch.Length < 2)
        {
            _itemPickerResults = [];
            _itemPickerLoading = false;
            return;
        }

        _itemPickerLoading = true;
        string searchText = _itemPickerSearch;

        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                PagedResult<ItemBlueprintDto> result = await ItemApi.GetAllAsync(searchText, 1, 15);
                await InvokeAsync(() =>
                {
                    if (_activePickerKey == key && _itemPickerSearch == searchText)
                    {
                        _itemPickerResults = result.Items;
                        _itemPickerLoading = false;
                        StateHasChanged();
                    }
                });
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Item search failed");
                await InvokeAsync(() =>
                {
                    _itemPickerLoading = false;
                    _itemPickerResults = [];
                    StateHasChanged();
                });
            }
        }, null, 300, Timeout.Infinite);
    }

    private void SelectItemForIngredient(int index, string itemTag)
    {
        if (index >= 0 && index < _editRecipe.Ingredients.Count)
        {
            _editRecipe.Ingredients[index].ItemTag = itemTag;
        }
        DismissItemPicker();
    }

    private void SelectItemForProduct(int index, string itemTag)
    {
        if (index >= 0 && index < _editRecipe.Products.Count)
        {
            _editRecipe.Products[index].ItemTag = itemTag;
        }
        DismissItemPicker();
    }

    private void DismissItemPicker()
    {
        _activePickerKey = null;
        _itemPickerSearch = "";
        _itemPickerResults = [];
        _itemPickerLoading = false;
    }

    private async Task DismissPickerDelayed()
    {
        // Short delay so @onmousedown on dropdown items fires before the blur dismisses the picker
        await Task.Delay(200);
        await InvokeAsync(() =>
        {
            DismissItemPicker();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}

