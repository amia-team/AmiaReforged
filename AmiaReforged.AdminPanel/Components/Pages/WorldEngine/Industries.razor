@page "/worldengine/industries"
@using AmiaReforged.AdminPanel.Models
@using AmiaReforged.AdminPanel.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable

@inject IndustryApiService IndustryApi
@inject WorkstationApiService WorkstationApi
@inject ItemApiService ItemApi
@inject RecipeTemplateApiService TemplateApi
@inject IWorldEngineEndpointService EndpointService
@inject ILogger<Industries> Logger

<PageTitle>Industries — WorldEngine</PageTitle>
<h3>Industries &amp; Crafting</h3>

@* ==================== Endpoint Selector ==================== *@
<div class="row mb-3">
    <div class="col-md-4">
        <label class="form-label fw-bold">Server Endpoint</label>
        <select class="form-select" value="@_selectedEndpointId" @onchange="OnEndpointChanged">
            <option value="">— Select endpoint —</option>
            @foreach (WorldEngineEndpoint ep in _endpoints)
            {
                <option value="@ep.Id">@ep.Name</option>
            }
        </select>
    </div>
</div>

@if (string.IsNullOrEmpty(_selectedEndpointId))
{
    <div class="alert alert-info">Select a server endpoint to manage industries.</div>
    return;
}

@* ==================== Tab Navigation ==================== *@
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "overview" ? "active" : "")" @onclick='() => SetTab("overview")'>Overview</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "knowledge" ? "active" : "")" @onclick='() => SetTab("knowledge")'>Knowledge Graph</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "recipes" ? "active" : "")" @onclick='() => SetTab("recipes")'>Recipes</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "workstations" ? "active" : "")" @onclick='() => SetTab("workstations")'>Workstations</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "templates" ? "active" : "")" @onclick='() => SetTab("templates")'>Recipe Templates</button>
    </li>
</ul>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger alert-dismissible">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_success))
{
    <div class="alert alert-success alert-dismissible">
        @_success
        <button type="button" class="btn-close" @onclick="() => _success = null"></button>
    </div>
}

@* ==================== OVERVIEW TAB ==================== *@
@if (_activeTab == "overview")
{
    <div class="row mb-3">
        <div class="col-md-4">
            <input class="form-control" placeholder="Search industries..." @bind="_industrySearch" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" @onclick="RefreshIndustries">Search</button>
        </div>
        <div class="col-md-2">
            <button class="btn btn-success w-100" @onclick="StartCreateIndustry">+ New Industry</button>
        </div>
    </div>

    @if (_isLoading)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Tag</th>
                    <th>Name</th>
                    <th>Knowledge</th>
                    <th>Recipes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (IndustryDefinitionDto industry in _industries)
                {
                    <tr>
                        <td><code>@industry.Tag</code></td>
                        <td>@industry.Name</td>
                        <td>@industry.Knowledge.Count</td>
                        <td>@industry.Recipes.Count</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditIndustry(industry)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeleteIndustry(industry)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @* Pagination *@
        @if (_industryTotalCount > _pageSize)
        {
            <nav>
                <ul class="pagination">
                    @for (int i = 1; i <= Math.Ceiling((double)_industryTotalCount / _pageSize); i++)
                    {
                        int pageNum = i;
                        <li class="page-item @(_page == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
}

@* ==================== KNOWLEDGE GRAPH TAB ==================== *@
@if (_activeTab == "knowledge")
{
    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Select Industry</label>
            <select class="form-select" value="@_selectedIndustryTag" @onchange="OnIndustrySelected">
                <option value="">— Select —</option>
                @foreach (IndustryDefinitionDto ind in _industries)
                {
                    <option value="@ind.Tag">@ind.Name (@ind.Tag)</option>
                }
            </select>
        </div>
        @if (_selectedIndustry != null)
        {
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-success w-100" @onclick="StartCreateKnowledge">+ Add Knowledge</button>
            </div>
        }
    </div>

    @if (_selectedIndustry != null)
    {
        @* Group by branch *@
        IOrderedEnumerable<IGrouping<string, IndustryKnowledgeDto>> branches = _selectedIndustry.Knowledge
            .GroupBy(k => k.Branch ?? "(No Branch)")
            .OrderBy(g => g.Key);

        @foreach (IGrouping<string, IndustryKnowledgeDto> branch in branches)
        {
            <h5 class="mt-3">@branch.Key</h5>
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Tag</th>
                        <th>Name</th>
                        <th>Level</th>
                        <th>Cost</th>
                        <th>Prerequisites</th>
                        <th>Effects</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (IndustryKnowledgeDto k in branch.OrderBy(k => k.Level).ThenBy(k => k.Tag))
                    {
                        <tr>
                            <td><code>@k.Tag</code></td>
                            <td>@k.Name</td>
                            <td>@k.Level</td>
                            <td>@k.PointCost</td>
                            <td>@string.Join(", ", k.Prerequisites)</td>
                            <td>@k.Effects.Count</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditKnowledge(k)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveKnowledge(k)">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
}

@* ==================== RECIPES TAB ==================== *@
@if (_activeTab == "recipes")
{
    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Select Industry</label>
            <select class="form-select" value="@_selectedIndustryTag" @onchange="OnIndustrySelected">
                <option value="">— Select —</option>
                @foreach (IndustryDefinitionDto ind in _industries)
                {
                    <option value="@ind.Tag">@ind.Name (@ind.Tag)</option>
                }
            </select>
        </div>
        @if (_selectedIndustry != null)
        {
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-success w-100" @onclick="StartCreateRecipe">+ Add Recipe</button>
            </div>
        }
    </div>

    @if (_selectedIndustry != null)
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Recipe ID</th>
                    <th>Name</th>
                    <th>Workstation</th>
                    <th>Tools</th>
                    <th>Ingredients</th>
                    <th>Products</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (IndustryRecipeDto r in _selectedIndustry.Recipes)
                {
                    <tr>
                        <td><code>@r.RecipeId</code></td>
                        <td>@r.Name</td>
                        <td>@(r.RequiredWorkstation ?? "—")</td>
                        <td>@(r.RequiredTools.Count > 0 ? string.Join(", ", r.RequiredTools) : "—")</td>
                        <td>@r.Ingredients.Count</td>
                        <td>@r.Products.Count</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditRecipe(r)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveRecipe(r)">Remove</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@* ==================== WORKSTATIONS TAB ==================== *@
@if (_activeTab == "workstations")
{
    <div class="row mb-3">
        <div class="col-md-4">
            <input class="form-control" placeholder="Search workstations..." @bind="_workstationSearch" @bind:event="oninput" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" @onclick="RefreshWorkstations">Search</button>
        </div>
        <div class="col-md-2">
            <button class="btn btn-success w-100" @onclick="StartCreateWorkstation">+ New Workstation</button>
        </div>
    </div>

    @if (_isLoading)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Tag</th>
                    <th>Name</th>
                    <th>ResRef</th>
                    <th>Supported Industries</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (WorkstationDefinitionDto ws in _workstations)
                {
                    <tr>
                        <td><code>@ws.Tag</code></td>
                        <td>@ws.Name</td>
                        <td>@(ws.PlaceableResRef ?? "—")</td>
                        <td>@string.Join(", ", ws.SupportedIndustries)</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditWorkstation(ws)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeleteWorkstation(ws)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@* ==================== RECIPE TEMPLATES TAB ==================== *@
@if (_activeTab == "templates")
{
    <div class="row mb-3">
        <div class="col-md-4">
            <input class="form-control" placeholder="Search templates..." @bind="_templateSearch" @bind:event="oninput" @onkeyup="OnTemplateSearchKeyUp" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" @onclick="RefreshTemplates">Search</button>
        </div>
        <div class="col-md-2">
            <button class="btn btn-success w-100" @onclick="StartCreateTemplate">+ New Template</button>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100" @onclick="InvalidateTemplateCache">
                <span class="bi bi-arrow-clockwise"></span> Invalidate Cache
            </button>
        </div>
    </div>

    @if (_isLoading)
    {
        <p><em>Loading...</em></p>
    }
    else if (_templateList.Count == 0)
    {
        <p class="text-muted">No recipe templates found.</p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Tag</th>
                    <th>Name</th>
                    <th>Industry</th>
                    <th>Ingredients</th>
                    <th>Products</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (RecipeTemplateDefinitionDto t in _templateList)
                {
                    <tr>
                        <td><code>@t.Tag</code></td>
                        <td>@t.Name</td>
                        <td>@t.IndustryTag</td>
                        <td>@t.Ingredients.Count</td>
                        <td>@t.Products.Count</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditTemplate(t.Tag)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeleteTemplate(t)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (_templateTotalCount > _pageSize)
        {
            <nav>
                <ul class="pagination">
                    @for (int i = 1; i <= Math.Ceiling((double)_templateTotalCount / _pageSize); i++)
                    {
                        int pageNum = i;
                        <li class="page-item @(_templatePage == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToTemplatePage(pageNum)">@pageNum</button>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
}

@* ==================== INDUSTRY EDIT MODAL ==================== *@
@if (_showIndustryModal)
{
    <div class="modal-backdrop" @onclick="CloseModals">
    <div class="admin-modal" @onclick:stopPropagation="true" style="max-width:550px;margin:15vh auto;background:var(--bg-card);border-radius:12px;padding:30px;position:fixed;top:0;left:50%;transform:translateX(-50%);z-index:1050;box-shadow:0 10px 40px rgba(0,0,0,0.5)">
        <h2>@(_isCreating ? "Create Industry" : "Edit Industry")</h2>

        <div style="display:flex;flex-direction:column;gap:12px;margin-top:15px">
            <div class="form-group">
                <label>Tag <small style="color:var(--text-secondary)">(unique identifier)</small></label>
                <input class="form-control" @bind="_editIndustry.Tag" disabled="@(!_isCreating)" placeholder="e.g. blacksmithing" />
            </div>
            <div class="form-group">
                <label>Name</label>
                <input class="form-control" @bind="_editIndustry.Name" placeholder="e.g. Blacksmithing" />
            </div>
        </div>

        <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px">
            <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveIndustry" disabled="@_isSaving">
                @(_isSaving ? "Saving..." : "Save")
            </button>
        </div>
    </div>
    </div>
}

@* ==================== WORKSTATION EDIT MODAL ==================== *@
@if (_showWorkstationModal)
{
    <div class="modal-backdrop" @onclick="CloseModals">
    <div class="admin-modal" @onclick:stopPropagation="true" style="max-width:650px;margin:10vh auto;background:var(--bg-card);border-radius:12px;padding:30px;position:fixed;top:0;left:50%;transform:translateX(-50%);z-index:1050;box-shadow:0 10px 40px rgba(0,0,0,0.5)">
        <h2>@(_isCreating ? "Create Workstation" : "Edit Workstation")</h2>

        <div style="display:flex;flex-direction:column;gap:12px;margin-top:15px">
            <div class="form-row" style="display:flex;gap:10px">
                <div class="form-group" style="flex:1">
                    <label>Tag <small style="color:var(--text-secondary)">(unique identifier)</small></label>
                    <input class="form-control" @bind="_editWorkstation.Tag" disabled="@(!_isCreating)" placeholder="e.g. forge" />
                </div>
                <div class="form-group" style="flex:1">
                    <label>Name</label>
                    <input class="form-control" @bind="_editWorkstation.Name" placeholder="e.g. Forge" />
                </div>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea class="form-control" rows="2" @bind="_editWorkstation.Description" placeholder="What this workstation is used for..."></textarea>
            </div>
            <div class="form-group">
                <label>Placeable ResRef <small style="color:var(--text-secondary)">(NWN blueprint)</small></label>
                <input class="form-control" @bind="_editWorkstation.PlaceableResRef" placeholder="e.g. plc_forge01" />
            </div>
            <div class="form-group">
                <label>Appearance ID <small style="color:var(--text-secondary)">(placeable table row index, leave blank for default)</small></label>
                <input class="form-control" type="number" value="@(_editWorkstation.AppearanceId)"
                       @onchange="OnWorkstationAppearanceChanged" placeholder="e.g. 50" />
            </div>
            <div class="form-group">
                <label>Supported Industries <small style="color:var(--text-secondary)">(comma-separated tags)</small></label>
                <input class="form-control" @bind="_editWorkstationIndustriesText" placeholder="e.g. blacksmithing, jewelcrafting" />
            </div>
        </div>

        <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px">
            <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveWorkstation" disabled="@_isSaving">
                @(_isSaving ? "Saving..." : "Save")
            </button>
        </div>
    </div>
    </div>
}

@* ==================== KNOWLEDGE EDIT MODAL ==================== *@
@if (_showKnowledgeModal)
{
    <div class="modal-backdrop" @onclick="CloseModals">
    <div class="admin-modal" @onclick:stopPropagation="true" style="max-width:850px;max-height:90vh;overflow-y:auto;margin:3vh auto;background:var(--bg-card);border-radius:12px;padding:30px;position:fixed;top:0;left:50%;transform:translateX(-50%);z-index:1050;box-shadow:0 10px 40px rgba(0,0,0,0.5)">
        <h2>@(_isCreating ? "Add Knowledge" : "Edit Knowledge")</h2>

        <div style="display:flex;flex-direction:column;gap:12px;margin-top:15px">
            <div class="form-row" style="display:flex;gap:10px">
                <div class="form-group" style="flex:1">
                    <label>Tag <small style="color:var(--text-secondary)">(unique identifier)</small></label>
                    <input class="form-control" @bind="_editKnowledge.Tag" disabled="@(!_isCreating)" placeholder="e.g. basic_smelting" />
                </div>
                <div class="form-group" style="flex:1">
                    <label>Name</label>
                    <input class="form-control" @bind="_editKnowledge.Name" placeholder="e.g. Basic Smelting" />
                </div>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea class="form-control" rows="2" @bind="_editKnowledge.Description" placeholder="What this knowledge represents..."></textarea>
            </div>
            <div class="form-row" style="display:flex;gap:10px">
                <div class="form-group" style="flex:1">
                    <label>Level</label>
                    <select class="form-control" @bind="_editKnowledge.Level">
                        <option value="Layman">Layman</option>
                        <option value="Novice">Novice</option>
                        <option value="Apprentice">Apprentice</option>
                        <option value="Journeyman">Journeyman</option>
                        <option value="Expert">Expert</option>
                        <option value="Master">Master</option>
                        <option value="Grandmaster">Grandmaster</option>
                    </select>
                </div>
                <div class="form-group" style="width:120px">
                    <label>Point Cost</label>
                    <input type="number" class="form-control" @bind="_editKnowledge.PointCost" />
                </div>
                <div class="form-group" style="flex:1">
                    <label>Branch</label>
                    <input class="form-control" @bind="_editKnowledge.Branch" placeholder="e.g. Bladesmith" />
                </div>
            </div>
            <div class="form-group">
                <label>Prerequisites <small style="color:var(--text-secondary)">(comma-separated tags)</small></label>
                <input class="form-control" @bind="_editKnowledgePrereqText" placeholder="basic_smelting, ore_knowledge" />
            </div>

            @* Harvest Effects *@
            <div style="margin-top:12px">
                <label style="font-weight:600">Harvest Effects</label>
                <small style="color:var(--text-secondary);display:block;margin-bottom:6px">Modify harvest node behaviour when this knowledge is learned</small>
                @for (int idx = 0; idx < _editKnowledge.HarvestEffects.Count; idx++)
                {
                    int i = idx;
                    <div style="display:flex;gap:8px;margin-top:4px;align-items:center">
                        <div class="form-group" style="flex:2">
                            <input class="form-control form-control-sm" placeholder="e.g. ore_vein_* or type:ore" @bind="_editKnowledge.HarvestEffects[i].NodeTag" />
                        </div>
                        <div class="form-group" style="flex:2">
                            <select class="form-control form-control-sm" @bind="_editKnowledge.HarvestEffects[i].StepModified">
                                <option value="">-- Step --</option>
                                <option value="ItemYield">Item Yield</option>
                                <option value="Quality">Quality</option>
                                <option value="HarvestStepRate">Harvest Rate</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex:1">
                            <input type="number" step="any" class="form-control form-control-sm" placeholder="Value" @bind="_editKnowledge.HarvestEffects[i].Value" />
                        </div>
                        <div class="form-group" style="flex:2">
                            <select class="form-control form-control-sm" @bind="_editKnowledge.HarvestEffects[i].Operation">
                                <option value="">-- Op --</option>
                                <option value="Additive">Additive</option>
                                <option value="PercentMult">Percent Mult</option>
                                <option value="Subtractive">Subtractive</option>
                            </select>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => _editKnowledge.HarvestEffects.RemoveAt(i)">X</button>
                    </div>
                }
                <button class="btn btn-sm btn-outline-secondary" style="margin-top:6px" @onclick="AddHarvestEffect">+ Harvest Effect</button>
            </div>

            @* Knowledge Effects *@
            <div style="margin-top:12px">
                <label style="font-weight:600">Knowledge Effects</label>
                <small style="color:var(--text-secondary);display:block;margin-bottom:6px">Actions triggered when this knowledge is learned</small>
                @for (int idx = 0; idx < _editKnowledge.Effects.Count; idx++)
                {
                    int i = idx;
                    <div style="display:flex;gap:8px;margin-top:4px;align-items:center">
                        <div class="form-group" style="flex:2">
                            <select class="form-control form-control-sm" @bind="_editKnowledge.Effects[i].EffectType">
                                <option value="">-- Effect Type --</option>
                                <option value="UnlockRecipe">Unlock Recipe</option>
                                <option value="GrantCodexEntry">Grant Codex Entry</option>
                                <option value="ModifyHarvest">Modify Harvest</option>
                                <option value="UnlockInteraction">Unlock Interaction</option>
                                <option value="Custom">Custom</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex:3">
                            <input class="form-control form-control-sm" placeholder="@GetKnowledgeEffectPlaceholder(_editKnowledge.Effects[i].EffectType)" @bind="_editKnowledge.Effects[i].TargetTag" />
                        </div>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => _editKnowledge.Effects.RemoveAt(i)">X</button>
                    </div>
                }
                <button class="btn btn-sm btn-outline-secondary" style="margin-top:6px" @onclick="AddKnowledgeEffect">+ Knowledge Effect</button>
            </div>

            @* Crafting Modifiers *@
            <div style="margin-top:12px">
                <label style="font-weight:600">Crafting Modifiers</label>
                <small style="color:var(--text-secondary);display:block;margin-bottom:6px">Modify crafting recipe outcomes when this knowledge is possessed</small>
                @for (int idx = 0; idx < _editKnowledge.CraftingModifiers.Count; idx++)
                {
                    int i = idx;
                    <div style="display:flex;gap:8px;margin-top:4px;align-items:center">
                        <div class="form-group" style="flex:2">
                            <select class="form-control form-control-sm" @bind="_editKnowledge.CraftingModifiers[i].Scope">
                                <option value="">-- Scope --</option>
                                <option value="Recipe">Recipe</option>
                                <option value="Industry">Industry</option>
                                <option value="Global">Global</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex:2">
                            <input class="form-control form-control-sm" placeholder="@GetCraftingModifierPlaceholder(_editKnowledge.CraftingModifiers[i].Scope)" @bind="_editKnowledge.CraftingModifiers[i].TargetTag" />
                        </div>
                        <div class="form-group" style="flex:2">
                            <select class="form-control form-control-sm" @bind="_editKnowledge.CraftingModifiers[i].StepModified">
                                <option value="">-- Step --</option>
                                <option value="Quality">Quality</option>
                                <option value="Quantity">Quantity</option>
                                <option value="SuccessChance">Success Chance</option>
                                <option value="CraftingTime">Crafting Time</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex:1">
                            <input type="number" step="any" class="form-control form-control-sm" placeholder="Value" @bind="_editKnowledge.CraftingModifiers[i].Value" />
                        </div>
                        <div class="form-group" style="flex:2">
                            <select class="form-control form-control-sm" @bind="_editKnowledge.CraftingModifiers[i].Operation">
                                <option value="">-- Op --</option>
                                <option value="Additive">Additive</option>
                                <option value="PercentMult">Percent Mult</option>
                                <option value="Subtractive">Subtractive</option>
                            </select>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => _editKnowledge.CraftingModifiers.RemoveAt(i)">X</button>
                    </div>
                }
                <button class="btn btn-sm btn-outline-secondary" style="margin-top:6px" @onclick="AddCraftingModifier">+ Crafting Modifier</button>
            </div>
        </div>

        <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px">
            <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveKnowledge" disabled="@_isSaving">
                @(_isSaving ? "Saving..." : "Save")
            </button>
        </div>
    </div>
    </div>
}

@* ==================== RECIPE EDIT MODAL ==================== *@
@if (_showRecipeModal)
{
    <div class="modal-backdrop" @onclick="CloseModals">
