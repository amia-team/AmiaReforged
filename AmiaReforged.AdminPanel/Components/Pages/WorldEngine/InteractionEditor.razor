    // ═══════════════════════════════════════════════════════════════════
    //  View Menu / Panel Management
    // ═══════════════════════════════════════════════════════════════════

    private async Task TogglePanel(string componentType)
    {
        _showViewMenu = false;
        if (_openPanels.Contains(componentType)) return;

        if (_bridgeModule != null)
        {
            string title = _panelTitles.GetValueOrDefault(componentType, componentType);
            await _bridgeModule.InvokeVoidAsync("addPanel", GlInstanceId, componentType, title, new { });
            _openPanels.Add(componentType);
        }
    }

    private async Task ResetLayout()
    {
        _showViewMenu = false;
        _openPanels.Clear();
        _openPanels.UnionWith(["palette", "canvas", "form", "responses", "inspector"]);

        if (_bridgeModule != null)
        {
            string layoutConfig = BuildDefaultLayoutConfig();
            await _bridgeModule.InvokeVoidAsync("loadLayout", GlInstanceId, layoutConfig);

            // Re-init the canvas editor since GL will unbind/rebind panels
            await Task.Delay(100);
            await InitScriptEditor();
        }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Save / Cancel
    // ═══════════════════════════════════════════════════════════════════

    private async Task Save()
    {
        _isSaving = true;
        _error = null;
        try
        {
            await CaptureCurrentScriptGraph();

            if (_isCreating)
                await Api.CreateAsync(_editItem);
            else
                await Api.UpdateAsync(_editItem.Tag, _editItem);

            await SaveEventScripts(_editItem.Tag);

            await DestroyLayout();
            _isOpen = false;
            StateHasChanged();

            await OnClosed.InvokeAsync(new InteractionEditorResult
            {
                Saved = true,
                InteractionTag = _editItem.Tag,
                IsNew = _isCreating,
                Message = _isCreating
                    ? $"Interaction '{_editItem.Name}' created."
                    : $"Interaction '{_editItem.Name}' updated.",
            });
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to save interaction");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task Cancel()
    {
        await DestroyLayout();
        _isOpen = false;
        _error = null;
        StateHasChanged();
        await OnClosed.InvokeAsync(new InteractionEditorResult { Saved = false });
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Script Editor Lifecycle
    // ═══════════════════════════════════════════════════════════════════

    private async Task InitScriptEditor()
    {
        try
        {
            _scriptEditorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/glyph-editor.js");
            _dotNetRef ??= DotNetObjectReference.Create(this);

            string catalogJson = JsonSerializer.Serialize(_nodeCatalog);
            string graphJson = _pipelineGraphJson;

            if (string.IsNullOrEmpty(graphJson) || graphJson == "{}" || !GraphHasNodes(graphJson))
            {
                graphJson = BuildEmptyPipelineGraphJson();
            }

            await _scriptEditorModule.InvokeVoidAsync("initGlyphEditor", "interaction-glyph-canvas", catalogJson, graphJson, _dotNetRef);
            _scriptEditorReady = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Script editor init failed");
            _scriptEditorReady = false;
        }
    }

    private async Task DestroyScriptEditor()
    {
        if (_scriptEditorModule == null) return;
        try { await _scriptEditorModule.InvokeVoidAsync("destroy"); }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to destroy script editor"); }
        _scriptEditorReady = false;
    }

    private void ResetScriptState()
    {
        _pipelineGraphJson = "{}";
        _pipelineScript = null;
        _scriptNodeSearchFilter = "";
        _scriptEditorReady = false;
        _scriptSelectedNodeInfo = null;
    }

    private async Task CaptureCurrentScriptGraph()
    {
        if (_scriptEditorModule == null || !_scriptEditorReady) return;
        try
        {
            string json = await _scriptEditorModule.InvokeAsync<string>("getGraphJson");
            _pipelineGraphJson = json;
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to capture pipeline script graph"); }
    }

    private async Task LoadInteractionScripts(string interactionTag)
    {
        try
        {
            if (_nodeCatalog.Count == 0)
                _nodeCatalog = await GlyphApi.GetNodeCatalogAsync();

            List<InteractionGlyphBindingDto> bindings = await GlyphApi.GetInteractionBindingsAsync(interactionTag);
            foreach (InteractionGlyphBindingDto binding in bindings)
            {
                GlyphDefinitionDto? def = await GlyphApi.GetDefinitionAsync(binding.GlyphDefinitionId);
                if (def == null) continue;
                if (def.EventType == PipelineEventType ||
                    def.EventType.StartsWith("OnInteraction", StringComparison.OrdinalIgnoreCase))
                {
                    _pipelineGraphJson = def.GraphJson ?? "{}";
                    _pipelineScript = def;
                    break;
                }
            }

            // Re-init the glyph editor with the loaded graph
            await DestroyScriptEditor();
            await Task.Delay(50);
            await InitScriptEditor();
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to load interaction scripts for {Tag}", interactionTag); }
    }

    private async Task SaveEventScripts(string interactionTag)
    {
        string graphJson = _pipelineGraphJson;
        bool hasGraph = GraphHasNodes(graphJson);
        GlyphDefinitionDto? existingDef = _pipelineScript;

        if (hasGraph)
        {
            if (existingDef != null)
            {
                GlyphDefinitionDto? updated = await GlyphApi.UpdateDefinitionAsync(existingDef.Id,
                    new UpdateGlyphRequest(GraphJson: graphJson, IsActive: true));
                if (updated != null) _pipelineScript = updated;
            }
            else
            {
                List<InteractionGlyphBindingDto> existingBindings = await GlyphApi.GetInteractionBindingsAsync(interactionTag);
                InteractionGlyphBindingDto? matchingBinding = existingBindings.FirstOrDefault();

                if (matchingBinding != null)
                {
                    GlyphDefinitionDto? updated = await GlyphApi.UpdateDefinitionAsync(
                        matchingBinding.GlyphDefinitionId,
                        new UpdateGlyphRequest(GraphJson: graphJson, IsActive: true));
                    if (updated != null) _pipelineScript = updated;
                }
                else
                {
                    string name = $"{interactionTag}/InteractionPipeline";
                    GlyphDefinitionDto? created = await GlyphApi.CreateDefinitionAsync(new CreateGlyphRequest(
                        Name: name,
                        EventType: PipelineEventType,
                        Category: "Interaction",
                        Description: $"Pipeline script for interaction '{interactionTag}'",
                        GraphJson: graphJson,
                        IsActive: true));

                    if (created != null)
                    {
                        _pipelineScript = created;
                        await GlyphApi.CreateInteractionBindingAsync(
                            new CreateInteractionGlyphBindingRequest(
                                InteractionTag: interactionTag,
                                GlyphDefinitionId: created.Id));
                    }
                }
            }
        }
        else if (existingDef != null)
        {
            await GlyphApi.UpdateDefinitionAsync(existingDef.Id, new UpdateGlyphRequest(IsActive: false));
            _pipelineScript = null;
        }
    }

