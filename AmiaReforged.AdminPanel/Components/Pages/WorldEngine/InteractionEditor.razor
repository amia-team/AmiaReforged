    private void OnIndustrySelected(ChangeEventArgs e)
    {
        string? tag = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(tag) && !_editItem.RequiredIndustryTags.Contains(tag))
            _editItem.RequiredIndustryTags.Add(tag);
    }

    private void AddAreaResRef()
    {
        string val = _newAreaResRef.Trim();
        if (!string.IsNullOrEmpty(val) && !_editItem.AllowedAreaResRefs.Contains(val))
        {
            _editItem.AllowedAreaResRefs.Add(val);
            _newAreaResRef = "";
        }
    }

    private void OnAreaKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") AddAreaResRef(); }

    private void AddKnowledgeTag()
    {
        string val = _newKnowledgeTag.Trim();
        if (!string.IsNullOrEmpty(val) && !_editItem.RequiredKnowledgeTags.Contains(val))
        {
            _editItem.RequiredKnowledgeTags.Add(val);
            _newKnowledgeTag = "";
        }
    }

    private void OnKnowledgeKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") AddKnowledgeTag(); }

    // ═══════════════════════════════════════════════════════════════════
    //  Response / Effect Management
    // ═══════════════════════════════════════════════════════════════════

    private void AddResponse()
    {
        _editItem.Responses.Add(new InteractionResponseDto { ResponseTag = "", Weight = 1 });
    }

    private void RemoveResponse(int index)
    {
        if (index >= 0 && index < _editItem.Responses.Count)
            _editItem.Responses.RemoveAt(index);
    }

    private void AddEffect(int responseIndex)
    {
        if (responseIndex >= 0 && responseIndex < _editItem.Responses.Count)
            _editItem.Responses[responseIndex].Effects.Add(new InteractionResponseEffectDto());
    }

    private void RemoveEffect(int responseIndex, int effectIndex)
    {
        if (responseIndex >= 0 && responseIndex < _editItem.Responses.Count)
        {
            List<InteractionResponseEffectDto> effects = _editItem.Responses[responseIndex].Effects;
            if (effectIndex >= 0 && effectIndex < effects.Count)
                effects.RemoveAt(effectIndex);
        }
    }

