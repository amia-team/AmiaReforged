    private async Task ClearCurrentScript()
    {
        _pipelineGraphJson = "{}";
        _scriptSelectedNodeInfo = null;
        await DestroyScriptEditor();
        StateHasChanged();
        await Task.Delay(50);
        await InitScriptEditor();
    }

