                        title = "Graph",
                        size = "55%",
                    },
                    new
                    {
                        type = "column",
                        size = "30%",
                        content = new object[]
                        {
                            new
                            {
                                type = "stack",
                                size = "65%",
                                content = new object[]
                                {
                                    new
                                    {
                                        type = "component",
                                        componentType = "form",
                                        title = "Properties",
                                    },
                                    new
                                    {
                                        type = "component",
                                        componentType = "responses",
                                        title = "Responses",
