    private async Task AddScriptNode(GlyphNodeCatalogEntryDto node)
    {
        if (_scriptEditorModule == null || !_scriptEditorReady) return;
        try
        {
            string nodeJson = JsonSerializer.Serialize(node);
            await _scriptEditorModule.InvokeVoidAsync("addNode", nodeJson);
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to add script node"); }
    }

    [JSInvokable]
    public Task OnNodeSelectionChanged(string? json)
    {
        if (string.IsNullOrEmpty(json) || json == "null")
        {
            _scriptSelectedNodeInfo = null;
        }
        else
        {
            try
            {
                _scriptSelectedNodeInfo = JsonSerializer.Deserialize<SelectedNodeInfo>(json, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
            }
            catch { _scriptSelectedNodeInfo = null; }
        }
        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private async Task OnScriptPropertyChanged(SelectedPinInfo pin, string value)
    {
        if (_scriptEditorModule == null || _scriptSelectedNodeInfo == null) return;
        try
        {
            await _scriptEditorModule.InvokeVoidAsync("setPropertyOverride", _scriptSelectedNodeInfo.NodeId, pin.Id, value);
            pin.OverrideValue = string.IsNullOrEmpty(value) ? null : value;
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to set script property override"); }
    }

