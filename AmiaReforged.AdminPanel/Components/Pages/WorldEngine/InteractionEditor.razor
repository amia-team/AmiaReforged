    //  Disposal
    // ═══════════════════════════════════════════════════════════════════

    public async ValueTask DisposeAsync()
    {
        await DestroyLayout();

        if (_scriptEditorModule != null)
        {
            try { await _scriptEditorModule.DisposeAsync(); }
            catch { /* ignore during teardown */ }
        }

        if (_bridgeModule != null)
        {
            try { await _bridgeModule.DisposeAsync(); }
            catch { /* ignore during teardown */ }
        }

        _dotNetRef?.Dispose();
    }
