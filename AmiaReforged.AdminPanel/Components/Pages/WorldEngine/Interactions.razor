    // ===== Event Scripts — Save =====

    private async Task SaveEventScripts(string interactionTag)
    {
        string graphJson = _pipelineGraphJson;
        bool hasGraph = GraphHasNodes(graphJson);
        GlyphDefinitionDto? existingDef = _pipelineScript;

        if (hasGraph)
        {
            if (existingDef != null)
            {
                // Update existing pipeline definition
                GlyphDefinitionDto? updated = await GlyphApi.UpdateDefinitionAsync(existingDef.Id,
                    new UpdateGlyphRequest(GraphJson: graphJson, IsActive: true));
                if (updated != null) _pipelineScript = updated;
            }
            else
            {
                // Deduplication safeguard: check if a binding already exists
                List<InteractionGlyphBindingDto> existingBindings = await GlyphApi.GetInteractionBindingsAsync(interactionTag);
                InteractionGlyphBindingDto? matchingBinding = existingBindings.FirstOrDefault();

                if (matchingBinding != null)
                {
                    // Reuse the existing definition — update it and reactivate
                    GlyphDefinitionDto? updated = await GlyphApi.UpdateDefinitionAsync(
                        matchingBinding.GlyphDefinitionId,
                        new UpdateGlyphRequest(GraphJson: graphJson, IsActive: true));
                    if (updated != null) _pipelineScript = updated;
                }
                else
                {
                    // Create new pipeline definition + binding
                    string name = $"{interactionTag}/InteractionPipeline";
                    GlyphDefinitionDto? created = await GlyphApi.CreateDefinitionAsync(new CreateGlyphRequest(
                        Name: name,
                        EventType: PipelineEventType,
                        Category: "Interaction",
                        Description: $"Pipeline script for interaction '{interactionTag}'",
                        GraphJson: graphJson,
                        IsActive: true));

                    if (created != null)
                    {
                        _pipelineScript = created;

                        // Create the binding
                        await GlyphApi.CreateInteractionBindingAsync(
                            new CreateInteractionGlyphBindingRequest(
                                InteractionTag: interactionTag,
                                GlyphDefinitionId: created.Id));
                    }
                }
            }
        }
        else if (existingDef != null)
        {
            // Graph was cleared — soft-disable the definition
            await GlyphApi.UpdateDefinitionAsync(existingDef.Id,
                new UpdateGlyphRequest(IsActive: false));
            _pipelineScript = null;
        }
    }

    // ===== Event Scripts — Node Palette & Properties =====

    private async Task AddScriptNode(GlyphNodeCatalogEntryDto node)
    {
        if (_scriptEditorModule == null || !_scriptEditorReady) return;

        try
        {
            string nodeJson = JsonSerializer.Serialize(node);
            await _scriptEditorModule.InvokeVoidAsync("addNode", nodeJson);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to add script node");
        }
    }

    [JSInvokable]
    public Task OnNodeSelectionChanged(string? json)
    {
        if (string.IsNullOrEmpty(json) || json == "null")
        {
            _scriptSelectedNodeInfo = null;
        }
        else
        {
            try
            {
                _scriptSelectedNodeInfo = JsonSerializer.Deserialize<SelectedNodeInfo>(json, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
            }
            catch
            {
                _scriptSelectedNodeInfo = null;
            }
        }

        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private static string GetScriptPinValue(SelectedPinInfo pin) => pin.OverrideValue ?? pin.DefaultValue ?? "";

    private async Task OnScriptPropertyChanged(SelectedPinInfo pin, string value)
    {
        if (_scriptEditorModule == null || _scriptSelectedNodeInfo == null) return;

        try
        {
            await _scriptEditorModule.InvokeVoidAsync("setPropertyOverride", _scriptSelectedNodeInfo.NodeId, pin.Id, value);
            pin.OverrideValue = string.IsNullOrEmpty(value) ? null : value;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to set script property override");
        }
    }

