    // ===== Event Scripts — State Management =====

    private void ResetScriptState()
    {
        _showScriptsSection = false;
        _pipelineGraphJson = "{}";
        _pipelineScript = null;
        _scriptNodeSearchFilter = "";
        _scriptEditorReady = false;
        _scriptSelectedNodeInfo = null;
    }

    private async Task LoadInteractionScripts(string interactionTag)
    {
        try
        {
            // Load node catalog if not already loaded
            if (_nodeCatalog.Count == 0)
            {
                _nodeCatalog = await GlyphApi.GetNodeCatalogAsync();
            }

            // Fetch all interaction glyph bindings for this tag
            List<InteractionGlyphBindingDto> bindings = await GlyphApi.GetInteractionBindingsAsync(interactionTag);

            foreach (InteractionGlyphBindingDto binding in bindings)
            {
                // Fetch the full glyph definition (with GraphJson)
                GlyphDefinitionDto? def = await GlyphApi.GetDefinitionAsync(binding.GlyphDefinitionId);
                if (def == null) continue;

                // Use the pipeline definition (or legacy event types)
                if (def.EventType == PipelineEventType ||
                    def.EventType.StartsWith("OnInteraction", StringComparison.OrdinalIgnoreCase))
                {
                    _pipelineGraphJson = def.GraphJson ?? "{}";
                    _pipelineScript = def;
                    break; // single pipeline definition per interaction
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load interaction scripts for {Tag}", interactionTag);
        }
    }

    private async Task ToggleScriptsSection()
    {
        if (_showScriptsSection)
        {
            // Closing — capture current graph and destroy editor
            await CaptureCurrentScriptGraph();
            await DestroyScriptEditor();
            _showScriptsSection = false;
            _scriptSelectedNodeInfo = null;
        }
        else
        {
            // Opening — load catalog if needed, then init editor
            _showScriptsSection = true;
            StateHasChanged();

            if (_nodeCatalog.Count == 0)
            {
                try { _nodeCatalog = await GlyphApi.GetNodeCatalogAsync(); }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load node catalog");
                }
            }

            await Task.Delay(100); // Wait for DOM render
            await InitScriptEditor();
        }
    }

    private async Task CaptureCurrentScriptGraph()
    {
        if (_scriptEditorModule == null || !_scriptEditorReady) return;

        try
        {
            string json = await _scriptEditorModule.InvokeAsync<string>("getGraphJson");
            _pipelineGraphJson = json;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to capture pipeline script graph");
        }
    }

    private async Task InitScriptEditor()
    {
        try
        {
            _scriptEditorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/glyph-editor.js");
            _dotNetRef ??= DotNetObjectReference.Create(this);

            string catalogJson = JsonSerializer.Serialize(_nodeCatalog);
            string graphJson = _pipelineGraphJson;

            // For new/empty graphs, pre-populate with the 4 pipeline stage nodes
            if (string.IsNullOrEmpty(graphJson) || graphJson == "{}" || !GraphHasNodes(graphJson))
            {
                graphJson = BuildEmptyPipelineGraphJson();
            }

            await _scriptEditorModule.InvokeVoidAsync("initGlyphEditor", "interaction-glyph-canvas", catalogJson, graphJson, _dotNetRef);
            _scriptEditorReady = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Script editor init failed");
            _scriptEditorReady = false;
        }
    }

    private async Task DestroyScriptEditor()
    {
        if (_scriptEditorModule == null) return;

        try
        {
            await _scriptEditorModule.InvokeVoidAsync("destroy");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to destroy script editor");
        }

        _scriptEditorReady = false;
    }

    private async Task ClearCurrentScript()
    {
        _pipelineGraphJson = "{}";
        _scriptSelectedNodeInfo = null;

        // Re-init with pre-populated pipeline stage nodes
        await DestroyScriptEditor();
        StateHasChanged();
        await Task.Delay(50);
        await InitScriptEditor();
    }

    /// <summary>
    /// Builds a pipeline graph JSON with the 4 stage nodes pre-placed on the canvas.
    /// Mirrors GlyphController.BuildInteractionPipelineGraphJson.
    /// </summary>
    private static string BuildEmptyPipelineGraphJson()
    {
        var graph = new
        {
            Id = Guid.NewGuid(),
            Name = "",
            Description = "",
            EventType = PipelineEventType,
            Nodes = new object[]
            {
                new { InstanceId = Guid.NewGuid(), TypeId = "stage.interaction_attempted", PositionX = 50.0, PositionY = 300.0, PropertyOverrides = new Dictionary<string, string>() },
                new { InstanceId = Guid.NewGuid(), TypeId = "stage.interaction_started", PositionX = 500.0, PositionY = 300.0, PropertyOverrides = new Dictionary<string, string>() },
                new { InstanceId = Guid.NewGuid(), TypeId = "stage.interaction_tick", PositionX = 950.0, PositionY = 300.0, PropertyOverrides = new Dictionary<string, string>() },
                new { InstanceId = Guid.NewGuid(), TypeId = "stage.interaction_completed", PositionX = 1400.0, PositionY = 300.0, PropertyOverrides = new Dictionary<string, string>() }
            },
            Edges = Array.Empty<object>(),
            Variables = Array.Empty<object>()
        };
        return JsonSerializer.Serialize(graph);
    }

