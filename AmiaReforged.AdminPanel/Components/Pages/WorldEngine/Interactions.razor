    /// <summary>
    /// Checks whether a graph JSON string contains at least one node.
    /// Empty canvases still produce structured JSON like {"Nodes":[],...} from the JS editor,
    /// so a simple != "{}" check is insufficient.
    /// </summary>
    private static bool GraphHasNodes(string? graphJson)
    {
        if (string.IsNullOrEmpty(graphJson) || graphJson == "{}") return false;
        try
        {
            using JsonDocument doc = System.Text.Json.JsonDocument.Parse(graphJson);
            return doc.RootElement.TryGetProperty("Nodes", out JsonElement nodesEl)
                && nodesEl.ValueKind == System.Text.Json.JsonValueKind.Array
                && nodesEl.GetArrayLength() > 0;
        }
        catch
        {
            return false;
        }
    }

    private IEnumerable<IGrouping<string, GlyphNodeCatalogEntryDto>> ScriptFilteredCatalog
    {
        get
        {
            IEnumerable<GlyphNodeCatalogEntryDto> nodes = _nodeCatalog;

            // Filter by pipeline event type
            nodes = nodes.Where(n =>
                n.RestrictToEventType == null ||
                n.RestrictToEventType == PipelineEventType);

            // Show only Interaction-category nodes + universal nodes
            nodes = nodes.Where(n =>
                n.ScriptCategory == null ||
                n.ScriptCategory.Equals("Interaction", StringComparison.OrdinalIgnoreCase));

            // Filter by search text
            if (!string.IsNullOrWhiteSpace(_scriptNodeSearchFilter))
            {
                string filter = _scriptNodeSearchFilter.Trim().ToLowerInvariant();
                nodes = nodes.Where(n =>
                    n.DisplayName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                    n.Category.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                    n.Description.Contains(filter, StringComparison.OrdinalIgnoreCase));
            }

            return nodes.GroupBy(n => n.Category).OrderBy(g => g.Key);
        }
    }

    // ===== Lifecycle =====

    protected override async Task OnInitializedAsync()
    {
        await RefreshEndpoints();
    }

    // ===== Endpoint Handling =====

    private async Task RefreshEndpoints()
    {
        IReadOnlyList<WorldEngineEndpoint> all = await EndpointService.GetAllEndpointsAsync();
        _endpoints = all.Where(e => e.IsEnabled).ToList();

        if (_selectedEndpoint != null && !_endpoints.Any(e => e.Id == _selectedEndpoint.Id))
            _selectedEndpoint = null;

        StateHasChanged();
    }

    private async Task OnEndpointChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id))
        {
            _selectedEndpoint = _endpoints.FirstOrDefault(ep => ep.Id == id);
            Api.SelectEndpoint(id);
            GlyphApi.SelectEndpoint(id);
            _page = 1;
            await RefreshInteractions();
        }
        else
        {
            _selectedEndpoint = null;
            Api.SelectEndpoint(null);
            GlyphApi.SelectEndpoint(null);
            _interactions.Clear();
        }
    }

    // ===== Data Loading =====

    private async Task RefreshInteractions()
    {
        if (_selectedEndpoint == null) return;
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            PagedResult<InteractionDefinitionDto> result = await Api.GetAllAsync(_searchTerm, _page, _pageSize);
            _interactions = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to load interactions");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SearchInteractions()
    {
        _page = 1;
        await RefreshInteractions();
    }

    private async Task PrevPage()
    {
        if (_page > 1) { _page--; await RefreshInteractions(); }
    }

    private async Task NextPage()
    {
        if (_page * _pageSize < _totalCount) { _page++; await RefreshInteractions(); }
    }

    // ===== Create / Edit Modal =====

    private void ShowCreateModal()
    {
        _isCreating = true;
        _editItem = new InteractionDefinitionDto
        {
            TargetMode = "Trigger",
            BaseRounds = 4,
            MinRounds = 2,
            ProficiencyReducesRounds = true,
            RequiresIndustryMembership = true,
        };
        ResetScriptState();
        _showEditModal = true;
    }

    private async Task ShowEditModal(InteractionDefinitionDto item)
    {
        _isCreating = false;
        _editItem = DeepCopy(item);
        ResetScriptState();
        _showEditModal = true;

        // Load existing scripts for this interaction
        await LoadInteractionScripts(item.Tag);
    }

    private async Task CloseEditModal()
    {
        await DestroyScriptEditor();
        _showEditModal = false;
        _showScriptsSection = false;
        _editItem = new();
        _scriptSelectedNodeInfo = null;
    }

    private async Task SaveInteraction()
    {
        _isSaving = true;
        _error = null;
        try
        {
            // Capture the current script tab's graph before saving
            await CaptureCurrentScriptGraph();

            if (_isCreating)
                await Api.CreateAsync(_editItem);
            else
                await Api.UpdateAsync(_editItem.Tag, _editItem);

            // Save event scripts (create/update glyph definitions + bindings)
            await SaveEventScripts(_editItem.Tag);

            _success = _isCreating
                ? $"Interaction '{_editItem.Name}' created."
                : $"Interaction '{_editItem.Name}' updated.";

            await DestroyScriptEditor();
            _showEditModal = false;
            _showScriptsSection = false;
            await RefreshInteractions();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to save interaction");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    // ===== Response Management =====

    private void AddResponse()
    {
        _editItem.Responses.Add(new InteractionResponseDto
        {
            ResponseTag = "",
            Weight = 1,
        });
    }

    private void RemoveResponse(int index)
    {
        if (index >= 0 && index < _editItem.Responses.Count)
            _editItem.Responses.RemoveAt(index);
    }

    // ===== Effect Management =====

    private void AddEffect(int responseIndex)
    {
        if (responseIndex >= 0 && responseIndex < _editItem.Responses.Count)
        {
            _editItem.Responses[responseIndex].Effects.Add(new InteractionResponseEffectDto());
        }
    }

    private void RemoveEffect(int responseIndex, int effectIndex)
    {
        if (responseIndex >= 0 && responseIndex < _editItem.Responses.Count)
        {
            List<InteractionResponseEffectDto> effects = _editItem.Responses[responseIndex].Effects;
            if (effectIndex >= 0 && effectIndex < effects.Count)
                effects.RemoveAt(effectIndex);
        }
    }

    // ===== Import =====

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            foreach (IBrowserFile file in e.GetMultipleFiles(100))
            {
                if (file.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
                {
                    await ProcessZipImport(file);
                }
                else
                {
                    await ProcessJsonFileImport(file);
                }
            }

            _importJson = JsonSerializer.Serialize(_importedItems);
            _importResult = null;
            _success = $"Loaded {_importedItems.Count} interaction(s) total. Pick more files to add more, or click Import.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = $"Failed to read file(s): {ex.Message}";
        }
    }

    private async Task ProcessJsonFileImport(IBrowserFile file)
    {
        using StreamReader reader = new StreamReader(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
        string content = await reader.ReadToEndAsync();
        ParseJsonItems(content);
    }

    private async Task ProcessZipImport(IBrowserFile file)
    {
        using MemoryStream ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
        ms.Position = 0;
        using ZipArchive archive = new ZipArchive(ms, ZipArchiveMode.Read);
        foreach (ZipArchiveEntry entry in archive.Entries)
        {
            if (!entry.FullName.EndsWith(".json", StringComparison.OrdinalIgnoreCase)) continue;
            using Stream entryStream = entry.Open();
            using StreamReader reader = new StreamReader(entryStream);
            string content = await reader.ReadToEndAsync();
            ParseJsonItems(content);
        }
    }

    private void ParseJsonItems(string content)
    {
        using JsonDocument doc = JsonDocument.Parse(content);
        if (doc.RootElement.ValueKind == JsonValueKind.Array)
        {
            foreach (JsonElement item in doc.RootElement.EnumerateArray())
                _importedItems.Add(item.Clone());
        }
        else if (doc.RootElement.ValueKind == JsonValueKind.Object)
        {
            _importedItems.Add(doc.RootElement.Clone());
        }
    }

    private async Task RunImport()
    {
        if (string.IsNullOrWhiteSpace(_importJson)) return;
        _isSaving = true;
        _error = null;
        try
        {
            _importResult = await Api.ImportJsonAsync(_importJson);
            if (_importResult is { Failed: 0 })
                _success = $"Successfully imported {_importResult.Succeeded} interaction(s).";
            await RefreshInteractions();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to import interactions");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void CloseImportModal()
    {
        _showImportModal = false;
        _importJson = "";
        _importResult = null;
        _importedItems.Clear();
    }

    // ===== Export =====

    private async Task ExportJson()
    {
        try
        {
            string json = JsonSerializer.Serialize(_interactions, new JsonSerializerOptions { WriteIndented = true });
            byte[] bytes = System.Text.Encoding.UTF8.GetBytes(json);
            string base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:application/json;base64,{base64}';a.download='interactions-export.json';document.body.appendChild(a);a.click();document.body.removeChild(a);");
        }
        catch (Exception ex)
        {
            _error = $"Export failed: {ex.Message}";
        }
    }

