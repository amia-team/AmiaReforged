    [JSInvokable]
    public async Task OnNodeAssignedToRegion(string resRef, string regionTag)
    {
        // Add the area to the target region via API
        RegionDefinitionDto? targetRegion = _regions.FirstOrDefault(r =>
            string.Equals(r.Tag, regionTag, StringComparison.OrdinalIgnoreCase));
        if (targetRegion == null) return;

        // Remove from old region if present
        foreach (RegionDefinitionDto r in _regions)
        {
            r.Areas.RemoveAll(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
        }

        // Add to target
        if (!targetRegion.Areas.Any(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase)))
        {
            targetRegion.Areas.Add(new AreaDefinitionDto { ResRef = resRef });
        }

        try
        {
            // Save all affected regions
            foreach (RegionDefinitionDto r in _regions)
            {
                await Api.UpdateAsync(r.Tag, r);
            }
            _success = $"Assigned '{resRef}' to '{targetRegion.Name}'.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to assign area to region");
        }

        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnNodeUnassigned(string resRef)
    {
        // Remove from all regions
        bool changed = false;
        foreach (RegionDefinitionDto r in _regions)
        {
            int removed = r.Areas.RemoveAll(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
            if (removed > 0)
            {
                try { await Api.UpdateAsync(r.Tag, r); changed = true; }
                catch (Exception ex) { _error = ex.Message; Logger.LogError(ex, "Failed to unassign area"); }
            }
        }

        if (changed)
        {
            _success = $"Unassigned '{resRef}' from its region.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
        }

        StateHasChanged();
    }

