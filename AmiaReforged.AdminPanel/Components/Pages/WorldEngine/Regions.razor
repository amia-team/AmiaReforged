<script suppress-error="BL9992">
    (function () {
        function fixLayout() {
            var editor = document.querySelector('.region-editor');
            if (!editor) return;

            // Force all Blazor layout wrappers to fill height
            var el = editor.parentElement;
            while (el && el !== document.body) {
                el.style.height = '100%';
                el.style.overflow = 'hidden';
                if (el.classList.contains('content')) {
                    el.style.padding = '0';
                    el.style.maxWidth = '100%';
                }
                el = el.parentElement;
            }
            document.documentElement.style.height = '100%';
            document.documentElement.style.overflow = 'hidden';
            document.body.style.height = '100%';
            document.body.style.overflow = 'hidden';
            document.body.style.margin = '0';
        }

        function onResize() {
            if (window.regionGraph && typeof window.regionGraph.resize === 'function') {
                window.regionGraph.resize();
            }
        }

        function setup() {
            if (!document.querySelector('.region-editor')) return false;
            fixLayout();
            return true;
        }

        // Always re-run fixLayout (handles Blazor re-navigation with new DOM elements)
        if (!setup()) {
            var observer = new MutationObserver(function () {
                if (setup()) observer.disconnect();
            });
            observer.observe(document.body, { childList: true, subtree: true });
        }

        // Attach resize listener once
        if (!window.__regionEditorResizeAttached) {
            window.__regionEditorResizeAttached = true;
            window.addEventListener('resize', onResize);
        }
    })();
</script>

@code {
    // ===== Enums =====
    private enum PanelMode { RegionList, RegionEditor, AreaEditor }

    // ===== Static option lists =====
    private static readonly string[] _climateOptions = { "Undefined", "Temperate", "Tropical", "Arid", "Arctic", "Mediterranean", "Continental", "Oceanic", "Subarctic", "Alpine", "Tundra", "Desert" };
    private static readonly string[] _qualityOptions = { "None", "VeryPoor", "Poor", "BelowAverage", "Average", "AboveAverage", "Good", "VeryGood", "Excellent", "Masterwork" };
    private static readonly string[] _poiTypeOptions = { "Undefined", "Dungeon", "Landmark", "ResourceNode", "House", "Guild", "Temple", "Library", "Shop", "Warehouse", "Bank" };

    // ===== Endpoint State =====
    private List<WorldEngineEndpoint> _endpoints = [];
    private WorldEngineEndpoint? _selectedEndpoint;

    // ===== Data =====
    private List<RegionDefinitionDto> _regions = [];
    private int _totalCount;
    private int _page = 1;
    private int _pageSize = 200;
    private string _searchTerm = "";

    // ===== UI State =====
    private bool _isLoading;
    private bool _isSaving;
    private string? _error;
    private string? _success;
    private PanelMode _panelMode = PanelMode.RegionList;
    private string _regionListFilter = "";
    private bool _showOverlay;

    // ===== Region Editor State =====
    private bool _isCreating;
    private RegionDefinitionDto _editRegion = new();
    private bool _showDeleteConfirm;
    private bool _showAddAreaInput;
    private string _newAreaResRef = "";

    // ===== Area Editor State =====
    private AreaDefinitionDto? _editArea;
    private string? _editAreaRegionTag;
    private string? _editAreaOriginalRegionTag;
    private string? _editAreaName;

    // ===== Resource Node Definitions (for tag picker) =====
    private List<ResourceNodeDefinitionDto> _allResourceDefs = new();
    private string _defTagSearch = "";
    private bool _defTagDropdownOpen;

    // ===== Import =====
    private bool _showImportModal;
    private string _importJson = "";
    private ImportResult? _importResult;
    private List<System.Text.Json.JsonElement> _importedRegions = new();

    // ===== Export =====
    private bool _isExporting;

    // ===== Area Graph =====
    private bool _isGraphLoading;
    private int _graphLoadPercent;
    private string _graphLoadPhase = "";
    private AreaGraphDto? _graphData;
    private List<AreaNodeDto> _knownAreas = new();
    private Dictionary<string, string> _regionColors = new();
    private string _graphSearchQuery = "";
    private string _selectedLayout = "cose";
    private bool _showLayoutConfigModal;

    // ===== Layout Configuration Parameters =====
    // Compact Grid
    private int _lcNodeSpacing = 32;
    private int _lcRegionGap = 24;
    private int _lcOrphanGroupGap = 12;
    private string _lcInnerSort = "proximity";
    private string _lcOuterSort = "size";
    // CoSE / fCoSE shared
    private int _lcNodeRepulsion = 1200;
    private int _lcIdealEdgeLength = 25;
    private double _lcGravity = 2.0;
    private double _lcNestingFactor = 0.15;
    private int _lcNumIter = 800;
    private int _lcPadding = 15;
    // Dagre
    private string _lcRankDir = "LR";
    private int _lcNodeSep = 18;
    private int _lcRankSep = 35;
    private int _lcEdgeSep = 10;
    // Breadthfirst
    private double _lcSpacingFactor = 0.6;
    private bool _lcDirected = true;
    // Grid
    private bool _lcCondense = true;
    private int _lcGridRows; // 0 = auto
    // Concentric
    private int _lcMinNodeSpacing = 10;
    private int _lcLevelWidth = 2;

    private DotNetObjectReference<Regions>? _dotNetRef;

    private static readonly JsonSerializerOptions CamelCase = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() }
    };

    // ===== Lifecycle =====

    protected override async Task OnInitializedAsync()
    {
        await RefreshEndpoints();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("regionGraph.destroy"); }
        catch { /* component may already be disposed */ }
        _dotNetRef?.Dispose();
    }

    // ===== Endpoint Handling =====

    private async Task RefreshEndpoints()
    {
        IReadOnlyList<WorldEngineEndpoint> all = await EndpointService.GetAllEndpointsAsync();
        _endpoints = all.Where(e => e.IsEnabled).ToList();
        if (_selectedEndpoint != null && !_endpoints.Any(e => e.Id == _selectedEndpoint.Id))
            _selectedEndpoint = null;
        StateHasChanged();
    }

    private async Task OnEndpointChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id))
        {
            _selectedEndpoint = _endpoints.FirstOrDefault(ep => ep.Id == id);
            Api.SelectEndpoint(id);
            GraphApi.SelectEndpoint(id);
            ResourceNodeApi.SelectEndpoint(id);
            _page = 1;
            _graphData = null;
            _knownAreas.Clear();
            _regionColors.Clear();
            _panelMode = PanelMode.RegionList;
            await RefreshRegions();
            await LoadResourceDefinitionsAsync();
        }
        else
        {
            _selectedEndpoint = null;
            Api.SelectEndpoint(null);
            GraphApi.SelectEndpoint(null);
            ResourceNodeApi.SelectEndpoint(null);
            _regions.Clear();
            _graphData = null;
            _knownAreas.Clear();
            _regionColors.Clear();
            _allResourceDefs.Clear();
        }
    }

    // ===== Data Loading =====

    private async Task RefreshRegions()
    {
        if (_selectedEndpoint == null) return;
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            PagedResult<RegionDefinitionDto> result = await Api.GetAllAsync(_searchTerm, _page, _pageSize);
            _regions = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to load regions");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task PrevPage()
    {
        if (_page > 1) { _page--; await RefreshRegions(); }
    }

    private async Task NextPage()
    {
        if (_page * _pageSize < _totalCount) { _page++; await RefreshRegions(); }
    }

    private IEnumerable<RegionDefinitionDto> FilteredRegions()
    {
        if (string.IsNullOrWhiteSpace(_regionListFilter)) return _regions;
        string f = _regionListFilter.Trim();
        return _regions.Where(r =>
            r.Name.Contains(f, StringComparison.OrdinalIgnoreCase) ||
            r.Tag.Contains(f, StringComparison.OrdinalIgnoreCase));
    }

    // ===== Area Graph Loading =====

    private async Task LoadGraph()
    {
        await FetchGraph(refresh: false);
    }

    private async Task RefreshGraphData()
    {
        await FetchGraph(refresh: true);
    }

    private async Task FetchGraph(bool refresh)
    {
        _isGraphLoading = true;
        _graphLoadPercent = 0;
        _graphLoadPhase = "Fetching data...";
        _error = null;
        StateHasChanged();

        try
        {
            if (refresh)
            {
                LayoutService.InvalidateCache();
            }

            _graphData = refresh
                ? await GraphApi.RefreshGraphAsync()
                : await GraphApi.GetGraphAsync();

            if (_graphData != null)
            {
                BuildKnownAreas();
                BuildRegionColors();

                _graphLoadPercent = 15;
                _graphLoadPhase = "Computing layout...";
                StateHasChanged();

                // Compute layout server-side
                GraphLayoutResult layoutResult = await ComputeLayoutServerSide();

                _graphLoadPercent = 85;
                _graphLoadPhase = "Rendering...";
                StateHasChanged();
                await Task.Delay(50);

                await RenderRegionGraph(layoutResult);
                // _isGraphLoading will be cleared by OnGraphLoadProgress(100, ...) from JS
            }
            else
            {
                _isGraphLoading = false;
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load area graph: {ex.Message}";
            Logger.LogError(ex, "Failed to load area graph");
            _isGraphLoading = false;
        }
        finally
        {
            StateHasChanged();
        }
    }

    private void BuildKnownAreas()
    {
        if (_graphData == null) { _knownAreas.Clear(); return; }
        List<AreaNodeDto> all = new List<AreaNodeDto>(_graphData.Nodes.Count + _graphData.DisconnectedAreas.Count);
        all.AddRange(_graphData.Nodes);
        all.AddRange(_graphData.DisconnectedAreas);
        all.Sort((a, b) => string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase));
        _knownAreas = all;
    }

    private void BuildRegionColors()
    {
        _regionColors.Clear();
        string[] palette = new[]
        {
            "#e6194b", "#3cb44b", "#4363d8", "#f58231",
            "#911eb4", "#42d4f4", "#f032e6", "#bfef45",
            "#fabed4", "#469990", "#dcbeff", "#9A6324"
        };

        // Use region tags from _regions for color assignment
        for (int i = 0; i < _regions.Count; i++)
        {
            _regionColors[_regions[i].Tag] = palette[i % palette.Length];
            // Also store by name for legend lookups
            if (!_regionColors.ContainsKey(_regions[i].Name))
                _regionColors[_regions[i].Name] = palette[i % palette.Length];
        }
    }

    /// <summary>
    /// Build the JSON that the graph JS needs: regions with their area ResRefs and POI counts.
    /// </summary>
    private string BuildRegionsGraphJson()
    {
        var data = _regions.Select(r => new
        {
            tag = r.Tag ?? "",
            name = r.Name ?? "",
            areaResRefs = r.Areas.Where(a => !string.IsNullOrWhiteSpace(a.ResRef)).Select(a => a.ResRef).ToList(),
            poiCounts = r.Areas
                .Where(a => !string.IsNullOrWhiteSpace(a.ResRef) && a.PlacesOfInterest?.Count > 0)
                .ToDictionary(a => a.ResRef, a => a.PlacesOfInterest!.Count)
        });
        return JsonSerializer.Serialize(data, CamelCase);
    }

    private async Task RenderRegionGraph(GraphLayoutResult? layoutResult = null)
    {
        if (_graphData == null) return;

        try
        {
            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);

            string nodesJson = JsonSerializer.Serialize(_graphData.Nodes, CamelCase);
            string edgesJson = JsonSerializer.Serialize(_graphData.Edges, CamelCase);
            string disconnectedJson = JsonSerializer.Serialize(_graphData.DisconnectedAreas, CamelCase);
            string regionsJson = BuildRegionsGraphJson();
            string positionsJson = layoutResult != null
                ? JsonSerializer.Serialize(layoutResult.Positions, CamelCase)
                : "null";

            await JS.InvokeVoidAsync("regionGraph.init", "region-cy", nodesJson, edgesJson, disconnectedJson, regionsJson, _dotNetRef, positionsJson);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to render region graph");
            _error = "Failed to render graph visualization.";
        }
    }

    private async Task<GraphLayoutResult> ComputeLayoutServerSide()
    {
        List<RegionInfo> regionInfos = _regions.Select(r => new RegionInfo
        {
            Tag = r.Tag,
            Name = r.Name,
            AreaResRefs = r.Areas
                .Where(a => !string.IsNullOrWhiteSpace(a.ResRef))
                .Select(a => a.ResRef)
                .ToList()
        }).ToList();

        var progress = new Progress<(int Percent, string Phase)>(p =>
        {
            // Map server-side progress (0-100) into the 15-85 range of overall progress
            _graphLoadPercent = 15 + (int)(p.Percent * 0.7);
            _graphLoadPhase = p.Phase;
            InvokeAsync(StateHasChanged);
        });

        return await LayoutService.ComputeLayoutAsync(
            _graphData!, regionInfos, _selectedLayout, BuildLayoutConfig(), progress);
    }

