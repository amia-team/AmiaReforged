    {
        public string ResRef { get; set; } = "";
        public string Name { get; set; } = "";
        public string? Region { get; set; }
        public bool HasSpawnProfile { get; set; }
        public string? SpawnProfileName { get; set; }
        public int PoiCount { get; set; }
    }
