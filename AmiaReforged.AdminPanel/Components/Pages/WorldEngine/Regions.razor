    private void OpenAreaEditor(string resRef, string? regionTag, string? areaName)
    {
        _editAreaRegionTag = regionTag ?? "";
        _editAreaOriginalRegionTag = _editAreaRegionTag;
        _editAreaName = areaName;

        // Find the AreaDefinitionDto in the region's data
        AreaDefinitionDto? found = null;
        if (!string.IsNullOrEmpty(regionTag))
        {
            RegionDefinitionDto? region = _regions.FirstOrDefault(r =>
                string.Equals(r.Tag, regionTag, StringComparison.OrdinalIgnoreCase));
            if (region != null)
            {
                found = region.Areas.FirstOrDefault(a =>
                    string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
            }
        }

        // If not found in any region, search all regions
        if (found == null)
        {
            foreach (RegionDefinitionDto r in _regions)
            {
                found = r.Areas.FirstOrDefault(a =>
                    string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
                if (found != null)
                {
                    _editAreaRegionTag = r.Tag;
                    _editAreaOriginalRegionTag = r.Tag;
                    break;
                }
            }
        }

        // Clone or create new if unassigned
        _editArea = found != null ? CloneAreaDefinition(found) : new AreaDefinitionDto { ResRef = resRef };
        _panelMode = PanelMode.AreaEditor;
        _showOverlay = true;
        StateHasChanged();
    }

    private void EditAreaInRegion(int areaIndex)
    {
        AreaDefinitionDto area = _editRegion.Areas[areaIndex];
        _editAreaRegionTag = _editRegion.Tag;
        _editAreaOriginalRegionTag = _editRegion.Tag;
        _editAreaName = GetAreaNameByResRef(area.ResRef);
        _editArea = CloneAreaDefinition(area);
        _panelMode = PanelMode.AreaEditor;
        _showOverlay = true;
    }

