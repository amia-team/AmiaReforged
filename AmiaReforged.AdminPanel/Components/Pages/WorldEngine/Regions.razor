@page "/worldengine/regions"
@using Microsoft.AspNetCore.Authorization
@using AmiaReforged.AdminPanel.Models
@using AmiaReforged.AdminPanel.Services
@using System.IO.Compression
@using System.Text.Json
@using System.Text.Json.Serialization
@attribute [Authorize]
@inject RegionApiService Api
@inject AreaGraphApiService GraphApi
@inject IWorldEngineEndpointService EndpointService
@inject ILogger<Regions> Logger
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>Regions — Visual Editor</PageTitle>

<div class="region-editor">
    @* ===== Toolbar ===== *@
    <div class="region-editor__toolbar">
        <h1>Regions</h1>

        @if (_endpoints.Count > 0)
        {
            <div class="toolbar-group">
                <label style="font-size:0.82rem;color:var(--text-secondary);white-space:nowrap">Server:</label>
                <select class="form-control form-control-sm" style="width:auto;min-width:140px"
                        value="@(_selectedEndpoint?.Id.ToString() ?? "")" @onchange="OnEndpointChanged">
                    <option value="">— Select —</option>
                    @foreach (var ep in _endpoints)
                    {
                        <option value="@ep.Id">@ep.Name</option>
                    }
                </select>
            </div>
        }

        @if (_selectedEndpoint != null)
        {
            <div class="toolbar-divider"></div>

            <div class="toolbar-group">
                <input class="form-control form-control-sm" style="width:200px" @bind="_graphSearchQuery" @bind:event="oninput"
                       placeholder="Search areas..." @onkeydown="OnGraphSearchKeyDown" />
                <button class="btn btn-primary btn-sm" @onclick="SearchInGraph">🔎</button>
            </div>

            <div class="toolbar-divider"></div>

            <div class="toolbar-group">
                @if (!_isGraphLoading && _graphData == null)
                {
                    <button class="btn btn-primary btn-sm" @onclick="LoadGraph">Load Graph</button>
                }
                else if (_graphData != null)
                {
                    <button class="btn btn-warning btn-sm" @onclick="RefreshGraphData" disabled="@_isGraphLoading">
                        @(_isGraphLoading ? "Scanning..." : "Rescan")
                    </button>
                }
                <button class="btn btn-info btn-sm" @onclick="HighlightOrphans" disabled="@(_graphData == null)">Unassigned</button>
                <button class="btn btn-secondary btn-sm" @onclick="ClearGraphHighlight" disabled="@(_graphData == null)">Clear</button>
                <button class="btn btn-secondary btn-sm" @onclick="FitGraphView" disabled="@(_graphData == null)">Fit</button>
            </div>

            <div class="toolbar-divider"></div>

            <div class="toolbar-group">
                <button class="btn btn-info btn-sm" @onclick="() => _showImportModal = true">Import</button>
                <button class="btn btn-success btn-sm" @onclick="ExportRegions" disabled="@_isExporting">
                    @(_isExporting ? "..." : "Export")
                </button>
            </div>
        }

        <div style="flex:1"></div>
        <a href="/" class="btn btn-secondary btn-sm">← Dashboard</a>
    </div>

    @* ===== Alerts ===== *@
    @if (_error != null)
    {
        <div class="alert alert-danger" style="margin:8px 0 0 0;flex-shrink:0">
            @_error
            <button class="btn btn-sm btn-secondary" style="margin-left:10px" @onclick="() => _error = null">Dismiss</button>
        </div>
    }
    @if (_success != null)
    {
        <div class="alert alert-success" style="margin:8px 0 0 0;flex-shrink:0">
            @_success
            <button class="btn btn-sm btn-secondary" style="margin-left:10px" @onclick="() => _success = null">Dismiss</button>
        </div>
    }

    @* ===== No server selected =====  *@
    @if (_selectedEndpoint == null)
    {
        <div style="flex:1;display:flex;align-items:center;justify-content:center">
            <p style="color:var(--text-secondary);font-size:1.1rem">
                @if (_endpoints.Count == 0)
                {
                    <span>No WorldEngine servers configured. Go to <a href="/encounters">Encounters</a> to add one.</span>
                }
                else
                {
                    <span>Select a server from the toolbar to begin editing regions.</span>
                }
            </p>
        </div>
    }
    else
    {
        @* ===== Main split: Graph + Side Panel ===== *@
        <div class="region-editor__main">
            @* ===== Graph Area ===== *@
            <div class="region-editor__graph-wrapper">
                @if (_graphData != null)
                {
                    <div class="graph-info-bar">
                        <span>🟢 @_graphData.Nodes.Count connected</span>
                        <span>💎 @_graphData.DisconnectedAreas.Count disconnected</span>
                        <span>📍 @_regions.Count regions</span>
                        <span>⏱ @_graphData.GeneratedAtUtc.ToString("HH:mm:ss") UTC</span>
                    </div>
                }

                <div id="region-cy" class="region-editor__graph">
                    @if (_graphData == null && !_isGraphLoading)
                    {
                        <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-secondary)">
                            <div style="text-align:center">
                                <p style="font-size:1.1rem;margin-bottom:12px">Click <strong>Load Graph</strong> in the toolbar to visualise the area graph.</p>
                                <p style="font-size:0.85rem">Right-click the graph background to create regions, or drag areas into region groups.</p>
                            </div>
                        </div>
                    }
                    @if (_isGraphLoading)
                    {
                        <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-secondary)">
                            <em>Loading area graph...</em>
                        </div>
                    }
                </div>

                @* ===== Legend ===== *@
                @if (_regionColors.Count > 0)
                {
                    <div class="region-editor__legend">
                        @foreach (var kv in _regionColors)
                        {
                            <span class="region-editor__legend-item" @onclick="() => HighlightRegionOnGraph(kv.Key)">
                                <span class="region-editor__legend-swatch" style="background:@kv.Value"></span>
                                @kv.Key
                            </span>
                        }
                        <span class="region-editor__legend-item" style="color:var(--text-secondary)">
                            <span class="region-editor__legend-swatch" style="background:#6b6b6b"></span>
                            Unassigned
                        </span>
                    </div>
                }
            </div>

            @* ===== Side Panel ===== *@
            <div class="region-editor__panel">
                @* ---- Panel Header ---- *@
                <div class="region-editor__panel-header">
                    @if (_panelMode == PanelMode.AreaEditor)
                    {
                        <h3>Area: @(_editAreaName ?? _editArea?.ResRef ?? "—")</h3>
                        <button class="btn btn-sm btn-secondary" @onclick="ClosePanelEditor">✕</button>
                    }
                    else if (_panelMode == PanelMode.RegionEditor)
                    {
                        <h3>@(_isCreating ? "New Region" : $"Region: {_editRegion.Name}")</h3>
                        <button class="btn btn-sm btn-secondary" @onclick="ClosePanelEditor">✕</button>
                    }
                    else
                    {
                        <h3>Regions (@_regions.Count)</h3>
                        <button class="btn btn-sm btn-primary" @onclick="ShowCreateRegion">+ New</button>
                    }
                </div>

                @* ---- Panel Body ---- *@
                <div class="region-editor__panel-body">
                    @if (_panelMode == PanelMode.RegionList)
                    {
                        @* ===== Region List ===== *@
                        @if (_isLoading)
                        {
                            <p style="text-align:center;color:var(--text-secondary);padding:20px 0"><em>Loading...</em></p>
                        }
                        else if (_regions.Count == 0)
                        {
                            <p style="color:var(--text-secondary);text-align:center;padding:20px 0">
                                No regions defined. Right-click the graph or click <strong>+ New</strong> to create one.
                            </p>
                        }
                        else
                        {
                            @* Search filter for region list *@
                            <div class="form-group" style="margin-bottom:10px">
                                <input class="form-control form-control-sm" @bind="_regionListFilter" @bind:event="oninput"
                                       placeholder="Filter regions..." />
                            </div>

                            @foreach (var region in FilteredRegions())
                            {
                                var color = _regionColors.GetValueOrDefault(region.Name, _regionColors.GetValueOrDefault(region.Tag, "#6b6b6b"));
                                <div class="region-list-item @(IsRegionSelected(region) ? "region-list-item--active" : "")"
                                     @onclick="() => SelectRegionForEdit(region)"
                                     @oncontextmenu="() => SelectRegionForEdit(region)" @oncontextmenu:preventDefault>
                                    <span class="region-list-item__swatch" style="background:@color"></span>
                                    <div class="region-list-item__info">
                                        <div class="region-list-item__name">@region.Name</div>
                                        <div class="region-list-item__tag">@region.Tag</div>
                                    </div>
                                    <span class="region-list-item__count">@region.Areas.Count areas</span>
                                    <button class="btn btn-sm btn-info" style="padding:1px 5px;font-size:0.7rem"
                                            @onclick="() => HighlightRegionOnGraph(region.Name)" @onclick:stopPropagation>
                                        Show
                                    </button>
                                </div>
                            }

                            @* Pagination *@
                            @if (_totalCount > _pageSize)
                            {
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:10px;font-size:0.82rem">
                                    <span style="color:var(--text-secondary)">
                                        @((_page - 1) * _pageSize + 1)–@(Math.Min(_page * _pageSize, _totalCount)) of @_totalCount
                                    </span>
                                    <div style="display:flex;gap:4px">
                                        <button class="btn btn-sm btn-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">←</button>
                                        <button class="btn btn-sm btn-secondary" disabled="@(_page * _pageSize >= _totalCount)" @onclick="NextPage">→</button>
                                    </div>
                                </div>
                            }
                        }
                    }
                    else if (_panelMode == PanelMode.RegionEditor)
                    {
                        @* ===== Region Editor ===== *@
                        <div class="panel-section">
                            <strong style="font-size:0.9rem">Basic Info</strong>
                            <div class="form-group" style="margin-top:8px">
                                <label>Tag <small>(unique identifier)</small></label>
                                <input class="form-control form-control-sm" @bind="_editRegion.Tag" disabled="@(!_isCreating)" />
                            </div>
                            <div class="form-group">
                                <label>Name</label>
                                <input class="form-control form-control-sm" @bind="_editRegion.Name" />
                            </div>
                        </div>

                        @* Default Chaos *@
                        <div class="panel-section">
                            <div class="panel-section__header">
                                <strong>Default Chaos</strong>
                                @if (_editRegion.DefaultChaos == null)
                                {
                                    <button class="btn btn-sm btn-secondary" style="font-size:0.75rem" @onclick="AddDefaultChaos">+ Add</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" style="font-size:0.75rem" @onclick="RemoveDefaultChaos">Remove</button>
                                }
                            </div>
                            @if (_editRegion.DefaultChaos != null)
                            {
                                <div style="display:flex;flex-direction:column;gap:4px">
                                    <div class="form-group">
                                        <label>Danger (@_editRegion.DefaultChaos.Danger)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editRegion.DefaultChaos.Danger" />
                                    </div>
                                    <div class="form-group">
                                        <label>Corruption (@_editRegion.DefaultChaos.Corruption)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editRegion.DefaultChaos.Corruption" />
                                    </div>
                                    <div class="form-group">
                                        <label>Density (@_editRegion.DefaultChaos.Density)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editRegion.DefaultChaos.Density" />
                                    </div>
                                    <div class="form-group">
                                        <label>Mutation (@_editRegion.DefaultChaos.Mutation)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editRegion.DefaultChaos.Mutation" />
                                    </div>
                                </div>
                            }
                        </div>

                        @* Areas belonging to this region *@
                        <div class="panel-section">
                            <div class="panel-section__header">
                                <strong>Areas (@_editRegion.Areas.Count)</strong>
                                <button class="btn btn-sm btn-primary" style="font-size:0.75rem" @onclick="AddArea">+ Add</button>
                            </div>

                            @for (int idx = 0; idx < _editRegion.Areas.Count; idx++)
                            {
                                var i = idx;
                                var area = _editRegion.Areas[i];
                                <div style="display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:1px solid var(--border-subtle)">
                                    <code style="flex:1;font-size:0.82rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                          title="@area.ResRef">
                                        @(string.IsNullOrWhiteSpace(area.ResRef) ? "(new)" : area.ResRef)
                                        @{ var n = GetAreaNameByResRef(area.ResRef); }
                                        @if (!string.IsNullOrEmpty(n))
                                        {
                                            <small style="color:var(--text-secondary)"> — @n</small>
                                        }
                                    </code>
                                    <button class="btn btn-sm btn-secondary" style="font-size:0.7rem;padding:1px 5px"
                                            @onclick="() => EditAreaInRegion(i)">Edit</button>
                                    <button class="btn btn-sm btn-outline-danger" style="font-size:0.7rem;padding:1px 5px"
                                            @onclick="() => RemoveArea(i)">✕</button>
                                </div>
                            }

                            @* New area quick-add *@
                            @if (_showAddAreaInput)
                            {
                                <div style="display:flex;gap:4px;margin-top:6px;align-items:end">
                                    @if (_knownAreas.Count > 0)
                                    {
                                        <input class="form-control form-control-sm" list="add-area-list" @bind="_newAreaResRef" placeholder="ResRef..."
                                               style="flex:1" maxlength="16" />
                                        <datalist id="add-area-list">
                                            @foreach (var ka in GetAvailableAreas(""))
                                            {
                                                <option value="@ka.ResRef">@ka.ResRef — @ka.Name</option>
                                            }
                                        </datalist>
                                    }
                                    else
                                    {
                                        <input class="form-control form-control-sm" @bind="_newAreaResRef" placeholder="ResRef..." style="flex:1" maxlength="16" />
                                    }
                                    <button class="btn btn-sm btn-primary" @onclick="ConfirmAddArea" disabled="@string.IsNullOrWhiteSpace(_newAreaResRef)">Add</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _showAddAreaInput = false">✕</button>
                                </div>
                            }
                        </div>

                        @* Delete region (inline confirm) *@
                        @if (!_isCreating)
                        {
                            @if (_showDeleteConfirm)
                            {
                                <div class="inline-confirm">
                                    <span>Delete <strong>@_editRegion.Name</strong>?</span>
                                    <button class="btn btn-sm btn-danger" @onclick="DeleteRegion" disabled="@_isSaving">Yes</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _showDeleteConfirm = false">No</button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" style="width:100%;margin-top:4px" @onclick="() => _showDeleteConfirm = true">
                                    Delete Region
                                </button>
                            }
                        }
                    }
                    else if (_panelMode == PanelMode.AreaEditor)
                    {
                        @* ===== Area Inline Editor ===== *@
                        <div class="panel-section">
                            <strong style="font-size:0.9rem">Area Info</strong>
                            <div class="form-group" style="margin-top:8px">
                                <label>ResRef</label>
                                <input class="form-control form-control-sm" value="@_editArea!.ResRef" disabled />
                            </div>
                            <div class="form-group">
                                <label>Region</label>
                                <select class="form-control form-control-sm" value="@_editAreaRegionTag"
                                        @onchange="OnAreaRegionChanged">
                                    <option value="">— Unassigned —</option>
                                    @foreach (var r in _regions)
                                    {
                                        <option value="@r.Tag">@r.Name (@r.Tag)</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Linked Settlement ID</label>
                                <input type="number" class="form-control form-control-sm"
                                       value="@(_editArea.LinkedSettlement?.ToString() ?? "")"
                                       @onchange="OnAreaLinkedSettlementChanged" min="1" />
                            </div>
                            <div class="form-group">
                                <label>Definition Tags <small>(comma-separated)</small></label>
                                <input class="form-control form-control-sm"
                                       value="@string.Join(", ", _editArea.DefinitionTags)"
                                       @onchange="OnAreaDefinitionTagsChanged" />
                            </div>
                        </div>

                        @* Environment *@
                        <div class="panel-section">
                            <strong style="font-size:0.9rem">Environment</strong>
                            <div class="form-group" style="margin-top:8px">
                                <label>Climate</label>
                                <select class="form-control form-control-sm" @bind="_editArea.Environment.Climate">
                                    <option value="">— Select —</option>
                                    @foreach (var c in _climateOptions)
                                    {
                                        <option value="@c">@c</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Soil Quality</label>
                                <select class="form-control form-control-sm" @bind="_editArea.Environment.SoilQuality">
                                    <option value="">— Select —</option>
                                    @foreach (var q in _qualityOptions)
                                    {
                                        <option value="@q">@q</option>
                                    }
                                </select>
                            </div>
                            <div style="display:flex;gap:8px">
                                <div class="form-group" style="flex:1">
                                    <label>Mineral Min</label>
                                    <select class="form-control form-control-sm" @bind="_editArea.Environment.MineralQualityRange.Min">
                                        <option value="">—</option>
                                        @foreach (var q in _qualityOptions)
                                        {
                                            <option value="@q">@q</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group" style="flex:1">
                                    <label>Mineral Max</label>
                                    <select class="form-control form-control-sm" @bind="_editArea.Environment.MineralQualityRange.Max">
                                        <option value="">—</option>
                                        @foreach (var q in _qualityOptions)
                                        {
                                            <option value="@q">@q</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        @* Area Chaos Override *@
                        <div class="panel-section">
                            <div class="panel-section__header">
                                <strong>Chaos Override</strong>
                                @if (_editArea.Environment.Chaos == null)
                                {
                                    <button class="btn btn-sm btn-secondary" style="font-size:0.75rem" @onclick="AddEditAreaChaos">+ Add</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" style="font-size:0.75rem" @onclick="RemoveEditAreaChaos">Remove</button>
                                }
                            </div>
                            @if (_editArea.Environment.Chaos != null)
                            {
                                <div style="display:flex;flex-direction:column;gap:4px">
                                    <div class="form-group">
                                        <label>Danger (@_editArea.Environment.Chaos.Danger)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editArea.Environment.Chaos.Danger" />
                                    </div>
                                    <div class="form-group">
                                        <label>Corruption (@_editArea.Environment.Chaos.Corruption)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editArea.Environment.Chaos.Corruption" />
                                    </div>
                                    <div class="form-group">
                                        <label>Density (@_editArea.Environment.Chaos.Density)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editArea.Environment.Chaos.Density" />
                                    </div>
                                    <div class="form-group">
                                        <label>Mutation (@_editArea.Environment.Chaos.Mutation)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editArea.Environment.Chaos.Mutation" />
                                    </div>
                                </div>
                            }
                        </div>

                        @* Places of Interest *@
                        <div class="panel-section">
                            <div class="panel-section__header">
                                <strong>Places of Interest (@(_editArea.PlacesOfInterest?.Count ?? 0))</strong>
                                <button class="btn btn-sm btn-secondary" style="font-size:0.75rem" @onclick="AddEditAreaPoi">+ POI</button>
                            </div>

                            @if (_editArea.PlacesOfInterest != null)
                            {
                                @for (int pidx = 0; pidx < _editArea.PlacesOfInterest.Count; pidx++)
                                {
                                    var pi = pidx;
                                    var poi = _editArea.PlacesOfInterest[pi];
                                    <div class="poi-card">
                                        <div class="poi-card__header">
                                            <small><strong>@(string.IsNullOrWhiteSpace(poi.Name) ? $"POI {pi + 1}" : poi.Name)</strong></small>
                                            <button class="btn btn-sm btn-outline-danger" style="font-size:0.65rem;padding:0 5px" @onclick="() => RemoveEditAreaPoi(pi)">✕</button>
                                        </div>
                                        <div class="poi-card__fields">
                                            <div class="form-group">
                                                <label>ResRef</label>
                                                @if (_knownAreas.Count > 0)
                                                {
                                                    <input class="form-control form-control-sm" list="@($"poi-area-{pi}")"
                                                           @bind="poi.ResRef" maxlength="16" placeholder="Area..." />
                                                    <datalist id="@($"poi-area-{pi}")">
                                                        @foreach (var ka in _knownAreas)
                                                        {
                                                            <option value="@ka.ResRef">@ka.ResRef — @ka.Name</option>
                                                        }
                                                    </datalist>
                                                }
                                                else
                                                {
                                                    <input class="form-control form-control-sm" @bind="poi.ResRef" maxlength="16" placeholder="ResRef..." />
                                                }
                                            </div>
                                            <div class="form-group">
                                                <label>Tag</label>
                                                @{ var tagDup = IsPoiTagDuplicate(poi.Tag, pi); }
                                                <input class="form-control form-control-sm @(tagDup ? "is-invalid" : "")" @bind="poi.Tag" />
                                                @if (tagDup)
                                                {
                                                    <div class="invalid-feedback" style="display:block;font-size:0.7rem">Duplicate tag</div>
                                                }
                                            </div>
                                            <div class="form-group">
                                                <label>Name</label>
                                                <input class="form-control form-control-sm" @bind="poi.Name" />
                                            </div>
                                            <div class="form-group">
                                                <label>Type</label>
                                                <select class="form-control form-control-sm" @bind="poi.Type">
                                                    <option value="">—</option>
                                                    @foreach (var t in _poiTypeOptions)
                                                    {
                                                        <option value="@t">@t</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                        <div class="form-group" style="margin-top:4px">
                                            <label>Description</label>
                                            <input class="form-control form-control-sm" @bind="poi.Description" />
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>

                @* ---- Panel Footer (save buttons) ---- *@
                @if (_panelMode == PanelMode.RegionEditor || _panelMode == PanelMode.AreaEditor)
                {
                    <div class="region-editor__panel-footer">
                        <button class="btn btn-secondary btn-sm" @onclick="ClosePanelEditor">Cancel</button>
                        <button class="btn btn-primary btn-sm" @onclick="SaveCurrentEditor" disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : "Save")
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @* ===== Import Modal ===== *@
    @if (_showImportModal)
    {
        <div class="modal-backdrop" @onclick="CloseImportModal">
        <div class="admin-modal" @onclick:stopPropagation="true" style="max-width:600px;max-height:80vh;overflow-y:auto;margin:10vh auto;background:var(--bg-card);border-radius:12px;padding:30px;position:fixed;top:0;left:50%;transform:translateX(-50%);z-index:1050;box-shadow:0 10px 40px rgba(0,0,0,0.5)">
            <h2>Import Region Definitions</h2>
            <p style="color:var(--text-secondary);font-size:0.9rem">
                Upload or paste JSON containing region definitions.
            </p>
            <div class="form-group" style="margin-top:15px">
                <label>Upload JSON / ZIP</label>
                <InputFile OnChange="OnImportFileSelected" accept=".json,.zip" multiple class="form-control" />
            </div>
            <div class="form-group" style="margin-top:10px">
                <label>Or paste JSON</label>
                <textarea class="form-control" rows="8" @bind="_importJson"
                          placeholder='[{"Tag":"my_region","Name":"My Region","Areas":[...]}]'
                          style="font-family:monospace;font-size:0.85rem"></textarea>
            </div>
            @if (_importResult != null)
            {
                <div class="alert @(_importResult.Failed > 0 ? "alert-warning" : "alert-success")" style="margin-top:15px">
                    <strong>Import:</strong> @_importResult.Succeeded ok, @_importResult.Failed failed of @_importResult.Total.
                    @if (_importResult.Errors.Count > 0)
                    {
                        <ul style="margin-top:8px;margin-bottom:0">
                            @foreach (var err in _importResult.Errors.Take(10))
                            {
                                <li style="font-size:0.85rem">@err</li>
                            }
                        </ul>
                    }
                </div>
            }
            <div class="form-actions" style="margin-top:20px;display:flex;gap:10px;justify-content:flex-end">
                <button class="btn btn-secondary" @onclick="CloseImportModal">Close</button>
                <button class="btn btn-primary" @onclick="RunImport" disabled="@(_isSaving || string.IsNullOrWhiteSpace(_importJson))">
                    @(_isSaving ? "Importing..." : "Import")
                </button>
            </div>
        </div>
        </div>
    }
</div>

<style>
    .modal-backdrop {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.6);
        z-index: 1040;
    }
</style>

@code {
    // ===== Enums =====
    private enum PanelMode { RegionList, RegionEditor, AreaEditor }

    // ===== Static option lists =====
    private static readonly string[] _climateOptions = { "Undefined", "Temperate", "Tropical", "Arid", "Arctic", "Mediterranean", "Continental", "Oceanic", "Subarctic", "Alpine", "Tundra", "Desert" };
    private static readonly string[] _qualityOptions = { "None", "VeryPoor", "Poor", "BelowAverage", "Average", "AboveAverage", "Good", "VeryGood", "Excellent", "Masterwork" };
    private static readonly string[] _poiTypeOptions = { "Undefined", "Dungeon", "Landmark", "ResourceNode", "House", "Guild", "Temple", "Library", "Shop", "Warehouse", "Bank" };

    // ===== Endpoint State =====
    private List<WorldEngineEndpoint> _endpoints = [];
    private WorldEngineEndpoint? _selectedEndpoint;

    // ===== Data =====
    private List<RegionDefinitionDto> _regions = [];
    private int _totalCount;
    private int _page = 1;
    private int _pageSize = 200;
    private string _searchTerm = "";

    // ===== UI State =====
    private bool _isLoading;
    private bool _isSaving;
    private string? _error;
    private string? _success;
    private PanelMode _panelMode = PanelMode.RegionList;
    private string _regionListFilter = "";

    // ===== Region Editor State =====
    private bool _isCreating;
    private RegionDefinitionDto _editRegion = new();
    private bool _showDeleteConfirm;
    private bool _showAddAreaInput;
    private string _newAreaResRef = "";

    // ===== Area Editor State =====
    private AreaDefinitionDto? _editArea;
    private string? _editAreaRegionTag;
    private string? _editAreaOriginalRegionTag;
    private string? _editAreaName;

    // ===== Import =====
    private bool _showImportModal;
    private string _importJson = "";
    private ImportResult? _importResult;
    private List<System.Text.Json.JsonElement> _importedRegions = new();

    // ===== Export =====
    private bool _isExporting;

    // ===== Area Graph =====
    private bool _isGraphLoading;
    private AreaGraphDto? _graphData;
    private List<AreaNodeDto> _knownAreas = new();
    private Dictionary<string, string> _regionColors = new();
    private string _graphSearchQuery = "";
    private DotNetObjectReference<Regions>? _dotNetRef;

    private static readonly JsonSerializerOptions CamelCase = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() }
    };

    // ===== Lifecycle =====

    protected override async Task OnInitializedAsync()
    {
        await RefreshEndpoints();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("regionGraph.destroy"); }
        catch { /* component may already be disposed */ }
        _dotNetRef?.Dispose();
    }

    // ===== Endpoint Handling =====

    private async Task RefreshEndpoints()
    {
        var all = await EndpointService.GetAllEndpointsAsync();
        _endpoints = all.Where(e => e.IsEnabled).ToList();
        if (_selectedEndpoint != null && !_endpoints.Any(e => e.Id == _selectedEndpoint.Id))
            _selectedEndpoint = null;
        StateHasChanged();
    }

    private async Task OnEndpointChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedEndpoint = _endpoints.FirstOrDefault(ep => ep.Id == id);
            Api.SelectEndpoint(id);
            GraphApi.SelectEndpoint(id);
            _page = 1;
            _graphData = null;
            _knownAreas.Clear();
            _regionColors.Clear();
            _panelMode = PanelMode.RegionList;
            await RefreshRegions();
        }
        else
        {
            _selectedEndpoint = null;
            Api.SelectEndpoint(null);
            GraphApi.SelectEndpoint(null);
            _regions.Clear();
            _graphData = null;
            _knownAreas.Clear();
            _regionColors.Clear();
        }
    }

    // ===== Data Loading =====

    private async Task RefreshRegions()
    {
        if (_selectedEndpoint == null) return;
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var result = await Api.GetAllAsync(_searchTerm, _page, _pageSize);
            _regions = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to load regions");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task PrevPage()
    {
        if (_page > 1) { _page--; await RefreshRegions(); }
    }

    private async Task NextPage()
    {
        if (_page * _pageSize < _totalCount) { _page++; await RefreshRegions(); }
    }

    private IEnumerable<RegionDefinitionDto> FilteredRegions()
    {
        if (string.IsNullOrWhiteSpace(_regionListFilter)) return _regions;
        var f = _regionListFilter.Trim();
        return _regions.Where(r =>
            r.Name.Contains(f, StringComparison.OrdinalIgnoreCase) ||
            r.Tag.Contains(f, StringComparison.OrdinalIgnoreCase));
    }

    // ===== Area Graph Loading =====

    private async Task LoadGraph()
    {
        await FetchGraph(refresh: false);
    }

    private async Task RefreshGraphData()
    {
        await FetchGraph(refresh: true);
    }

    private async Task FetchGraph(bool refresh)
    {
        _isGraphLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _graphData = refresh
                ? await GraphApi.RefreshGraphAsync()
                : await GraphApi.GetGraphAsync();

            if (_graphData != null)
            {
                BuildKnownAreas();
                BuildRegionColors();
                StateHasChanged();
                await Task.Delay(50);
                await RenderRegionGraph();
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load area graph: {ex.Message}";
            Logger.LogError(ex, "Failed to load area graph");
        }
        finally
        {
            _isGraphLoading = false;
            StateHasChanged();
        }
    }

    private void BuildKnownAreas()
    {
        if (_graphData == null) { _knownAreas.Clear(); return; }
        var all = new List<AreaNodeDto>(_graphData.Nodes.Count + _graphData.DisconnectedAreas.Count);
        all.AddRange(_graphData.Nodes);
        all.AddRange(_graphData.DisconnectedAreas);
        all.Sort((a, b) => string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase));
        _knownAreas = all;
    }

    private void BuildRegionColors()
    {
        _regionColors.Clear();
        var palette = new[]
        {
            "#e6194b", "#3cb44b", "#4363d8", "#f58231",
            "#911eb4", "#42d4f4", "#f032e6", "#bfef45",
            "#fabed4", "#469990", "#dcbeff", "#9A6324"
        };

        // Use region tags from _regions for color assignment
        for (int i = 0; i < _regions.Count; i++)
        {
            _regionColors[_regions[i].Tag] = palette[i % palette.Length];
            // Also store by name for legend lookups
            if (!_regionColors.ContainsKey(_regions[i].Name))
                _regionColors[_regions[i].Name] = palette[i % palette.Length];
        }
    }

    /// <summary>
    /// Build the JSON that the graph JS needs: regions with their area ResRefs and POI counts.
    /// </summary>
    private string BuildRegionsGraphJson()
    {
        var data = _regions.Select(r => new
        {
            tag = r.Tag,
            name = r.Name,
            areaResRefs = r.Areas.Where(a => !string.IsNullOrWhiteSpace(a.ResRef)).Select(a => a.ResRef).ToList(),
            poiCounts = r.Areas
                .Where(a => !string.IsNullOrWhiteSpace(a.ResRef) && a.PlacesOfInterest?.Count > 0)
                .ToDictionary(a => a.ResRef, a => a.PlacesOfInterest!.Count)
        });
        return JsonSerializer.Serialize(data, CamelCase);
    }

    private async Task RenderRegionGraph()
    {
        if (_graphData == null) return;

        try
        {
            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);

            string nodesJson = JsonSerializer.Serialize(_graphData.Nodes, CamelCase);
            string edgesJson = JsonSerializer.Serialize(_graphData.Edges, CamelCase);
            string disconnectedJson = JsonSerializer.Serialize(_graphData.DisconnectedAreas, CamelCase);
            string regionsJson = BuildRegionsGraphJson();

            await JS.InvokeVoidAsync("regionGraph.init", "region-cy", nodesJson, edgesJson, disconnectedJson, regionsJson, _dotNetRef);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to render region graph");
            _error = "Failed to render graph visualization.";
        }
    }

    // ===== Graph Interaction =====

    private async Task HighlightRegionOnGraph(string regionName)
    {
        try { await JS.InvokeVoidAsync("regionGraph.highlightRegion", regionName); }
        catch { /* ignore if graph not initialized */ }
    }

    private async Task HighlightOrphans()
    {
        try { await JS.InvokeVoidAsync("regionGraph.highlightOrphans"); }
        catch { }
    }

    private async Task ClearGraphHighlight()
    {
        try { await JS.InvokeVoidAsync("regionGraph.clearHighlight"); }
        catch { }
    }

    private async Task FitGraphView()
    {
        try { await JS.InvokeVoidAsync("regionGraph.fitView"); }
        catch { }
    }

    private async Task SearchInGraph()
    {
        if (string.IsNullOrWhiteSpace(_graphSearchQuery)) return;
        try
        {
            bool found = await JS.InvokeAsync<bool>("regionGraph.highlightNode", _graphSearchQuery);
            if (!found) _error = $"No area found matching '{_graphSearchQuery}'.";
        }
        catch (Exception ex) { Logger.LogError(ex, "Graph search error"); }
    }

    private async Task OnGraphSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchInGraph();
    }

    /// <summary>
    /// Lightweight graph update: pushes current region data to JS for in-place recolor/reparent.
    /// </summary>
    private async Task UpdateGraphRegionData()
    {
        if (_graphData == null) return;

        try
        {
            BuildRegionColors();

            // Update in-memory graph node regions
            var assignments = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var region in _regions)
                foreach (var area in region.Areas)
                    if (!string.IsNullOrWhiteSpace(area.ResRef))
                        assignments[area.ResRef] = region.Tag;

            foreach (var node in _graphData.Nodes.Concat(_graphData.DisconnectedAreas))
                node.Region = assignments.TryGetValue(node.ResRef, out var tag) ? tag : null;

            BuildRegionColors();
            string regionsJson = BuildRegionsGraphJson();
            await JS.InvokeVoidAsync("regionGraph.updateRegionData", regionsJson);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update graph region data");
        }
    }

    // ===== JS Callbacks =====

    [JSInvokable]
    public Task OnGraphNodeSelected(string json)
    {
        try
        {
            var info = JsonSerializer.Deserialize<GraphNodeInfo>(json, CamelCase);
            if (info != null)
            {
                OpenAreaEditor(info.ResRef, info.Region, info.Name);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to deserialize graph node selection");
        }
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnGraphNodeDeselected()
    {
        if (_panelMode == PanelMode.AreaEditor)
        {
            _panelMode = PanelMode.RegionList;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnRegionParentSelected(string regionTag)
    {
        var region = _regions.FirstOrDefault(r =>
            string.Equals(r.Tag, regionTag, StringComparison.OrdinalIgnoreCase));
        if (region != null)
        {
            SelectRegionForEdit(region);
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnNodeAssignedToRegion(string resRef, string regionTag)
    {
        // Add the area to the target region via API
        var targetRegion = _regions.FirstOrDefault(r =>
            string.Equals(r.Tag, regionTag, StringComparison.OrdinalIgnoreCase));
        if (targetRegion == null) return;

        // Remove from old region if present
        foreach (var r in _regions)
        {
            r.Areas.RemoveAll(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
        }

        // Add to target
        if (!targetRegion.Areas.Any(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase)))
        {
            targetRegion.Areas.Add(new AreaDefinitionDto { ResRef = resRef });
        }

        try
        {
            // Save all affected regions
            foreach (var r in _regions)
            {
                await Api.UpdateAsync(r.Tag, r);
            }
            _success = $"Assigned '{resRef}' to '{targetRegion.Name}'.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to assign area to region");
        }

        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnNodeUnassigned(string resRef)
    {
        // Remove from all regions
        bool changed = false;
        foreach (var r in _regions)
        {
            int removed = r.Areas.RemoveAll(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
            if (removed > 0)
            {
                try { await Api.UpdateAsync(r.Tag, r); changed = true; }
                catch (Exception ex) { _error = ex.Message; Logger.LogError(ex, "Failed to unassign area"); }
            }
        }

        if (changed)
        {
            _success = $"Unassigned '{resRef}' from its region.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
        }

        StateHasChanged();
    }

    [JSInvokable]
    public Task OnContextMenuAction(string action, string targetId)
    {
        switch (action)
        {
            case "newRegion":
                ShowCreateRegion();
                break;
            case "deleteRegion":
                var region = _regions.FirstOrDefault(r =>
                    string.Equals(r.Tag, targetId, StringComparison.OrdinalIgnoreCase));
                if (region != null)
                {
                    SelectRegionForEdit(region);
                    _showDeleteConfirm = true;
                }
                break;
        }
        StateHasChanged();
        return Task.CompletedTask;
    }

    // ===== Panel Mode Management =====

    private void ShowCreateRegion()
    {
        _isCreating = true;
        _editRegion = new RegionDefinitionDto();
        _showDeleteConfirm = false;
        _showAddAreaInput = false;
        _panelMode = PanelMode.RegionEditor;
    }

    private void SelectRegionForEdit(RegionDefinitionDto region)
    {
        _isCreating = false;
        _editRegion = CloneRegion(region);
        _showDeleteConfirm = false;
        _showAddAreaInput = false;
        _panelMode = PanelMode.RegionEditor;
    }

    private bool IsRegionSelected(RegionDefinitionDto region) =>
        _panelMode == PanelMode.RegionEditor && !_isCreating &&
        string.Equals(_editRegion.Tag, region.Tag, StringComparison.OrdinalIgnoreCase);

    private void OpenAreaEditor(string resRef, string? regionTag, string? areaName)
    {
        _editAreaRegionTag = regionTag ?? "";
        _editAreaOriginalRegionTag = _editAreaRegionTag;
        _editAreaName = areaName;

        // Find the AreaDefinitionDto in the region's data
        AreaDefinitionDto? found = null;
        if (!string.IsNullOrEmpty(regionTag))
        {
            var region = _regions.FirstOrDefault(r =>
                string.Equals(r.Tag, regionTag, StringComparison.OrdinalIgnoreCase));
            if (region != null)
            {
                found = region.Areas.FirstOrDefault(a =>
                    string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
            }
        }

        // If not found in any region, search all regions
        if (found == null)
        {
            foreach (var r in _regions)
            {
                found = r.Areas.FirstOrDefault(a =>
                    string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
                if (found != null)
                {
                    _editAreaRegionTag = r.Tag;
                    _editAreaOriginalRegionTag = r.Tag;
                    break;
                }
            }
        }

        // Clone or create new if unassigned
        _editArea = found != null ? CloneAreaDefinition(found) : new AreaDefinitionDto { ResRef = resRef };
        _panelMode = PanelMode.AreaEditor;
        StateHasChanged();
    }

    private void EditAreaInRegion(int areaIndex)
    {
        var area = _editRegion.Areas[areaIndex];
        _editAreaRegionTag = _editRegion.Tag;
        _editAreaOriginalRegionTag = _editRegion.Tag;
        _editAreaName = GetAreaNameByResRef(area.ResRef);
        _editArea = CloneAreaDefinition(area);
        _panelMode = PanelMode.AreaEditor;
    }

    private void ClosePanelEditor()
    {
        _panelMode = PanelMode.RegionList;
        _editArea = null;
        _showDeleteConfirm = false;
        _showAddAreaInput = false;
    }

    // ===== Save =====

    private async Task SaveCurrentEditor()
    {
        if (_panelMode == PanelMode.RegionEditor)
            await SaveRegion();
        else if (_panelMode == PanelMode.AreaEditor)
            await SaveArea();
    }

    private async Task SaveRegion()
    {
        _isSaving = true;
        _error = null;
        try
        {
            // Validate PoI tag uniqueness across all areas
            var allPoiTags = _editRegion.Areas
                .SelectMany(a => a.PlacesOfInterest ?? new())
                .Where(p => !string.IsNullOrWhiteSpace(p.Tag))
                .Select(p => p.Tag)
                .ToList();
            var duplicates = allPoiTags
                .GroupBy(t => t, StringComparer.OrdinalIgnoreCase)
                .Where(g => g.Count() > 1)
                .Select(g => g.Key)
                .ToList();
            if (duplicates.Count > 0)
            {
                _error = $"Duplicate PoI tags: {string.Join(", ", duplicates)}";
                return;
            }

            if (_isCreating)
                await Api.CreateAsync(_editRegion);
            else
                await Api.UpdateAsync(_editRegion.Tag, _editRegion);

            _success = _isCreating ? $"Region '{_editRegion.Name}' created." : $"Region '{_editRegion.Name}' updated.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
            _panelMode = PanelMode.RegionList;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to save region");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task SaveArea()
    {
        if (_editArea == null) return;
        _isSaving = true;
        _error = null;

        try
        {
            var resRef = _editArea.ResRef;
            var newRegionTag = _editAreaRegionTag;
            var oldRegionTag = _editAreaOriginalRegionTag;

            // If region changed, remove from old and add to new
            if (!string.Equals(oldRegionTag, newRegionTag, StringComparison.OrdinalIgnoreCase))
            {
                // Remove from old region
                if (!string.IsNullOrEmpty(oldRegionTag))
                {
                    var oldRegion = _regions.FirstOrDefault(r => string.Equals(r.Tag, oldRegionTag, StringComparison.OrdinalIgnoreCase));
                    if (oldRegion != null)
                    {
                        oldRegion.Areas.RemoveAll(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
                        await Api.UpdateAsync(oldRegion.Tag, oldRegion);
                    }
                }

                // Add to new region
                if (!string.IsNullOrEmpty(newRegionTag))
                {
                    var newRegion = _regions.FirstOrDefault(r => string.Equals(r.Tag, newRegionTag, StringComparison.OrdinalIgnoreCase));
                    if (newRegion != null)
                    {
                        newRegion.Areas.RemoveAll(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
                        newRegion.Areas.Add(CloneAreaDefinition(_editArea));
                        await Api.UpdateAsync(newRegion.Tag, newRegion);
                    }
                }
            }
            else if (!string.IsNullOrEmpty(newRegionTag))
            {
                // Same region — just update the area data in place
                var targetRegion = _regions.FirstOrDefault(r => string.Equals(r.Tag, newRegionTag, StringComparison.OrdinalIgnoreCase));
                if (targetRegion != null)
                {
                    var idx = targetRegion.Areas.FindIndex(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
                    if (idx >= 0)
                        targetRegion.Areas[idx] = CloneAreaDefinition(_editArea);
                    else
                        targetRegion.Areas.Add(CloneAreaDefinition(_editArea));

                    await Api.UpdateAsync(targetRegion.Tag, targetRegion);
                }
            }

            _success = $"Area '{resRef}' saved.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
            _panelMode = PanelMode.RegionList;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to save area");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    // ===== Delete =====

    private async Task DeleteRegion()
    {
        if (_editRegion == null) return;
        _isSaving = true;
        _error = null;
        try
        {
            await Api.DeleteAsync(_editRegion.Tag);
            _success = $"Deleted region '{_editRegion.Name}'.";
            _showDeleteConfirm = false;
            _panelMode = PanelMode.RegionList;
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to delete region");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    // ===== Area Helpers =====

    private void AddArea()
    {
        _showAddAreaInput = true;
        _newAreaResRef = "";
    }

    private void ConfirmAddArea()
    {
        if (string.IsNullOrWhiteSpace(_newAreaResRef)) return;
        _editRegion.Areas.Add(new AreaDefinitionDto { ResRef = _newAreaResRef.Trim() });
        _newAreaResRef = "";
        _showAddAreaInput = false;
    }

    private void RemoveArea(int index)
    {
        _editRegion.Areas.RemoveAt(index);
    }

    private string? GetAreaNameByResRef(string? resRef)
    {
        if (string.IsNullOrWhiteSpace(resRef) || _knownAreas.Count == 0) return null;
        return _knownAreas.FirstOrDefault(a =>
            string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase))?.Name;
    }

    private List<AreaNodeDto> GetAvailableAreas(string? currentResRef)
    {
        var usedResRefs = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var a in _editRegion.Areas)
        {
            if (!string.IsNullOrWhiteSpace(a.ResRef) &&
                !string.Equals(a.ResRef, currentResRef, StringComparison.OrdinalIgnoreCase))
                usedResRefs.Add(a.ResRef);
        }
        return _knownAreas.Where(a => !usedResRefs.Contains(a.ResRef)).ToList();
    }

    // ===== Area Editor Helpers =====

    private void OnAreaRegionChanged(ChangeEventArgs e)
    {
        _editAreaRegionTag = e.Value?.ToString() ?? "";
    }

    private void OnAreaLinkedSettlementChanged(ChangeEventArgs e)
    {
        if (_editArea == null) return;
        _editArea.LinkedSettlement = int.TryParse(e.Value?.ToString(), out var val) && val > 0 ? val : null;
    }

    private void OnAreaDefinitionTagsChanged(ChangeEventArgs e)
    {
        if (_editArea == null) return;
        var raw = e.Value?.ToString() ?? "";
        _editArea.DefinitionTags = string.IsNullOrWhiteSpace(raw)
            ? new List<string>()
            : raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private void AddEditAreaChaos() { if (_editArea != null) _editArea.Environment.Chaos = new ChaosStateDto(); }
    private void RemoveEditAreaChaos() { if (_editArea != null) _editArea.Environment.Chaos = null; }

    private void AddEditAreaPoi()
    {
        if (_editArea == null) return;
        _editArea.PlacesOfInterest ??= new List<PlaceOfInterestDto>();
        _editArea.PlacesOfInterest.Add(new PlaceOfInterestDto());
    }

    private void RemoveEditAreaPoi(int index)
    {
        _editArea?.PlacesOfInterest?.RemoveAt(index);
    }

    private bool IsPoiTagDuplicate(string? tag, int poiIndex)
    {
        if (_editArea?.PlacesOfInterest == null || string.IsNullOrWhiteSpace(tag)) return false;
        for (int i = 0; i < _editArea.PlacesOfInterest.Count; i++)
        {
            if (i == poiIndex) continue;
            if (string.Equals(_editArea.PlacesOfInterest[i].Tag, tag, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        return false;
    }

    // ===== Chaos Helpers (Region Editor) =====

    private void AddDefaultChaos() => _editRegion.DefaultChaos = new ChaosStateDto();
    private void RemoveDefaultChaos() => _editRegion.DefaultChaos = null;

    // ===== Clone Helpers =====

    private static RegionDefinitionDto CloneRegion(RegionDefinitionDto source) => new()
    {
        Tag = source.Tag,
        Name = source.Name,
        DefaultChaos = source.DefaultChaos != null ? new ChaosStateDto
        {
            Danger = source.DefaultChaos.Danger,
            Corruption = source.DefaultChaos.Corruption,
            Density = source.DefaultChaos.Density,
            Mutation = source.DefaultChaos.Mutation
        } : null,
        Areas = source.Areas.Select(CloneAreaDefinition).ToList()
    };

    private static AreaDefinitionDto CloneAreaDefinition(AreaDefinitionDto a) => new()
    {
        ResRef = a.ResRef,
        DefinitionTags = a.DefinitionTags.ToList(),
        LinkedSettlement = a.LinkedSettlement,
        Environment = new EnvironmentDataDto
        {
            Climate = a.Environment.Climate,
            SoilQuality = a.Environment.SoilQuality,
            MineralQualityRange = new QualityRangeDto
            {
                Min = a.Environment.MineralQualityRange.Min,
                Max = a.Environment.MineralQualityRange.Max
            },
            Chaos = a.Environment.Chaos != null ? new ChaosStateDto
            {
                Danger = a.Environment.Chaos.Danger,
                Corruption = a.Environment.Chaos.Corruption,
                Density = a.Environment.Chaos.Density,
                Mutation = a.Environment.Chaos.Mutation
            } : null
        },
        PlacesOfInterest = a.PlacesOfInterest?.Select(p => new PlaceOfInterestDto
        {
            ResRef = p.ResRef,
            Tag = p.Tag,
            Name = p.Name,
            Type = p.Type,
            Description = p.Description
        }).ToList()
    };

    // ===== Import =====

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            foreach (var file in e.GetMultipleFiles(100))
            {
                if (file.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
                    await ProcessZipRegions(file);
                else
                    await ProcessJsonFileRegions(file);
            }
            _importJson = JsonSerializer.Serialize(_importedRegions);
            _importResult = null;
            _success = $"Loaded {_importedRegions.Count} region(s). Click Import to apply.";
            StateHasChanged();
        }
        catch (Exception ex) { _error = $"Failed to read file(s): {ex.Message}"; }
    }

    private async Task ProcessJsonFileRegions(IBrowserFile file)
    {
        using var reader = new StreamReader(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
        ParseJsonRegions(await reader.ReadToEndAsync());
    }

    private async Task ProcessZipRegions(IBrowserFile file)
    {
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
        ms.Position = 0;
        using var archive = new ZipArchive(ms, ZipArchiveMode.Read);
        foreach (var entry in archive.Entries)
        {
            if (!entry.FullName.EndsWith(".json", StringComparison.OrdinalIgnoreCase)) continue;
            using var entryStream = entry.Open();
            using var reader = new StreamReader(entryStream);
            ParseJsonRegions(await reader.ReadToEndAsync());
        }
    }

    private void ParseJsonRegions(string content)
    {
        using var doc = JsonDocument.Parse(content);
        if (doc.RootElement.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in doc.RootElement.EnumerateArray())
                _importedRegions.Add(item.Clone());
        }
        else if (doc.RootElement.ValueKind == JsonValueKind.Object)
        {
            _importedRegions.Add(doc.RootElement.Clone());
        }
    }

    private async Task RunImport()
    {
        if (string.IsNullOrWhiteSpace(_importJson)) return;
        _isSaving = true;
        _error = null;
        try
        {
            _importResult = await Api.ImportJsonAsync(_importJson);
            if (_importResult is { Failed: 0 })
                _success = $"Successfully imported {_importResult.Succeeded} regions.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
        }
        catch (Exception ex) { _error = ex.Message; Logger.LogError(ex, "Import failed"); }
        finally { _isSaving = false; StateHasChanged(); }
    }

    private void CloseImportModal()
    {
        _showImportModal = false;
        _importJson = "";
        _importResult = null;
        _importedRegions.Clear();
    }

    // ===== Export =====

    private async Task ExportRegions()
    {
        _isExporting = true;
        _error = null;
        StateHasChanged();
        try
        {
            string json = await Api.ExportJsonAsync(_searchTerm);
            string fileName = $"regions-export-{DateTime.UtcNow:yyyyMMdd-HHmmss}.json";
            await DownloadFileAsync(fileName, json);
            _success = "Export downloaded.";
        }
        catch (Exception ex) { _error = ex.Message; Logger.LogError(ex, "Export failed"); }
        finally { _isExporting = false; StateHasChanged(); }
    }

    private async Task DownloadFileAsync(string fileName, string content)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(content);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("adminPanelDownloadFile", fileName, base64);
    }

