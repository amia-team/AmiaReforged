@page "/worldengine/regions"
@using Microsoft.AspNetCore.Authorization
@using AmiaReforged.AdminPanel.Models
@using AmiaReforged.AdminPanel.Services
@using System.IO.Compression
@using System.Text.Json
@using System.Text.Json.Serialization
@attribute [Authorize]
@inject RegionApiService Api
@inject AreaGraphApiService GraphApi
@inject ResourceNodeApiService ResourceNodeApi
@inject IWorldEngineEndpointService EndpointService
@inject ILogger<Regions> Logger
@inject IJSRuntime JS
@inject GraphLayoutService LayoutService
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>Regions — Visual Editor</PageTitle>

<div class="region-editor">
    @* ===== Toolbar ===== *@
    <div class="region-editor__toolbar">
        <h1>Regions</h1>

        @if (_endpoints.Count > 0)
        {
            <div class="toolbar-group">
                <label style="font-size:0.82rem;color:var(--text-secondary);white-space:nowrap">Server:</label>
                <select class="form-control form-control-sm" style="width:auto;min-width:140px"
                        value="@(_selectedEndpoint?.Id.ToString() ?? "")" @onchange="OnEndpointChanged">
                    <option value="">— Select —</option>
                    @foreach (WorldEngineEndpoint ep in _endpoints)
                    {
                        <option value="@ep.Id">@ep.Name</option>
                    }
                </select>
            </div>
        }

        @if (_selectedEndpoint != null)
        {
            <div class="toolbar-divider"></div>

            <div class="toolbar-group">
                <input class="form-control form-control-sm" style="width:200px" @bind="_graphSearchQuery" @bind:event="oninput"
                       placeholder="Search areas..." @onkeydown="OnGraphSearchKeyDown" />
                <button class="btn btn-primary btn-sm" @onclick="SearchInGraph">🔎</button>
            </div>

            <div class="toolbar-divider"></div>

            <div class="toolbar-group">
                @if (!_isGraphLoading && _graphData == null)
                {
                    <button class="btn btn-primary btn-sm" @onclick="LoadGraph">Load Graph</button>
                }
                else if (_graphData != null)
                {
                    <button class="btn btn-warning btn-sm" @onclick="RefreshGraphData" disabled="@_isGraphLoading">
                        @(_isGraphLoading ? "Scanning..." : "Rescan")
                    </button>
                }
                <button class="btn btn-info btn-sm" @onclick="HighlightOrphans" disabled="@(_graphData == null)">Unassigned</button>
                <button class="btn btn-secondary btn-sm" @onclick="ClearGraphHighlight" disabled="@(_graphData == null)">Clear</button>
                <button class="btn btn-secondary btn-sm" @onclick="FitGraphView" disabled="@(_graphData == null)">Fit</button>
            </div>

            <div class="toolbar-divider"></div>

            <div class="toolbar-group">
                <label style="font-size:0.82rem;color:var(--text-secondary);white-space:nowrap">Layout:</label>
                <select class="form-control form-control-sm" style="width:auto;min-width:140px"
                        @bind="_selectedLayout" disabled="@(_graphData == null)">
                    <option value="compact-grid">Compact Grid</option>
                    <option value="cose">Force-Directed (CoSE)</option>
                    <option value="fcose">Fast Force-Directed (fCoSE)</option>
                    <option value="dagre">Hierarchical (Dagre)</option>
                    <option value="grid">Grid</option>
                    <option value="circle">Circle</option>
                    <option value="concentric">Concentric</option>
                    <option value="breadthfirst">Breadthfirst</option>
                </select>
                <button class="btn btn-secondary btn-sm" @onclick="ApplyLayout" disabled="@(_graphData == null)">Re-Layout</button>
                <button class="btn btn-secondary btn-sm" @onclick="() => _showLayoutConfigModal = true"
                        disabled="@(_graphData == null)" title="Configure layout parameters">⚙</button>
            </div>

            <div class="toolbar-divider"></div>

            <div class="toolbar-group">
                <button class="btn btn-info btn-sm" @onclick="() => _showImportModal = true">Import</button>
                <button class="btn btn-success btn-sm" @onclick="ExportRegions" disabled="@_isExporting">
                    @(_isExporting ? "..." : "Export")
                </button>
            </div>

            <div class="toolbar-divider"></div>

            <div class="toolbar-group">
                <button class="btn btn-sm @(_showOverlay ? "btn-accent" : "btn-secondary")" @onclick="ToggleOverlayPanel">
                    📋 Regions
                </button>
            </div>
        }

        <div style="flex:1"></div>
        <a href="/" class="btn btn-secondary btn-sm">← Dashboard</a>
    </div>

    @* ===== Alerts ===== *@
    @if (_error != null)
    {
        <div class="alert alert-danger" style="margin:8px 0 0 0;flex-shrink:0">
            @_error
            <button class="btn btn-sm btn-secondary" style="margin-left:10px" @onclick="() => _error = null">Dismiss</button>
        </div>
    }
    @if (_success != null)
    {
        <div class="alert alert-success" style="margin:8px 0 0 0;flex-shrink:0">
            @_success
            <button class="btn btn-sm btn-secondary" style="margin-left:10px" @onclick="() => _success = null">Dismiss</button>
        </div>
    }

    @* ===== No server selected =====  *@
    @if (_selectedEndpoint == null)
    {
        <div style="flex:1;display:flex;align-items:center;justify-content:center">
            <p style="color:var(--text-secondary);font-size:1.1rem">
                @if (_endpoints.Count == 0)
                {
                    <span>No WorldEngine servers configured. Go to <a href="/encounters">Encounters</a> to add one.</span>
                }
                else
                {
                    <span>Select a server from the toolbar to begin editing regions.</span>
                }
            </p>
        </div>
    }
    else
    {
        @* ===== Main split: Graph + Side Panel ===== *@
        <div class="region-editor__main">
            @* ===== Graph Area ===== *@
            <div class="region-editor__graph-wrapper">
                @if (_graphData != null)
                {
                    <div class="graph-info-bar">
                        <span>🟢 @_graphData.Nodes.Count connected</span>
                        <span>💎 @_graphData.DisconnectedAreas.Count disconnected</span>
                        <span>📍 @_regions.Count regions</span>
                        <span>⏱ @_graphData.GeneratedAtUtc.ToString("HH:mm:ss") UTC</span>
                    </div>
                }

                <div id="region-cy" class="region-editor__graph">
                    @if (_graphData == null && !_isGraphLoading)
                    {
                        <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-secondary)">
                            <div style="text-align:center">
                                <p style="font-size:1.1rem;margin-bottom:12px">Click <strong>Load Graph</strong> in the toolbar to visualise the area graph.</p>
                                <p style="font-size:0.85rem">Right-click the graph background to create regions, or drag areas into region groups.</p>
                            </div>
                        </div>
                    }
                </div>
                @if (_isGraphLoading && _graphLoadPercent > 0 && _graphLoadPercent < 100)
                {
                    <div style="position:absolute;top:0;left:0;right:0;z-index:10;pointer-events:none;padding:6px 12px">
                        <div style="background:rgba(26,26,26,0.75);border-radius:6px;padding:6px 12px;display:inline-flex;align-items:center;gap:10px;backdrop-filter:blur(4px)">
                            <div style="width:160px;background:rgba(255,255,255,0.1);border-radius:4px;height:6px;overflow:hidden">
                                <div style="background:var(--accent-color, #c9a84c);height:100%;border-radius:4px;transition:width 0.15s ease;width:@(_graphLoadPercent)%"></div>
                            </div>
                            <span style="font-size:0.75rem;color:var(--text-secondary);white-space:nowrap">@_graphLoadPhase @(_graphLoadPercent)%</span>
                        </div>
                    </div>
                }

                @* ===== Legend ===== *@
                @if (_regionColors.Count > 0)
                {
                    <div class="region-editor__legend">
                        @foreach (KeyValuePair<string, string> kv in _regionColors)
                        {
                            <span class="region-editor__legend-item" @onclick="() => HighlightRegionOnGraph(kv.Key)">
                                <span class="region-editor__legend-swatch" style="background:@kv.Value"></span>
                                @kv.Key
                            </span>
                        }
                        <span class="region-editor__legend-item" style="color:var(--text-secondary)">
                            <span class="region-editor__legend-swatch" style="background:#6b6b6b"></span>
                            Unassigned
                        </span>
                    </div>
                }

                @* ===== Overlay Panel (inside graph) ===== *@
                @if (_showOverlay)
                {
                <div class="region-overlay-panel region-overlay-panel--open"
                     style="position:absolute;top:0;right:0;bottom:0;width:380px;max-width:90%;background:#26241f;border-left:2px solid #c9a84c;z-index:500;display:flex;flex-direction:column;box-shadow:-4px 0 24px rgba(0,0,0,0.4);overflow:hidden;">
                @* ---- Panel Header ---- *@
                <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px solid #3a3733;background:#1c1b19;flex-shrink:0;">
                    @if (_panelMode == PanelMode.AreaEditor)
                    {
                        <h3>Area: @(_editAreaName ?? _editArea?.ResRef ?? "—")</h3>
                        <button class="btn btn-sm btn-secondary" @onclick="CloseOverlay">✕</button>
                    }
                    else if (_panelMode == PanelMode.RegionEditor)
                    {
                        <h3>@(_isCreating ? "New Region" : $"Region: {_editRegion.Name}")</h3>
                        <button class="btn btn-sm btn-secondary" @onclick="CloseOverlay">✕</button>
                    }
                    else
                    {
                        <h3>Regions (@_regions.Count)</h3>
                        <button class="btn btn-sm btn-primary" @onclick="ShowCreateRegion">+ New</button>
                    }
                </div>

                @* ---- Panel Body ---- *@
                <div class="region-editor__panel-body" style="flex:1;overflow-y:auto;padding:12px 14px;">
                    @if (_panelMode == PanelMode.RegionList)
                    {
                        @* ===== Region List ===== *@
                        @if (_isLoading)
                        {
                            <p style="text-align:center;color:var(--text-secondary);padding:20px 0"><em>Loading...</em></p>
                        }
                        else if (_regions.Count == 0)
                        {
                            <p style="color:var(--text-secondary);text-align:center;padding:20px 0">
                                No regions defined. Right-click the graph or click <strong>+ New</strong> to create one.
                            </p>
                        }
                        else
                        {
                            @* Search filter for region list *@
                            <div class="form-group" style="margin-bottom:10px">
                                <input class="form-control form-control-sm" @bind="_regionListFilter" @bind:event="oninput"
                                       placeholder="Filter regions..." />
                            </div>

                            @foreach (RegionDefinitionDto region in FilteredRegions())
                            {
                                string color = _regionColors.GetValueOrDefault(region.Name, _regionColors.GetValueOrDefault(region.Tag, "#6b6b6b"));
                                <div class="region-list-item @(IsRegionSelected(region) ? "region-list-item--active" : "")"
                                     @onclick="() => SelectRegionForEdit(region)"
                                     @oncontextmenu="() => SelectRegionForEdit(region)" @oncontextmenu:preventDefault>
                                    <span class="region-list-item__swatch" style="background:@color"></span>
                                    <div class="region-list-item__info">
                                        <div class="region-list-item__name">@region.Name</div>
                                        <div class="region-list-item__tag">@region.Tag</div>
                                    </div>
                                    <span class="region-list-item__count">@region.Areas.Count areas</span>
                                    <button class="btn btn-sm btn-info" style="padding:1px 5px;font-size:0.7rem"
                                            @onclick="() => HighlightRegionOnGraph(region.Name)" @onclick:stopPropagation>
                                        Show
                                    </button>
                                </div>
                            }

                            @* Pagination *@
                            @if (_totalCount > _pageSize)
                            {
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:10px;font-size:0.82rem">
                                    <span style="color:var(--text-secondary)">
                                        @((_page - 1) * _pageSize + 1)–@(Math.Min(_page * _pageSize, _totalCount)) of @_totalCount
                                    </span>
                                    <div style="display:flex;gap:4px">
                                        <button class="btn btn-sm btn-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">←</button>
                                        <button class="btn btn-sm btn-secondary" disabled="@(_page * _pageSize >= _totalCount)" @onclick="NextPage">→</button>
                                    </div>
                                </div>
                            }
                        }
                    }
                    else if (_panelMode == PanelMode.RegionEditor)
                    {
                        @* ===== Region Editor ===== *@
                        <div class="panel-section">
                            <strong style="font-size:0.9rem">Basic Info</strong>
                            <div class="form-group" style="margin-top:8px">
                                <label>Tag <small>(unique identifier)</small></label>
                                <input class="form-control form-control-sm" @bind="_editRegion.Tag" disabled="@(!_isCreating)" />
                            </div>
                            <div class="form-group">
                                <label>Name</label>
                                <input class="form-control form-control-sm" @bind="_editRegion.Name" />
                            </div>
                        </div>

                        @* Default Chaos *@
                        <div class="panel-section">
                            <div class="panel-section__header">
                                <strong>Default Chaos</strong>
                                @if (_editRegion.DefaultChaos == null)
                                {
                                    <button class="btn btn-sm btn-secondary" style="font-size:0.75rem" @onclick="AddDefaultChaos">+ Add</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" style="font-size:0.75rem" @onclick="RemoveDefaultChaos">Remove</button>
                                }
                            </div>
                            @if (_editRegion.DefaultChaos != null)
                            {
                                <div style="display:flex;flex-direction:column;gap:4px">
                                    <div class="form-group">
                                        <label>Danger (@_editRegion.DefaultChaos.Danger)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editRegion.DefaultChaos.Danger" />
                                    </div>
                                    <div class="form-group">
                                        <label>Corruption (@_editRegion.DefaultChaos.Corruption)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editRegion.DefaultChaos.Corruption" />
                                    </div>
                                    <div class="form-group">
                                        <label>Density (@_editRegion.DefaultChaos.Density)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editRegion.DefaultChaos.Density" />
                                    </div>
                                    <div class="form-group">
                                        <label>Mutation (@_editRegion.DefaultChaos.Mutation)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editRegion.DefaultChaos.Mutation" />
                                    </div>
                                </div>
                            }
                        </div>

                        @* Areas belonging to this region *@
                        <div class="panel-section">
                            <div class="panel-section__header">
                                <strong>Areas (@_editRegion.Areas.Count)</strong>
                                <button class="btn btn-sm btn-primary" style="font-size:0.75rem" @onclick="AddArea">+ Add</button>
                            </div>

                            @for (int idx = 0; idx < _editRegion.Areas.Count; idx++)
                            {
                                int i = idx;
                                AreaDefinitionDto area = _editRegion.Areas[i];
                                <div style="display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:1px solid var(--border-subtle)">
                                    <code style="flex:1;font-size:0.82rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                          title="@area.ResRef">
                                        @(string.IsNullOrWhiteSpace(area.ResRef) ? "(new)" : area.ResRef)
                                        @{ string? n = GetAreaNameByResRef(area.ResRef); }
                                        @if (!string.IsNullOrEmpty(n))
                                        {
                                            <small style="color:var(--text-secondary)"> — @n</small>
                                        }
                                    </code>
                                    <button class="btn btn-sm btn-secondary" style="font-size:0.7rem;padding:1px 5px"
                                            @onclick="() => EditAreaInRegion(i)">Edit</button>
                                    <button class="btn btn-sm btn-outline-danger" style="font-size:0.7rem;padding:1px 5px"
                                            @onclick="() => RemoveArea(i)">✕</button>
                                </div>
                            }

                            @* New area quick-add *@
                            @if (_showAddAreaInput)
                            {
                                <div style="display:flex;gap:4px;margin-top:6px;align-items:end">
                                    @if (_knownAreas.Count > 0)
                                    {
                                        <input class="form-control form-control-sm" list="add-area-list" @bind="_newAreaResRef" placeholder="ResRef..."
                                               style="flex:1" maxlength="16" />
                                        <datalist id="add-area-list">
                                            @foreach (AreaNodeDto ka in GetAvailableAreas(""))
                                            {
                                                <option value="@ka.ResRef">@ka.ResRef — @ka.Name</option>
                                            }
                                        </datalist>
                                    }
                                    else
                                    {
                                        <input class="form-control form-control-sm" @bind="_newAreaResRef" placeholder="ResRef..." style="flex:1" maxlength="16" />
                                    }
                                    <button class="btn btn-sm btn-primary" @onclick="ConfirmAddArea" disabled="@string.IsNullOrWhiteSpace(_newAreaResRef)">Add</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _showAddAreaInput = false">✕</button>
                                </div>
                            }
                        </div>

                        @* Delete region (inline confirm) *@
                        @if (!_isCreating)
                        {
                            @if (_showDeleteConfirm)
                            {
                                <div class="inline-confirm">
                                    <span>Delete <strong>@_editRegion.Name</strong>?</span>
                                    <button class="btn btn-sm btn-danger" @onclick="DeleteRegion" disabled="@_isSaving">Yes</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _showDeleteConfirm = false">No</button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" style="width:100%;margin-top:4px" @onclick="() => _showDeleteConfirm = true">
                                    Delete Region
                                </button>
                            }
                        }
                    }
                    else if (_panelMode == PanelMode.AreaEditor)
                    {
                        @* ===== Area Inline Editor ===== *@
                        <div class="panel-section">
                            <strong style="font-size:0.9rem">Area Info</strong>
                            <div class="form-group" style="margin-top:8px">
                                <label>ResRef</label>
                                <input class="form-control form-control-sm" value="@_editArea!.ResRef" disabled />
                            </div>
                            <div class="form-group">
                                <label>Region</label>
                                <select class="form-control form-control-sm" value="@_editAreaRegionTag"
                                        @onchange="OnAreaRegionChanged">
                                    <option value="">— Unassigned —</option>
                                    @foreach (RegionDefinitionDto r in _regions)
                                    {
                                        <option value="@r.Tag">@r.Name (@r.Tag)</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Linked Settlement ID</label>
                                <input type="number" class="form-control form-control-sm"
                                       value="@(_editArea.LinkedSettlement?.ToString() ?? "")"
                                       @onchange="OnAreaLinkedSettlementChanged" min="1" />
                            </div>
                            <div class="form-group">
                                <label>Resource Node Definitions</label>
                                @if (_editArea!.DefinitionTags.Count > 0)
                                {
                                    <div class="def-tag-chips">
                                        @foreach (string tag in _editArea.DefinitionTags)
                                        {
                                            ResourceNodeDefinitionDto? def = _allResourceDefs.FirstOrDefault(d => d.Tag == tag);
                                            <span class="def-tag-chip" title="@(def != null ? $"{def.Name} ({def.Type})" : tag)">
                                                @tag
                                                <button type="button" class="def-tag-chip-remove" @onclick="() => RemoveDefinitionTag(tag)">×</button>
                                            </span>
                                        }
                                    </div>
                                }
                                <div class="def-tag-picker" @onfocusin="() => _defTagDropdownOpen = true" @onfocusout="OnDefTagBlur">
                                    <input class="form-control form-control-sm" placeholder="Search definitions..."
                                           @bind="_defTagSearch" @bind:event="oninput"
                                           @onfocus="() => _defTagDropdownOpen = true" />
                                    @if (_defTagDropdownOpen)
                                    {
                                        List<ResourceNodeDefinitionDto> filtered = GetFilteredResourceDefs();
                                        @if (filtered.Count > 0)
                                        {
                                            <div class="def-tag-dropdown">
                                                @foreach (ResourceNodeDefinitionDto def in filtered.Take(30))
                                                {
                                                    <div class="def-tag-dropdown-item" @onmousedown="() => AddDefinitionTag(def.Tag)"
                                                         @onmousedown:preventDefault>
                                                        <span class="def-tag-dropdown-tag">@def.Tag</span>
                                                        @if (!string.IsNullOrEmpty(def.Name) || !string.IsNullOrEmpty(def.Type))
                                                        {
                                                            <span class="def-tag-dropdown-info">
                                                                @(def.Name ?? "") @(!string.IsNullOrEmpty(def.Type) ? $"· {def.Type}" : "")
                                                            </span>
                                                        }
                                                    </div>
                                                }
                                                @if (filtered.Count > 30)
                                                {
                                                    <div class="def-tag-dropdown-more">
                                                        @(filtered.Count - 30) more — refine search
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(_defTagSearch))
                                        {
                                            <div class="def-tag-dropdown">
                                                <div class="def-tag-dropdown-empty">No matching definitions</div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        @* Environment *@
                        <div class="panel-section">
                            <strong style="font-size:0.9rem">Environment</strong>
                            <div class="form-group" style="margin-top:8px">
                                <label>Climate</label>
                                <select class="form-control form-control-sm" @bind="_editArea.Environment.Climate">
                                    <option value="">— Select —</option>
                                    @foreach (string c in _climateOptions)
                                    {
                                        <option value="@c">@c</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Soil Quality</label>
                                <select class="form-control form-control-sm" @bind="_editArea.Environment.SoilQuality">
                                    <option value="">— Select —</option>
                                    @foreach (string q in _qualityOptions)
                                    {
                                        <option value="@q">@q</option>
                                    }
                                </select>
                            </div>
                            <div style="display:flex;gap:8px">
                                <div class="form-group" style="flex:1">
                                    <label>Mineral Min</label>
                                    <select class="form-control form-control-sm" @bind="_editArea.Environment.MineralQualityRange.Min">
                                        <option value="">—</option>
                                        @foreach (string q in _qualityOptions)
                                        {
                                            <option value="@q">@q</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group" style="flex:1">
                                    <label>Mineral Max</label>
                                    <select class="form-control form-control-sm" @bind="_editArea.Environment.MineralQualityRange.Max">
                                        <option value="">—</option>
                                        @foreach (string q in _qualityOptions)
                                        {
                                            <option value="@q">@q</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        @* Area Chaos Override *@
                        <div class="panel-section">
                            <div class="panel-section__header">
                                <strong>Chaos Override</strong>
                                @if (_editArea.Environment.Chaos == null)
                                {
                                    <button class="btn btn-sm btn-secondary" style="font-size:0.75rem" @onclick="AddEditAreaChaos">+ Add</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" style="font-size:0.75rem" @onclick="RemoveEditAreaChaos">Remove</button>
                                }
                            </div>
                            @if (_editArea.Environment.Chaos != null)
                            {
                                <div style="display:flex;flex-direction:column;gap:4px">
                                    <div class="form-group">
                                        <label>Danger (@_editArea.Environment.Chaos.Danger)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editArea.Environment.Chaos.Danger" />
                                    </div>
                                    <div class="form-group">
                                        <label>Corruption (@_editArea.Environment.Chaos.Corruption)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editArea.Environment.Chaos.Corruption" />
                                    </div>
                                    <div class="form-group">
                                        <label>Density (@_editArea.Environment.Chaos.Density)</label>
                                        <input type="range" class="form-range" min="0" max="100" @bind="_editArea.Environment.Chaos.Density" />
                                    </div>
                                    <div class="form-group">
