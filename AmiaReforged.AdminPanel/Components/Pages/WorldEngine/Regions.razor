        _showLayoutConfigModal = false;
        await ApplyLayout();
    }

    private Dictionary<string, object> BuildLayoutConfig()
    {
        Dictionary<string, object> cfg = new Dictionary<string, object>();
        switch (_selectedLayout)
        {
            case "compact-grid":
                cfg["nodeSpacing"] = _lcNodeSpacing;
                cfg["regionGap"] = _lcRegionGap;
                cfg["orphanGroupGap"] = _lcOrphanGroupGap;
                cfg["innerSort"] = _lcInnerSort;
                cfg["outerSort"] = _lcOuterSort;
                break;
            case "cose":
            case "fcose":
                cfg["nodeRepulsion"] = _lcNodeRepulsion;
                cfg["idealEdgeLength"] = _lcIdealEdgeLength;
                cfg["gravity"] = _lcGravity;
                cfg["nestingFactor"] = _lcNestingFactor;
                cfg["numIter"] = _lcNumIter;
                cfg["padding"] = _lcPadding;
                break;
            case "dagre":
                cfg["rankDir"] = _lcRankDir;
                cfg["nodeSep"] = _lcNodeSep;
                cfg["rankSep"] = _lcRankSep;
                cfg["edgeSep"] = _lcEdgeSep;
                cfg["padding"] = _lcPadding;
                break;
            case "breadthfirst":
                cfg["spacingFactor"] = _lcSpacingFactor;
                cfg["directed"] = _lcDirected;
                cfg["padding"] = _lcPadding;
                break;
            case "grid":
                cfg["condense"] = _lcCondense;
                if (_lcGridRows > 0) cfg["rows"] = _lcGridRows;
                cfg["padding"] = _lcPadding;
                break;
            case "circle":
                cfg["padding"] = _lcPadding;
                break;
            case "concentric":
                cfg["minNodeSpacing"] = _lcMinNodeSpacing;
                cfg["levelWidth"] = _lcLevelWidth;
                cfg["padding"] = _lcPadding;
                break;
        }
        return cfg;
    }

