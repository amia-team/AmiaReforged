    private async Task ApplyLayout()
    {
        if (_graphData == null) return;

        _isGraphLoading = true;
        _graphLoadPercent = 10;
        _graphLoadPhase = "Computing layout...";
        StateHasChanged();

        try
        {
            GraphLayoutResult layoutResult = await ComputeLayoutServerSide();

            _graphLoadPercent = 90;
            _graphLoadPhase = "Applying positions...";
            StateHasChanged();

            string positionsJson = JsonSerializer.Serialize(layoutResult.Positions, CamelCase);
            await JS.InvokeVoidAsync("regionGraph.applyPositions", positionsJson);

            _graphLoadPercent = 100;
            _graphLoadPhase = "Complete";
            _isGraphLoading = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to apply layout: {Layout}", _selectedLayout);
            _error = "Failed to compute layout.";
            _isGraphLoading = false;
        }
        finally
        {
            StateHasChanged();
        }
    }

