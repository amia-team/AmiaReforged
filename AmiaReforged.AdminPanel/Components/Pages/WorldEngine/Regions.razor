    private async Task SaveRegion()
    {
        _isSaving = true;
        _error = null;
        try
        {
            // Validate PoI tag uniqueness across all areas
            List<string> allPoiTags = _editRegion.Areas
                .SelectMany(a => a.PlacesOfInterest ?? new())
                .Where(p => !string.IsNullOrWhiteSpace(p.Tag))
                .Select(p => p.Tag)
                .ToList();
            List<string> duplicates = allPoiTags
                .GroupBy(t => t, StringComparer.OrdinalIgnoreCase)
                .Where(g => g.Count() > 1)
                .Select(g => g.Key)
                .ToList();
            if (duplicates.Count > 0)
            {
                _error = $"Duplicate PoI tags: {string.Join(", ", duplicates)}";
                return;
            }

            if (_isCreating)
                await Api.CreateAsync(_editRegion);
            else
                await Api.UpdateAsync(_editRegion.Tag, _editRegion);

            _success = _isCreating ? $"Region '{_editRegion.Name}' created." : $"Region '{_editRegion.Name}' updated.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
            _panelMode = PanelMode.RegionList;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to save region");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task SaveArea()
    {
        if (_editArea == null) return;
        _isSaving = true;
        _error = null;

        try
        {
            string resRef = _editArea.ResRef;
            string? newRegionTag = _editAreaRegionTag;
            string? oldRegionTag = _editAreaOriginalRegionTag;

            // If region changed, remove from old and add to new
            if (!string.Equals(oldRegionTag, newRegionTag, StringComparison.OrdinalIgnoreCase))
            {
                // Remove from old region
                if (!string.IsNullOrEmpty(oldRegionTag))
                {
                    RegionDefinitionDto? oldRegion = _regions.FirstOrDefault(r => string.Equals(r.Tag, oldRegionTag, StringComparison.OrdinalIgnoreCase));
                    if (oldRegion != null)
                    {
                        oldRegion.Areas.RemoveAll(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
                        await Api.UpdateAsync(oldRegion.Tag, oldRegion);
                    }
                }

                // Add to new region
                if (!string.IsNullOrEmpty(newRegionTag))
                {
                    RegionDefinitionDto? newRegion = _regions.FirstOrDefault(r => string.Equals(r.Tag, newRegionTag, StringComparison.OrdinalIgnoreCase));
                    if (newRegion != null)
                    {
                        newRegion.Areas.RemoveAll(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
                        newRegion.Areas.Add(CloneAreaDefinition(_editArea));
                        await Api.UpdateAsync(newRegion.Tag, newRegion);
                    }
                }
            }
            else if (!string.IsNullOrEmpty(newRegionTag))
            {
                // Same region — just update the area data in place
                RegionDefinitionDto? targetRegion = _regions.FirstOrDefault(r => string.Equals(r.Tag, newRegionTag, StringComparison.OrdinalIgnoreCase));
                if (targetRegion != null)
                {
                    int idx = targetRegion.Areas.FindIndex(a => string.Equals(a.ResRef, resRef, StringComparison.OrdinalIgnoreCase));
                    if (idx >= 0)
                        targetRegion.Areas[idx] = CloneAreaDefinition(_editArea);
                    else
                        targetRegion.Areas.Add(CloneAreaDefinition(_editArea));

                    await Api.UpdateAsync(targetRegion.Tag, targetRegion);
                }
            }

            _success = $"Area '{resRef}' saved.";
            await RefreshRegions();
            if (_graphData != null) await UpdateGraphRegionData();
            _panelMode = PanelMode.RegionList;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to save area");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

