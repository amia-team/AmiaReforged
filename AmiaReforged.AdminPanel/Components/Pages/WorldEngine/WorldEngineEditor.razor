    //  Codex Editor — Config Helpers
    // ═══════════════════════════════════════════════════════════════════

    private static string CeGetConfigString(ObjectiveDefinitionDto obj, string key, string fallback)
    {
        if (obj.Config != null && obj.Config.TryGetValue(key, out object? val) && val != null)
            return val.ToString() ?? fallback;
        return fallback;
    }

    private static void CeSetConfig(ObjectiveDefinitionDto obj, string key, string value)
    {
        obj.Config ??= new Dictionary<string, object>();
        obj.Config[key] = value;
    }

