    private async Task IeInitScriptEditor()
    {
        try
        {
            _ieScriptEditorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/glyph-editor.js");
            _ieDotNetRef ??= DotNetObjectReference.Create(this);

            string catalogJson = JsonSerializer.Serialize(_ieNodeCatalog);
            string graphJson = _iePipelineGraphJson;

            if (string.IsNullOrEmpty(graphJson) || graphJson == "{}" || !IeGraphHasNodes(graphJson))
            {
                graphJson = IeBuildEmptyPipelineGraphJson();
            }

            await _ieScriptEditorModule.InvokeVoidAsync("initGlyphEditor", "we-interaction-glyph-canvas", catalogJson, graphJson, _ieDotNetRef);
            _ieScriptEditorReady = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "IE script editor init failed");
            _ieScriptEditorReady = false;
        }
