    private ObjectiveDefinitionDto? CeGetGraphEditorObjective()
    {
        QuestStageDto? stage = _ceQuestItem.Stages.FirstOrDefault(s => s.StageId == _ceGraphEditorStageId);
        if (stage == null || _ceGraphEditorGroupIdx < 0 || _ceGraphEditorGroupIdx >= stage.ObjectiveGroups.Count)
            return null;
        ObjectiveGroupDto grp = stage.ObjectiveGroups[_ceGraphEditorGroupIdx];
        if (_ceGraphEditorObjIdx < 0 || _ceGraphEditorObjIdx >= grp.Objectives.Count)
            return null;
        return grp.Objectives[_ceGraphEditorObjIdx];
    }
