    //  Interaction Editor — Lifecycle
    // ═══════════════════════════════════════════════════════════════════

    private async Task OpenInteractionEditor(string interactionTag)
    {
        if (_interactionEditorOpen) await CloseInteractionEditor();

        _interactionEditorOpen = true;
        _interactionEditorLoading = true;
        _interactionEditorError = null;
        _ieError = null;
        _ieSuccess = null;
        _ieIsCreating = false;
        IeResetScriptState();
        StateHasChanged();

        try
        {
            // Load interaction and industries in parallel
            Task<InteractionDefinitionDto?> interactionTask = InteractionApi.GetByTagAsync(interactionTag);
            Task<PagedResult<IndustryDefinitionDto>> industriesTask = IndustryApi.GetAllAsync(null, 1, 200);

            await Task.WhenAll(interactionTask, industriesTask);

            InteractionDefinitionDto? loaded = await interactionTask;
            if (loaded == null)
            {
                _interactionEditorError = $"Interaction '{interactionTag}' not found.";
                _interactionEditorLoading = false;
                StateHasChanged();
                return;
            }

            _ieEditItem = IeDeepCopy(loaded);
            PagedResult<IndustryDefinitionDto> indResult = await industriesTask;
            _ieAvailableIndustries = indResult.Items;

            StateHasChanged();
            await Task.Delay(50); // Let DOM render GL host + panel divs

            await IeInitLayout();

            // Load existing glyph scripts for this interaction
            await IeLoadInteractionScripts(interactionTag);

            _interactionEditorLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to open interaction editor for {Tag}", interactionTag);
            _interactionEditorError = $"Failed to load: {ex.Message}";
            _interactionEditorLoading = false;
            StateHasChanged();
        }
    }

    private async Task CloseInteractionEditor()
    {
        await IeDestroyScriptEditor();

        if (_ieBridgeModule != null)
        {
            try { await _ieBridgeModule.InvokeVoidAsync("destroy", InteractionGlInstanceId); }
            catch (Exception ex) { Logger.LogWarning(ex, "IE GL bridge destroy failed"); }
        }

        _interactionEditorOpen = false;
        _interactionEditorLoading = false;
        _interactionEditorError = null;
        _ieError = null;
        _ieSuccess = null;
        _ieShowViewMenu = false;
        IeResetScriptState();
        StateHasChanged();
    }

