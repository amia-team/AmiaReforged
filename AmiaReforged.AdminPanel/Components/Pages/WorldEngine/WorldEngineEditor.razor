    private static InteractionDefinitionDto IeDeepCopy(InteractionDefinitionDto src) => new()
    {
        Tag = src.Tag,
        Name = src.Name,
        Description = src.Description,
        TargetMode = src.TargetMode,
        BaseRounds = src.BaseRounds,
        MinRounds = src.MinRounds,
        ProficiencyReducesRounds = src.ProficiencyReducesRounds,
        RequiresIndustryMembership = src.RequiresIndustryMembership,
        RequiredIndustryTags = [..src.RequiredIndustryTags],
        AllowedAreaResRefs = [..src.AllowedAreaResRefs],
        RequiredKnowledgeTags = [..src.RequiredKnowledgeTags],
        CreatedAt = src.CreatedAt,
        UpdatedAt = src.UpdatedAt,
        Responses = src.Responses.Select(r => new InteractionResponseDto
        {
            ResponseTag = r.ResponseTag,
            Weight = r.Weight,
            MinProficiency = r.MinProficiency,
            Message = r.Message,
            Effects = r.Effects.Select(e => new InteractionResponseEffectDto
            {
                EffectType = e.EffectType,
                Value = e.Value,
                Metadata = e.Metadata != null ? new Dictionary<string, object>(e.Metadata) : null,
            }).ToList(),
        }).ToList(),
    };

    private static bool IeGraphHasNodes(string? graphJson)
    {
        if (string.IsNullOrEmpty(graphJson) || graphJson == "{}") return false;
        try
        {
            using JsonDocument doc = JsonDocument.Parse(graphJson);
            return doc.RootElement.TryGetProperty("Nodes", out JsonElement nodesEl)
                && nodesEl.ValueKind == JsonValueKind.Array
                && nodesEl.GetArrayLength() > 0;
        }
        catch { return false; }
    }

    private static string IeBuildEmptyPipelineGraphJson()
    {
        Guid n1 = Guid.NewGuid(), n2 = Guid.NewGuid(), n3 = Guid.NewGuid(), n4 = Guid.NewGuid();
        var graph = new
        {
            Id = Guid.NewGuid(),
            Name = "",
            Description = "",
            EventType = IePipelineEventType,
            Nodes = new object[]
            {
                new { InstanceId = n1, TypeId = "stage.interaction_attempted", PositionX = 50.0, PositionY = 300.0, PropertyOverrides = new Dictionary<string, string>() },
                new { InstanceId = n2, TypeId = "stage.interaction_started", PositionX = 500.0, PositionY = 300.0, PropertyOverrides = new Dictionary<string, string>() },
                new { InstanceId = n3, TypeId = "stage.interaction_tick", PositionX = 950.0, PositionY = 300.0, PropertyOverrides = new Dictionary<string, string>() },
                new { InstanceId = n4, TypeId = "stage.interaction_completed", PositionX = 1400.0, PositionY = 300.0, PropertyOverrides = new Dictionary<string, string>() }
            },
            Edges = new[]
            {
                new { SourceNodeId = n1, SourcePinId = "exec_out", TargetNodeId = n2, TargetPinId = "exec_in" },
                new { SourceNodeId = n2, SourcePinId = "exec_out", TargetNodeId = n3, TargetPinId = "exec_in" },
                new { SourceNodeId = n3, SourcePinId = "exec_out", TargetNodeId = n4, TargetPinId = "exec_in" },
            },
            Variables = Array.Empty<object>()
        };
        return JsonSerializer.Serialize(graph);
    }

