    // ═══════════════════════════════════════════════════════════════════

    private async Task CeEnsureIndustriesLoaded()
    {
        if (_ceIndustriesLoaded) return;
        try
        {
            PagedResult<IndustryDefinitionDto> result = await IndustryApi.GetAllAsync(pageSize: 500);
            _ceIndustries = result.Items?.ToList() ?? [];
            _ceIndustriesLoaded = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load industries for reward dropdown");
            _ceIndustries = [];
        }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Codex Editor — Graph Editor
    // ═══════════════════════════════════════════════════════════════════

    private async Task CeOpenGraphEditor(int stageId, int groupIdx, int objIdx, string mode)
    {
        _ceGraphEditorStageId = stageId;
        _ceGraphEditorGroupIdx = groupIdx;
        _ceGraphEditorObjIdx = objIdx;
        _ceGraphEditorMode = mode;
        _ceGraphEditorOpen = true;
        StateHasChanged();

        // Give Blazor a tick to render the overlay DOM
        await Task.Delay(50);

        _ceDotNetRef ??= DotNetObjectReference.Create(this);

        ObjectiveDefinitionDto? obj = CeGetGraphEditorObjective();
        string existingJson = obj != null ? CeGetConfigString(obj, "graph_json", "{}") : "{}";

        if (mode == "clue_graph")
        {
            await JS.InvokeVoidAsync("clueGraphEditor.init", "ce-graph-canvas", existingJson, _ceDotNetRef);
        }
        else
        {
            await JS.InvokeVoidAsync("stateMachineEditor.init", "ce-graph-canvas", existingJson, _ceDotNetRef);
        }
    }

    private async Task CeCloseGraphEditor()
    {
        // Save the graph JSON back into the objective's config before closing
        try
        {
            string json;
            if (_ceGraphEditorMode == "clue_graph")
            {
                json = await JS.InvokeAsync<string>("clueGraphEditor.getGraphJson");
                await JS.InvokeVoidAsync("clueGraphEditor.destroy");
            }
            else
            {
                json = await JS.InvokeAsync<string>("stateMachineEditor.getGraphJson");
                await JS.InvokeVoidAsync("stateMachineEditor.destroy");
            }

            ObjectiveDefinitionDto? obj = CeGetGraphEditorObjective();
            if (obj != null && !string.IsNullOrWhiteSpace(json))
            {
                CeSetConfig(obj, "graph_json", json);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to save graph editor data");
        }

        _ceGraphEditorOpen = false;
    }

    [JSInvokable]
    public void OnGraphChanged(string graphJson)
    {
        // Live-update the objective config as the user edits the graph
        ObjectiveDefinitionDto? obj = CeGetGraphEditorObjective();
        if (obj != null)
        {
            CeSetConfig(obj, "graph_json", graphJson);
        }
    }

