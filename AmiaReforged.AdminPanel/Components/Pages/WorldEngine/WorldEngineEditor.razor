    private bool IeHasCurrentScript => IeGraphHasNodes(_iePipelineGraphJson);

    private IEnumerable<IGrouping<string, GlyphNodeCatalogEntryDto>> IeFilteredCatalog
    {
        get
        {
            IEnumerable<GlyphNodeCatalogEntryDto> nodes = _ieNodeCatalog;
            nodes = nodes.Where(n => n.RestrictToEventType == null || n.RestrictToEventType == IePipelineEventType);
            nodes = nodes.Where(n => n.ScriptCategory == null || n.ScriptCategory.Equals("Interaction", StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(_ieScriptNodeSearchFilter))
            {
                string filter = _ieScriptNodeSearchFilter.Trim().ToLowerInvariant();
                nodes = nodes.Where(n =>
                    n.DisplayName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                    n.Category.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                    n.Description.Contains(filter, StringComparison.OrdinalIgnoreCase));
            }
            return nodes.GroupBy(n => n.Category).OrderBy(g => g.Key);
        }
    }

