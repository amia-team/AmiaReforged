@page "/worldengine/editor"
@using Microsoft.AspNetCore.Authorization
@using AmiaReforged.AdminPanel.Models
@using AmiaReforged.AdminPanel.Services
@using System.Text.Json
@using System.Text.Json.Serialization
@attribute [Authorize]
@inject WorldEngineEditorState EditorState
@inject IWorldEngineEndpointService EndpointService
@inject GraphLayoutService LayoutService
@inject ItemApiService ItemApi
@inject ResourceNodeApiService ResourceNodeApi
@inject RegionApiService RegionApi
@inject AreaGraphApiService AreaGraphApi
@inject LoreApiService LoreApi
@inject TraitApiService TraitApi
@inject GlyphApiService GlyphApi
@inject IndustryApiService IndustryApi
@inject InteractionApiService InteractionApi
@inject CoinhouseApiService CoinhouseApi
@inject ILogger<WorldEngineEditor> Logger
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>World Engine Editor</PageTitle>

<div class="we-editor">
    @* ── Toolbar ─────────────────────────────────────────────────── *@
    <div class="we-editor__toolbar">
        <span class="we-editor__toolbar-brand">World Engine</span>

        @* Endpoint selector *@
        <div class="we-editor__endpoint-selector">
            <label>Server:</label>
            <select class="form-control form-control-sm"
                    value="@(EditorState.SelectedEndpointId?.ToString() ?? "")"
                    @onchange="OnEndpointChanged">
                <option value="">— Select —</option>
                @foreach (WorldEngineEndpoint ep in _endpoints)
                {
                    <option value="@ep.Id">@ep.Name</option>
                }
            </select>
        </div>

        @* Breadcrumb *@
        @if (EditorState.ActiveEntityType != null)
        {
            <span class="we-editor__breadcrumb">
                <span class="bi @GetEntityIcon(EditorState.ActiveEntityType.Value)"></span>
                @GetEntityLabel(EditorState.ActiveEntityType.Value)
                @if (EditorState.ActiveTab != null)
                {
                    <span class="we-editor__breadcrumb-sep">/</span>
                    <span>@EditorState.ActiveTab.Title</span>
                }
            </span>
        }

        <div class="we-editor__toolbar-spacer"></div>
    </div>

    <div class="we-editor__body">
        @* ── Activity bar ────────────────────────────────────────── *@
        <div class="we-editor__activity-bar">
            @foreach (WorldEngineEntityType entityType in Enum.GetValues<WorldEngineEntityType>())
            {
                bool isActive = EditorState.ActiveEntityType == entityType;
                <button class="we-editor__activity-btn @(isActive ? "we-editor__activity-btn--active" : "")"
                        title="@GetEntityLabel(entityType)"
                        @onclick="() => OnActivityBarClick(entityType)">
                    <span class="bi @GetEntityIcon(entityType)"></span>
                </button>
            }
        </div>

        @* ── List panel (collapsible) ────────────────────────────── *@
        @if (_listPanelOpen && EditorState.ActiveEntityType != null)
        {
            <div class="we-editor__list-panel">
                <div class="we-editor__list-header">
                    <span>@GetEntityLabel(EditorState.ActiveEntityType.Value)</span>
                    <button class="btn btn-sm btn-link" @onclick="() => _listPanelOpen = false" title="Close">
                        <span class="bi bi-x"></span>
                    </button>
                </div>

                @if (EditorState.SelectedEndpointId == null)
                {
                    <div class="we-editor__list-body">
                        <p class="text-muted small p-2">Select an endpoint to load entities.</p>
                    </div>
                }
                else
                {
                    @* Region graph button (only for Regions type) *@
                    @if (EditorState.ActiveEntityType == WorldEngineEntityType.Regions && EditorState.SelectedEndpointId != null)
                    {
                        <div class="we-editor__list-graph-btn">
                            @if (_regionGraphOpen)
                            {
                                <button class="btn btn-sm btn-accent w-100" @onclick="CloseRegionGraph">
                                    <span class="bi bi-x-circle me-1"></span> Close Graph View
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-primary w-100" @onclick="OpenRegionGraph">
                                    <span class="bi bi-diagram-3 me-1"></span> Open Region Graph
                                </button>
                            }
                        </div>
                    }

                    @* Search box *@
                    <div class="we-editor__list-search">
                        <input type="text" class="form-control form-control-sm"
                               placeholder="Search…"
                               value="@_listSearch"
                               @oninput="OnListSearchInput" />
                    </div>

                    <div class="we-editor__list-body">
                        @if (_listLoading)
                        {
                            <p class="text-muted small p-2"><em>Loading…</em></p>
                        }
                        else if (_listError != null)
                        {
                            <p class="text-danger small p-2">@_listError</p>
                        }
                        else if (_listItems.Count == 0)
                        {
                            <p class="text-muted small p-2">No entities found.</p>
                        }
                        else
                        {
                            @foreach (EntityListItem item in _listItems)
                            {
                                <button class="we-editor__list-item" @onclick="() => OnListItemClick(item)">
                                    <span class="we-editor__list-item-name">@item.DisplayName</span>
                                    <span class="we-editor__list-item-key">@item.Key</span>
                                </button>
                            }

                            @if (_listHasMore)
                            {
                                <button class="we-editor__list-load-more" @onclick="LoadMoreEntities">
                                    Load more…
                                </button>
                            }
                        }
                    </div>
                }
            </div>
        }

        @* ── Editor area ─────────────────────────────────────────── *@
        <div class="we-editor__editor-area">
            @if (_regionGraphOpen)
            {
                @* ══════ Region Graph GL Mode ══════ *@
                <div class="we-editor__region-graph-wrap">
                    @if (_regionGraphLoading)
                    {
                        <div class="we-editor__region-graph-loading">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>@_regionGraphLoadPhase @(_regionGraphLoadPercent > 0 ? $"{_regionGraphLoadPercent}%" : "")</span>
                        </div>
                    }
                    else if (_regionGraphError != null)
                    {
                        <div class="we-editor__tab-error">
                            <span class="bi bi-exclamation-triangle me-1"></span> @_regionGraphError
                            <button class="btn btn-sm btn-outline-warning ms-2" @onclick="OpenRegionGraph">Retry</button>
                        </div>
                    }

                    @* GL container *@
                    <div id="we-region-gl-container" class="we-editor__region-gl-host"></div>

                    @* Pre-rendered panel: Region Graph (Cytoscape + toolbar) *@
                    <div id="bl-panel-regiongraph" class="we-editor__gl-panel" style="display:none">
                        @* Compact graph toolbar *@
                        <div class="we-rg-toolbar">
                            <div class="we-rg-toolbar__group">
                                <input class="form-control form-control-sm" style="width:160px" @bind="_rgGraphSearchQuery" @bind:event="oninput"
                                       placeholder="Search areas…" @onkeydown="OnRgGraphSearchKeyDown" />
                                <button class="btn btn-sm btn-primary" @onclick="RgSearchInGraph" title="Search">
                                    <span class="bi bi-search"></span>
                                </button>
                            </div>
                            <div class="we-rg-toolbar__divider"></div>
                            <div class="we-rg-toolbar__group">
                                <button class="btn btn-sm btn-info" @onclick="RgHighlightOrphans" title="Highlight unassigned">Unassigned</button>
                                <button class="btn btn-sm btn-secondary" @onclick="RgClearHighlight" title="Clear highlights">Clear</button>
                                <button class="btn btn-sm btn-secondary" @onclick="RgFitView" title="Fit graph to view">Fit</button>
                            </div>
                            <div class="we-rg-toolbar__divider"></div>
                            <div class="we-rg-toolbar__group">
                                <select class="form-control form-control-sm" style="width:auto;min-width:120px" @bind="_rgSelectedLayout">
                                    <option value="compact-grid">Compact Grid</option>
                                    <option value="cose">CoSE</option>
                                    <option value="fcose">fCoSE</option>
                                    <option value="dagre">Dagre</option>
                                    <option value="grid">Grid</option>
                                    <option value="circle">Circle</option>
                                    <option value="concentric">Concentric</option>
                                    <option value="breadthfirst">Breadthfirst</option>
                                </select>
                                <button class="btn btn-sm btn-secondary" @onclick="RgApplyLayout" title="Re-layout">Re-Layout</button>
                            </div>
                            <div style="flex:1"></div>
                            @if (_rgRegionColors.Count > 0)
                            {
                                <div class="we-rg-toolbar__legend">
                                    @foreach (KeyValuePair<string, string> kv in _rgRegionColors.Where(kv => _rgRegions.Any(r => r.Name == kv.Key || r.Tag == kv.Key)).DistinctBy(kv => kv.Value))
                                    {
                                        <span class="we-rg-legend-item" @onclick="() => RgHighlightRegion(kv.Key)">
                                            <span class="we-rg-legend-swatch" style="background:@kv.Value"></span>
                                            @kv.Key
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                        @* Graph info bar *@
                        @if (_regionGraphData != null)
                        {
                            <div class="we-rg-info-bar">
                                <span>🟢 @_regionGraphData.Nodes.Count connected</span>
                                <span>💎 @_regionGraphData.DisconnectedAreas.Count disconnected</span>
                                <span>📍 @_rgRegions.Count regions</span>
                            </div>
                        }
                        @* Cytoscape container *@
                        <div id="region-cy-gl" class="we-rg-cytoscape"></div>
                    </div>

                    @* Pre-rendered panel: Region Properties *@
                    <div id="bl-panel-regionprops" class="we-editor__gl-panel" style="display:none">
                        <div class="we-rg-props">
                            @* Properties panel header *@
                            <div class="we-rg-props__header">
                                @if (_rgPanelMode == RgPanelMode.AreaEditor)
                                {
                                    <span>Area: @(_rgEditAreaName ?? _rgEditArea?.ResRef ?? "—")</span>
                                    <button class="btn btn-sm btn-secondary" @onclick="RgCloseEditor">✕</button>
                                }
                                else if (_rgPanelMode == RgPanelMode.RegionEditor)
                                {
                                    <span>@(_rgIsCreating ? "New Region" : $"Region: {_rgEditRegion.Name}")</span>
                                    <button class="btn btn-sm btn-secondary" @onclick="RgCloseEditor">✕</button>
                                }
                                else
                                {
                                    <span>Regions (@_rgRegions.Count)</span>
                                    <button class="btn btn-sm btn-primary" @onclick="RgShowCreateRegion">+ New</button>
                                }
                            </div>

                            @* Properties panel body *@
                            <div class="we-rg-props__body">
                                @if (_rgPanelMode == RgPanelMode.RegionList)
                                {
                                    @* Region List *@
                                    <div class="form-group" style="margin-bottom:10px">
                                        <input class="form-control form-control-sm" @bind="_rgRegionListFilter" @bind:event="oninput"
                                               placeholder="Filter regions…" />
                                    </div>
                                    @if (_rgRegions.Count == 0)
                                    {
                                        <p class="text-muted small p-2">No regions. Right-click the graph or click + New.</p>
                                    }
                                    else
                                    {
                                        @foreach (RegionDefinitionDto region in RgFilteredRegions())
                                        {
                                            string color = _rgRegionColors.GetValueOrDefault(region.Name, _rgRegionColors.GetValueOrDefault(region.Tag, "#6b6b6b"));
                                            <div class="region-list-item @(RgIsRegionSelected(region) ? "region-list-item--active" : "")"
                                                 @onclick="() => RgSelectRegionForEdit(region)">
                                                <span class="region-list-item__swatch" style="background:@color"></span>
                                                <div class="region-list-item__info">
                                                    <div class="region-list-item__name">@region.Name</div>
                                                    <div class="region-list-item__tag">@region.Tag</div>
                                                </div>
                                                <span class="region-list-item__count">@region.Areas.Count areas</span>
                                                <button class="btn btn-sm btn-info" style="padding:1px 5px;font-size:0.7rem"
                                                        @onclick="() => RgHighlightRegion(region.Name)" @onclick:stopPropagation>Show</button>
                                            </div>
                                        }
                                    }
                                }
                                else if (_rgPanelMode == RgPanelMode.RegionEditor)
                                {
                                    @* Region Editor *@
                                    <div class="panel-section">
                                        <strong style="font-size:0.9rem">Basic Info</strong>
                                        <div class="form-group" style="margin-top:8px">
                                            <label>Tag <small>(unique identifier)</small></label>
                                            <input class="form-control form-control-sm" @bind="_rgEditRegion.Tag" disabled="@(!_rgIsCreating)" />
                                        </div>
                                        <div class="form-group">
                                            <label>Name</label>
                                            <input class="form-control form-control-sm" @bind="_rgEditRegion.Name" />
                                        </div>
                                    </div>

                                    @* Default Chaos *@
                                    <div class="panel-section">
                                        <div class="panel-section__header">
                                            <strong>Default Chaos</strong>
                                            @if (_rgEditRegion.DefaultChaos == null)
                                            {
                                                <button class="btn btn-sm btn-secondary" style="font-size:0.75rem" @onclick="() => _rgEditRegion.DefaultChaos = new ChaosStateDto()">+ Add</button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-danger" style="font-size:0.75rem" @onclick="() => _rgEditRegion.DefaultChaos = null">Remove</button>
                                            }
                                        </div>
                                        @if (_rgEditRegion.DefaultChaos != null)
                                        {
                                            <div style="display:flex;flex-direction:column;gap:4px">
                                                <div class="form-group"><label>Danger (@_rgEditRegion.DefaultChaos.Danger)</label><input type="range" class="form-range" min="0" max="100" @bind="_rgEditRegion.DefaultChaos.Danger" /></div>
                                                <div class="form-group"><label>Corruption (@_rgEditRegion.DefaultChaos.Corruption)</label><input type="range" class="form-range" min="0" max="100" @bind="_rgEditRegion.DefaultChaos.Corruption" /></div>
                                                <div class="form-group"><label>Density (@_rgEditRegion.DefaultChaos.Density)</label><input type="range" class="form-range" min="0" max="100" @bind="_rgEditRegion.DefaultChaos.Density" /></div>
                                                <div class="form-group"><label>Mutation (@_rgEditRegion.DefaultChaos.Mutation)</label><input type="range" class="form-range" min="0" max="100" @bind="_rgEditRegion.DefaultChaos.Mutation" /></div>
                                            </div>
                                        }
                                    </div>

                                    @* Areas belonging to this region *@
                                    <div class="panel-section">
                                        <div class="panel-section__header">
                                            <strong>Areas (@_rgEditRegion.Areas.Count)</strong>
                                            <button class="btn btn-sm btn-primary" style="font-size:0.75rem" @onclick="RgOpenAddArea">+ Add</button>
                                        </div>
                                        @for (int idx = 0; idx < _rgEditRegion.Areas.Count; idx++)
                                        {
                                            int i = idx;
                                            AreaDefinitionDto area = _rgEditRegion.Areas[i];
                                            <div style="display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:1px solid var(--border-subtle)">
                                                <code style="flex:1;font-size:0.82rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@area.ResRef">
                                                    @(string.IsNullOrWhiteSpace(area.ResRef) ? "(new)" : area.ResRef)
                                                    @{ string? n = RgGetAreaName(area.ResRef); }
                                                    @if (!string.IsNullOrEmpty(n)) { <small style="color:var(--text-secondary)"> — @n</small> }
                                                </code>
                                                <button class="btn btn-sm btn-secondary" style="font-size:0.7rem;padding:1px 5px"
                                                        @onclick="() => RgEditAreaInRegion(i)">Edit</button>
                                                <button class="btn btn-sm btn-outline-danger" style="font-size:0.7rem;padding:1px 5px"
                                                        @onclick="() => _rgEditRegion.Areas.RemoveAt(i)">✕</button>
                                            </div>
                                        }
                                        @if (_rgShowAddAreaInput)
                                        {
                                            <div style="display:flex;gap:4px;margin-top:6px;align-items:end">
                                                <input class="form-control form-control-sm" @bind="_rgNewAreaResRef" placeholder="ResRef…" style="flex:1" maxlength="16" />
                                                <button class="btn btn-sm btn-primary" @onclick="RgConfirmAddArea" disabled="@string.IsNullOrWhiteSpace(_rgNewAreaResRef)">Add</button>
                                                <button class="btn btn-sm btn-secondary" @onclick="() => _rgShowAddAreaInput = false">✕</button>
                                            </div>
                                        }
                                    </div>

                                    @* Delete region *@
                                    @if (!_rgIsCreating)
                                    {
                                        @if (_rgShowDeleteConfirm)
                                        {
                                            <div class="inline-confirm">
                                                <span>Delete <strong>@_rgEditRegion.Name</strong>?</span>
                                                <button class="btn btn-sm btn-danger" @onclick="RgDeleteRegion" disabled="@_rgIsSaving">Yes</button>
                                                <button class="btn btn-sm btn-secondary" @onclick="() => _rgShowDeleteConfirm = false">No</button>
                                            </div>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger" style="width:100%;margin-top:4px" @onclick="() => _rgShowDeleteConfirm = true">Delete Region</button>
                                        }
                                    }
                                }
                                else if (_rgPanelMode == RgPanelMode.AreaEditor && _rgEditArea != null)
                                {
                                    @* Area Editor *@
                                    <div class="panel-section">
                                        <strong style="font-size:0.9rem">Area Info</strong>
                                        <div class="form-group" style="margin-top:8px">
                                            <label>ResRef</label>
                                            <input class="form-control form-control-sm" value="@_rgEditArea.ResRef" disabled />
                                        </div>
                                        <div class="form-group">
                                            <label>Region</label>
                                            <select class="form-control form-control-sm" value="@_rgEditAreaRegionTag"
                                                    @onchange="RgOnAreaRegionChanged">
                                                <option value="">— Unassigned —</option>
                                                @foreach (RegionDefinitionDto r in _rgRegions)
                                                {
                                                    <option value="@r.Tag">@r.Name (@r.Tag)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Linked Settlement ID</label>
                                            <input type="number" class="form-control form-control-sm"
                                                   value="@(_rgEditArea.LinkedSettlement?.ToString() ?? "")"
                                                   @onchange="e => _rgEditArea.LinkedSettlement = int.TryParse(e.Value?.ToString(), out int v) && v > 0 ? v : null" min="1" />
                                        </div>
                                        <div class="form-group">
                                            <label>Resource Node Definitions</label>
                                            @if (_rgEditArea.DefinitionTags.Count > 0)
                                            {
                                                <div class="def-tag-chips">
                                                    @foreach (string tag in _rgEditArea.DefinitionTags)
                                                    {
                                                        <span class="def-tag-chip" title="@tag">
                                                            @tag
                                                            <button type="button" class="def-tag-chip-remove" @onclick="() => _rgEditArea.DefinitionTags.Remove(tag)">×</button>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            <div class="def-tag-picker" @onfocusin="() => _rgDefTagDropdownOpen = true" @onfocusout="RgOnDefTagBlur">
                                                <input class="form-control form-control-sm" placeholder="Search definitions…"
                                                       @bind="_rgDefTagSearch" @bind:event="oninput"
                                                       @onfocus="() => _rgDefTagDropdownOpen = true" />
                                                @if (_rgDefTagDropdownOpen)
                                                {
                                                    List<ResourceNodeDefinitionDto> filtered = RgGetFilteredResourceDefs();
                                                    @if (filtered.Count > 0)
                                                    {
                                                        <div class="def-tag-dropdown">
                                                            @foreach (ResourceNodeDefinitionDto def in filtered.Take(30))
                                                            {
                                                                <div class="def-tag-dropdown-item" @onmousedown="() => RgAddDefinitionTag(def.Tag)" @onmousedown:preventDefault>
                                                                    <span class="def-tag-dropdown-tag">@def.Tag</span>
                                                                    @if (!string.IsNullOrEmpty(def.Name) || !string.IsNullOrEmpty(def.Type))
                                                                    {
                                                                        <span class="def-tag-dropdown-info">@(def.Name ?? "") @(!string.IsNullOrEmpty(def.Type) ? $"· {def.Type}" : "")</span>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    @* Environment *@
                                    <div class="panel-section">
                                        <strong style="font-size:0.9rem">Environment</strong>
                                        <div class="form-group" style="margin-top:8px">
                                            <label>Climate</label>
                                            <select class="form-control form-control-sm" @bind="_rgEditArea.Environment.Climate">
                                                <option value="">— Select —</option>
                                                @foreach (string c in _rgClimateOptions) { <option value="@c">@c</option> }
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Soil Quality</label>
                                            <select class="form-control form-control-sm" @bind="_rgEditArea.Environment.SoilQuality">
                                                <option value="">— Select —</option>
                                                @foreach (string q in _rgQualityOptions) { <option value="@q">@q</option> }
                                            </select>
                                        </div>
                                        <div style="display:flex;gap:8px">
                                            <div class="form-group" style="flex:1">
                                                <label>Mineral Min</label>
                                                <select class="form-control form-control-sm" @bind="_rgEditArea.Environment.MineralQualityRange.Min">
                                                    <option value="">—</option>
                                                    @foreach (string q in _rgQualityOptions) { <option value="@q">@q</option> }
                                                </select>
                                            </div>
                                            <div class="form-group" style="flex:1">
                                                <label>Mineral Max</label>
                                                <select class="form-control form-control-sm" @bind="_rgEditArea.Environment.MineralQualityRange.Max">
                                                    <option value="">—</option>
                                                    @foreach (string q in _rgQualityOptions) { <option value="@q">@q</option> }
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    @* Chaos Override *@
                                    <div class="panel-section">
                                        <div class="panel-section__header">
                                            <strong>Chaos Override</strong>
                                            @if (_rgEditArea.Environment.Chaos == null)
                                            {
                                                <button class="btn btn-sm btn-secondary" style="font-size:0.75rem" @onclick="() => _rgEditArea.Environment.Chaos = new ChaosStateDto()">+ Add</button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-danger" style="font-size:0.75rem" @onclick="() => _rgEditArea.Environment.Chaos = null">Remove</button>
                                            }
                                        </div>
                                        @if (_rgEditArea.Environment.Chaos != null)
                                        {
                                            <div style="display:flex;flex-direction:column;gap:4px">
                                                <div class="form-group"><label>Danger (@_rgEditArea.Environment.Chaos.Danger)</label><input type="range" class="form-range" min="0" max="100" @bind="_rgEditArea.Environment.Chaos.Danger" /></div>
                                                <div class="form-group"><label>Corruption (@_rgEditArea.Environment.Chaos.Corruption)</label><input type="range" class="form-range" min="0" max="100" @bind="_rgEditArea.Environment.Chaos.Corruption" /></div>
                                                <div class="form-group"><label>Density (@_rgEditArea.Environment.Chaos.Density)</label><input type="range" class="form-range" min="0" max="100" @bind="_rgEditArea.Environment.Chaos.Density" /></div>
                                                <div class="form-group"><label>Mutation (@_rgEditArea.Environment.Chaos.Mutation)</label><input type="range" class="form-range" min="0" max="100" @bind="_rgEditArea.Environment.Chaos.Mutation" /></div>
                                            </div>
                                        }
                                    </div>

                                    @* Places of Interest *@
                                    <div class="panel-section">
                                        <div class="panel-section__header">
                                            <strong>Places of Interest (@(_rgEditArea.PlacesOfInterest?.Count ?? 0))</strong>
                                            <button class="btn btn-sm btn-secondary" style="font-size:0.75rem" @onclick="RgAddPoi">+ POI</button>
                                        </div>
                                        @if (_rgEditArea.PlacesOfInterest != null)
                                        {
                                            @for (int pidx = 0; pidx < _rgEditArea.PlacesOfInterest.Count; pidx++)
                                            {
                                                int pi = pidx;
                                                PlaceOfInterestDto poi = _rgEditArea.PlacesOfInterest[pi];
                                                <div class="poi-card">
                                                    <div class="poi-card__header">
                                                        <small><strong>@(string.IsNullOrWhiteSpace(poi.Name) ? $"POI {pi + 1}" : poi.Name)</strong></small>
                                                        <button class="btn btn-sm btn-outline-danger" style="font-size:0.65rem;padding:0 5px" @onclick="() => _rgEditArea.PlacesOfInterest.RemoveAt(pi)">✕</button>
                                                    </div>
                                                    <div class="poi-card__fields">
                                                        <div class="form-group"><label>ResRef</label><input class="form-control form-control-sm" @bind="poi.ResRef" maxlength="16" placeholder="Area…" /></div>
                                                        <div class="form-group"><label>Tag</label><input class="form-control form-control-sm" @bind="poi.Tag" /></div>
                                                        <div class="form-group"><label>Name</label><input class="form-control form-control-sm" @bind="poi.Name" /></div>
                                                        <div class="form-group">
                                                            <label>Type</label>
                                                            <select class="form-control form-control-sm" @bind="poi.Type">
                                                                <option value="">—</option>
                                                                @foreach (string t in _rgPoiTypeOptions) { <option value="@t">@t</option> }
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="form-group" style="margin-top:4px">
                                                        <label>Description</label>
                                                        <input class="form-control form-control-sm" @bind="poi.Description" />
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                }

                                @* Status messages *@
                                @if (_rgError != null)
                                {
                                    <div class="alert alert-danger" style="font-size:0.82rem;margin-top:8px">@_rgError</div>
                                }
                                @if (_rgSuccess != null)
                                {
                                    <div class="alert alert-success" style="font-size:0.82rem;margin-top:8px">@_rgSuccess</div>
                                }
                            </div>

                            @* Properties panel footer (save buttons) *@
                            @if (_rgPanelMode == RgPanelMode.RegionEditor || _rgPanelMode == RgPanelMode.AreaEditor)
                            {
                                <div class="we-rg-props__footer">
                                    <button class="btn btn-secondary btn-sm" @onclick="RgCloseEditor">Cancel</button>
                                    <button class="btn btn-primary btn-sm" @onclick="RgSaveCurrentEditor" disabled="@_rgIsSaving">
                                        @(_rgIsSaving ? "Saving…" : "Save")
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
            @* ══════ Normal Tab Mode ══════ *@
            @* Tab bar *@
            @if (EditorState.OpenTabs.Count > 0)
            {
                <div class="we-editor__tab-bar">
                    @foreach (EditorTab tab in EditorState.OpenTabs)
                    {
                        bool isActive = tab.Id == EditorState.ActiveTabId;
                        <div class="we-editor__tab @(isActive ? "we-editor__tab--active" : "")"
                             @onclick="() => EditorState.ActiveTabId = tab.Id">
                            <span class="bi @GetEntityIcon(tab.EntityType) me-1"></span>
                            <span class="we-editor__tab-title">@tab.Title</span>
                            @if (tab.IsDirty)
                            {
                                <span class="we-editor__tab-dirty">●</span>
                            }
                            <button class="we-editor__tab-close" @onclick="() => CloseTab(tab.Id)" @onclick:stopPropagation="true">
                                <span class="bi bi-x"></span>
                            </button>
                        </div>
                    }
                </div>
            }

            @* Entity editor content *@
            <div class="we-editor__content">
                @if (EditorState.OpenTabs.Count == 0)
                {
                    <div class="we-editor__welcome">
                        <h2>World Engine Editor</h2>
                        <p class="text-muted">Select an entity type from the activity bar, then open an item to begin editing.</p>
                    </div>
                }
                else if (EditorState.ActiveTab is { } activeTab)
                {
                    @if (_tabDataLoading)
                    {
                        <div class="we-editor__tab-loading">
                            <span class="spinner-border spinner-border-sm me-2"></span> Loading…
                        </div>
                    }
                    else if (_tabDataError != null)
                    {
                        <div class="we-editor__tab-error">
                            <span class="bi bi-exclamation-triangle me-1"></span> @_tabDataError
                            <button class="btn btn-sm btn-outline-warning ms-2" @onclick="() => LoadTabData(activeTab)">Retry</button>
                        </div>
                    }
                    else if (_tabData.TryGetValue(activeTab.Id, out object? data) && data != null)
                    {
                        <div class="we-editor__entity-editor">
                            @RenderEntityEditor(activeTab, data)
                        </div>
                    }
                }
            </div>
            } @* end normal tab mode *@
        </div>
    </div>
</div>

@code {
    private List<WorldEngineEndpoint> _endpoints = [];
    private bool _listPanelOpen = true;

    // ── Entity list state ───────────────────────────────────────────
    private List<EntityListItem> _listItems = [];
    private bool _listLoading;
    private string? _listError;
    private string _listSearch = "";
    private int _listPage = 1;
    private bool _listHasMore;
    private const int ListPageSize = 50;
    private CancellationTokenSource? _searchCts;

    /// <summary>Lightweight display model for the entity list.</summary>
    private sealed record EntityListItem(string Key, string DisplayName, WorldEngineEntityType EntityType);

    // ── Tab data state ──────────────────────────────────────────────
    private readonly Dictionary<string, object?> _tabData = new();
    private bool _tabDataLoading;
    private string? _tabDataError;

    // ═══════════════════════════════════════════════════════════════════
    //  Region Graph state
    // ═══════════════════════════════════════════════════════════════════
    private const string RegionGlInstanceId = "we-region-graph";
    private bool _regionGraphOpen;
    private bool _regionGraphLoading;
    private bool _regionGraphNeedsInit;
    private string? _regionGraphError;
    private int _regionGraphLoadPercent;
    private string _regionGraphLoadPhase = "";

    private AreaGraphDto? _regionGraphData;
    private List<RegionDefinitionDto> _rgRegions = [];
    private List<AreaNodeDto> _rgKnownAreas = [];
    private Dictionary<string, string> _rgRegionColors = new();
    private List<ResourceNodeDefinitionDto> _rgAllResourceDefs = [];

    // Region graph editing state
    private enum RgPanelMode { RegionList, RegionEditor, AreaEditor }
    private RgPanelMode _rgPanelMode = RgPanelMode.RegionList;
    private string _rgRegionListFilter = "";
    private bool _rgIsCreating;
    private RegionDefinitionDto _rgEditRegion = new();
    private bool _rgShowDeleteConfirm;
    private bool _rgShowAddAreaInput;
    private string _rgNewAreaResRef = "";
    private AreaDefinitionDto? _rgEditArea;
    private string? _rgEditAreaRegionTag;
    private string? _rgEditAreaOriginalRegionTag;
    private string? _rgEditAreaName;
    private bool _rgIsSaving;
    private string? _rgError;
    private string? _rgSuccess;
    private string _rgDefTagSearch = "";
    private bool _rgDefTagDropdownOpen;

    // Region graph toolbar state
    private string _rgGraphSearchQuery = "";
    private string _rgSelectedLayout = "cose";

    // GL bridge refs
    private IJSObjectReference? _regionBridgeModule;
    private DotNetObjectReference<WorldEngineEditor>? _regionDotNetRef;

    private static readonly JsonSerializerOptions RgCamelCase = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() }
    };

    private static readonly string[] _rgClimateOptions = { "Tropical", "Arid", "Temperate", "Continental", "Polar", "Marine", "Subterranean", "Planar" };
    private static readonly string[] _rgQualityOptions = { "Terrible", "Poor", "Low", "Average", "Good", "High", "Excellent", "Legendary" };
    private static readonly string[] _rgPoiTypeOptions = { "Undefined", "Dungeon", "Landmark", "ResourceNode", "House", "Guild", "Temple", "Library", "Shop", "Warehouse", "Bank" };

    protected override async Task OnInitializedAsync()
    {
        _endpoints = (await EndpointService.GetEnabledEndpointsAsync()).ToList();

        // Subscribe to state changes
        EditorState.OnEndpointChanged += OnEditorEndpointChanged;
        EditorState.OnActiveEntityTypeChanged += OnActiveEntityTypeChanged;
        EditorState.OnActiveTabChanged += OnActiveTabChanged;
        EditorState.OnTabListChanged += StateHasChangedSafe;
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Endpoint
    // ═══════════════════════════════════════════════════════════════════

    private void OnEndpointChanged(ChangeEventArgs e)
    {
        string? val = e.Value?.ToString();
        EditorState.SelectedEndpointId = Guid.TryParse(val, out Guid id) ? id : null;
    }

    private void OnEditorEndpointChanged()
    {
        // Push the endpoint selection to ALL API services
        Guid? eid = EditorState.SelectedEndpointId;
        ItemApi.SelectEndpoint(eid);
        ResourceNodeApi.SelectEndpoint(eid);
        RegionApi.SelectEndpoint(eid);
        AreaGraphApi.SelectEndpoint(eid);
        LoreApi.SelectEndpoint(eid);
        TraitApi.SelectEndpoint(eid);
        GlyphApi.SelectEndpoint(eid);
        IndustryApi.SelectEndpoint(eid);
        InteractionApi.SelectEndpoint(eid);
        CoinhouseApi.SelectEndpoint(eid);

        // Reload the current entity list
        _ = InvokeAsync(async () =>
        {
            _listSearch = "";
            await LoadEntityList(reset: true);
            StateHasChanged();
        });
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Activity bar
    // ═══════════════════════════════════════════════════════════════════

    private async Task OnActivityBarClick(WorldEngineEntityType entityType)
    {
        // Close region graph if switching away from Regions
        if (_regionGraphOpen && entityType != WorldEngineEntityType.Regions)
        {
            await CloseRegionGraph();
        }

        if (EditorState.ActiveEntityType == entityType)
        {
            _listPanelOpen = !_listPanelOpen;
        }
        else
        {
            EditorState.ActiveEntityType = entityType;
            _listPanelOpen = true;
        }
    }

    private void OnActiveEntityTypeChanged()
    {
        _ = InvokeAsync(async () =>
        {
            _listSearch = "";
            await LoadEntityList(reset: true);
            StateHasChanged();
        });
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Entity list loading
    // ═══════════════════════════════════════════════════════════════════

    private async Task OnListSearchInput(ChangeEventArgs e)
    {
        _listSearch = e.Value?.ToString() ?? "";

        // Debounce: cancel any pending search, wait 300ms
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        CancellationToken token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            if (!token.IsCancellationRequested)
            {
                await LoadEntityList(reset: true);
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { /* debounce — expected */ }
    }

    private async Task LoadMoreEntities()
    {
        _listPage++;
        await LoadEntityList(reset: false);
    }

    private async Task LoadEntityList(bool reset)
    {
        if (EditorState.SelectedEndpointId == null || EditorState.ActiveEntityType == null)
        {
            _listItems.Clear();
            _listHasMore = false;
            return;
        }

        if (reset)
        {
            _listPage = 1;
            _listItems.Clear();
        }

        _listLoading = true;
        _listError = null;
        StateHasChanged();

        try
        {
            WorldEngineEntityType type = EditorState.ActiveEntityType.Value;
            string? search = string.IsNullOrWhiteSpace(_listSearch) ? null : _listSearch.Trim();

            List<EntityListItem> fetched = type switch
            {
                WorldEngineEntityType.Items => await LoadItems(search),
                WorldEngineEntityType.ResourceNodes => await LoadResourceNodes(search),
                WorldEngineEntityType.Regions => await LoadRegions(search),
                WorldEngineEntityType.AreaGraph => await LoadAreaGraph(),
                WorldEngineEntityType.Lore => await LoadLore(search),
                WorldEngineEntityType.Traits => await LoadTraits(search),
                WorldEngineEntityType.Glyphs => await LoadGlyphs(),
                WorldEngineEntityType.Industries => await LoadIndustries(search),
                WorldEngineEntityType.Interactions => await LoadInteractions(search),
                WorldEngineEntityType.Coinhouses => await LoadCoinhouses(search),
                _ => [],
            };

            if (reset)
                _listItems = fetched;
            else
                _listItems.AddRange(fetched);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load entity list for {Type}", EditorState.ActiveEntityType);
            _listError = $"Failed to load: {ex.Message}";
        }
        finally
        {
            _listLoading = false;
        }
    }

    // ── Per-type loaders ────────────────────────────────────────────

    private async Task<List<EntityListItem>> LoadItems(string? search)
    {
        PagedResult<ItemBlueprintDto> result = await ItemApi.GetAllAsync(search, _listPage, ListPageSize);
        _listHasMore = _listPage * ListPageSize < result.TotalCount;
        return result.Items.Select(i => new EntityListItem(i.ItemTag, i.Name, WorldEngineEntityType.Items)).ToList();
    }

    private async Task<List<EntityListItem>> LoadResourceNodes(string? search)
    {
        PagedResult<ResourceNodeDefinitionDto> result = await ResourceNodeApi.GetAllAsync(search, page: _listPage, pageSize: ListPageSize);
        _listHasMore = _listPage * ListPageSize < result.TotalCount;
        return result.Items.Select(i => new EntityListItem(i.Tag, i.Name ?? i.Tag, WorldEngineEntityType.ResourceNodes)).ToList();
    }

    private async Task<List<EntityListItem>> LoadRegions(string? search)
    {
        PagedResult<RegionDefinitionDto> result = await RegionApi.GetAllAsync(search, _listPage, ListPageSize);
        _listHasMore = _listPage * ListPageSize < result.TotalCount;
        return result.Items.Select(i => new EntityListItem(i.Tag, i.Name, WorldEngineEntityType.Regions)).ToList();
    }

    private async Task<List<EntityListItem>> LoadAreaGraph()
    {
        AreaGraphDto? graph = await AreaGraphApi.GetGraphAsync();
        _listHasMore = false;
        if (graph == null) return [];
        List<AreaNodeDto> all = [..graph.Nodes, ..graph.DisconnectedAreas];
        if (!string.IsNullOrWhiteSpace(_listSearch))
        {
            string filter = _listSearch.Trim();
            all = all.Where(n => (n.Name?.Contains(filter, StringComparison.OrdinalIgnoreCase) ?? false)
                               || n.ResRef.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();
        }
        return all.Select(n => new EntityListItem(n.ResRef, n.Name ?? n.ResRef, WorldEngineEntityType.AreaGraph)).ToList();
    }

    private async Task<List<EntityListItem>> LoadLore(string? search)
    {
        PagedResult<LoreDefinitionDto> result = await LoreApi.GetAllAsync(search, page: _listPage, pageSize: ListPageSize);
        _listHasMore = _listPage * ListPageSize < result.TotalCount;
        return result.Items.Select(i => new EntityListItem(i.LoreId, i.Title, WorldEngineEntityType.Lore)).ToList();
    }

    private async Task<List<EntityListItem>> LoadTraits(string? search)
    {
        PagedResult<TraitDefinitionDto> result = await TraitApi.GetAllAsync(search, page: _listPage, pageSize: ListPageSize);
        _listHasMore = _listPage * ListPageSize < result.TotalCount;
        return result.Items.Select(i => new EntityListItem(i.Tag, i.Name, WorldEngineEntityType.Traits)).ToList();
    }

    private async Task<List<EntityListItem>> LoadGlyphs()
    {
        List<GlyphDefinitionDto> all = await GlyphApi.GetAllDefinitionsAsync();
        _listHasMore = false;
        if (!string.IsNullOrWhiteSpace(_listSearch))
        {
            string filter = _listSearch.Trim();
            all = all.Where(g => g.Name.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();
        }
        return all.Select(g => new EntityListItem(g.Id.ToString(), g.Name, WorldEngineEntityType.Glyphs)).ToList();
    }

    private async Task<List<EntityListItem>> LoadIndustries(string? search)
    {
        PagedResult<IndustryDefinitionDto> result = await IndustryApi.GetAllAsync(search, _listPage, ListPageSize);
        _listHasMore = _listPage * ListPageSize < result.TotalCount;
        return result.Items.Select(i => new EntityListItem(i.Tag, i.Name, WorldEngineEntityType.Industries)).ToList();
    }

    private async Task<List<EntityListItem>> LoadInteractions(string? search)
    {
        PagedResult<InteractionDefinitionDto> result = await InteractionApi.GetAllAsync(search, _listPage, ListPageSize);
        _listHasMore = _listPage * ListPageSize < result.TotalCount;
        return result.Items.Select(i => new EntityListItem(i.Tag, i.Name, WorldEngineEntityType.Interactions)).ToList();
    }

    private async Task<List<EntityListItem>> LoadCoinhouses(string? search)
    {
        PagedResult<CoinhouseDto> result = await CoinhouseApi.GetAllAsync(search, _listPage, ListPageSize);
        _listHasMore = _listPage * ListPageSize < result.TotalCount;
        return result.Items.Select(i => new EntityListItem(i.Tag, i.Tag, WorldEngineEntityType.Coinhouses)).ToList();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  List item click → open tab
    // ═══════════════════════════════════════════════════════════════════

    private async Task OnListItemClick(EntityListItem item)
    {
        if (item.EntityType == WorldEngineEntityType.Regions)
        {
            await OnRegionListItemClick(item);
        }
        else
        {
            EditorTab tab = EditorState.OpenTab(item.EntityType, item.DisplayName, item.Key);
            // Data will be loaded by OnActiveTabChanged
        }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Tab data loading
    // ═══════════════════════════════════════════════════════════════════

    private void OnActiveTabChanged()
    {
        _ = InvokeAsync(async () =>
        {
            EditorTab? tab = EditorState.ActiveTab;
            if (tab != null && !_tabData.ContainsKey(tab.Id))
            {
                await LoadTabData(tab);
            }
            StateHasChanged();
        });
    }

    private async Task LoadTabData(EditorTab tab)
    {
        if (tab.EntityKey == null) return;

        _tabDataLoading = true;
        _tabDataError = null;
        StateHasChanged();

        try
        {
            object? data = tab.EntityType switch
            {
                WorldEngineEntityType.Items => await ItemApi.GetByTagAsync(tab.EntityKey),
                WorldEngineEntityType.ResourceNodes => await ResourceNodeApi.GetByTagAsync(tab.EntityKey),
                WorldEngineEntityType.Regions => await RegionApi.GetByTagAsync(tab.EntityKey),
                WorldEngineEntityType.Lore => await LoreApi.GetByIdAsync(tab.EntityKey),
                WorldEngineEntityType.Traits => await TraitApi.GetByTagAsync(tab.EntityKey),
                WorldEngineEntityType.Glyphs => await GlyphApi.GetDefinitionAsync(Guid.Parse(tab.EntityKey)),
                WorldEngineEntityType.Industries => await IndustryApi.GetByTagAsync(tab.EntityKey),
                WorldEngineEntityType.Interactions => await InteractionApi.GetByTagAsync(tab.EntityKey),
                WorldEngineEntityType.Coinhouses => await CoinhouseApi.GetByTagAsync(tab.EntityKey),
                WorldEngineEntityType.AreaGraph => null, // Area graph is a singleton, no per-entity load
                _ => null,
            };

            if (data != null)
                _tabData[tab.Id] = data;
            else
                _tabDataError = "Entity not found.";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load entity data for tab {TabId}", tab.Id);
            _tabDataError = $"Failed to load: {ex.Message}";
        }
        finally
        {
            _tabDataLoading = false;
        }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Tabs
    // ═══════════════════════════════════════════════════════════════════

    private void CloseTab(string tabId)
    {
        _tabData.Remove(tabId);
        EditorState.CloseTab(tabId);
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Entity rendering
    // ═══════════════════════════════════════════════════════════════════

    private RenderFragment RenderEntityEditor(EditorTab tab, object data) => builder =>
    {
        switch (tab.EntityType)
        {
            case WorldEngineEntityType.Items when data is ItemBlueprintDto item:
                RenderItemEditor(builder, item);
                break;
            case WorldEngineEntityType.ResourceNodes when data is ResourceNodeDefinitionDto node:
                RenderResourceNodeEditor(builder, node);
                break;
            case WorldEngineEntityType.Regions when data is RegionDefinitionDto region:
                RenderRegionEditor(builder, region);
                break;
            case WorldEngineEntityType.Lore when data is LoreDefinitionDto lore:
                RenderLoreEditor(builder, lore);
                break;
            case WorldEngineEntityType.Traits when data is TraitDefinitionDto trait:
                RenderTraitEditor(builder, trait);
                break;
            case WorldEngineEntityType.Glyphs when data is GlyphDefinitionDto glyph:
                RenderGlyphEditor(builder, glyph);
                break;
            case WorldEngineEntityType.Industries when data is IndustryDefinitionDto industry:
                RenderIndustryEditor(builder, industry);
                break;
            case WorldEngineEntityType.Interactions when data is InteractionDefinitionDto interaction:
                RenderInteractionEditor(builder, interaction);
                break;
            case WorldEngineEntityType.Coinhouses when data is CoinhouseDto coinhouse:
                RenderCoinhouseEditor(builder, coinhouse);
                break;
        }
    };

    // ── Item ────────────────────────────────────────────────────────
    private static void RenderItemEditor(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b, ItemBlueprintDto dto)
    {
        int s = 0;
        b.OpenElement(s++, "div"); b.AddAttribute(s++, "class", "we-entity-form");
        AddField(b, ref s, "Tag", dto.ItemTag);
        AddField(b, ref s, "Name", dto.Name);
        AddField(b, ref s, "ResRef", dto.ResRef);
        AddField(b, ref s, "Description", dto.Description);
        AddField(b, ref s, "Base Item Type", dto.BaseItemType.ToString());
        AddField(b, ref s, "Base Value", dto.BaseValue.ToString());
        AddField(b, ref s, "Item Form", dto.ItemForm);
        AddField(b, ref s, "Materials", dto.Materials != null ? string.Join(", ", dto.Materials) : "—");
        AddField(b, ref s, "Is Template", dto.IsTemplate ? "Yes" : "No");
        AddField(b, ref s, "Variants", dto.Variants?.Count.ToString() ?? "0");
        b.CloseElement();
    }

    // ── Resource Node ───────────────────────────────────────────────
    private static void RenderResourceNodeEditor(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b, ResourceNodeDefinitionDto dto)
    {
        int s = 0;
        b.OpenElement(s++, "div"); b.AddAttribute(s++, "class", "we-entity-form");
        AddField(b, ref s, "Tag", dto.Tag);
        AddField(b, ref s, "Name", dto.Name);
        AddField(b, ref s, "Type", dto.Type);
        AddField(b, ref s, "Description", dto.Description);
        AddField(b, ref s, "Uses", dto.Uses.ToString());
        AddField(b, ref s, "Harvest Rounds", dto.BaseHarvestRounds.ToString());
        AddField(b, ref s, "PLC Appearance", dto.PlcAppearance.ToString());
        AddField(b, ref s, "Quality", $"{dto.MinQuality ?? "—"} → {dto.MaxQuality ?? "—"}");
        AddField(b, ref s, "Outputs", dto.Outputs?.Length.ToString() ?? "0");
        b.CloseElement();
    }

    // ── Region ──────────────────────────────────────────────────────
    private static void RenderRegionEditor(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b, RegionDefinitionDto dto)
    {
        int s = 0;
        b.OpenElement(s++, "div"); b.AddAttribute(s++, "class", "we-entity-form");
        AddField(b, ref s, "Tag", dto.Tag);
        AddField(b, ref s, "Name", dto.Name);
        AddField(b, ref s, "Areas", dto.Areas.Count.ToString());
        if (dto.DefaultChaos != null)
        {
            AddField(b, ref s, "Default Chaos", $"D:{dto.DefaultChaos.Danger} C:{dto.DefaultChaos.Corruption} N:{dto.DefaultChaos.Density} M:{dto.DefaultChaos.Mutation}");
        }
        b.CloseElement();
    }

    // ── Lore ────────────────────────────────────────────────────────
    private static void RenderLoreEditor(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b, LoreDefinitionDto dto)
    {
        int s = 0;
        b.OpenElement(s++, "div"); b.AddAttribute(s++, "class", "we-entity-form");
        AddField(b, ref s, "Lore ID", dto.LoreId);
        AddField(b, ref s, "Title", dto.Title);
        AddField(b, ref s, "Category", dto.CategoryName ?? dto.Category.ToString());
        AddField(b, ref s, "Tier", dto.Tier.ToString());
        AddField(b, ref s, "Keywords", dto.Keywords);
        AddField(b, ref s, "Always Available", dto.IsAlwaysAvailable ? "Yes" : "No");
        AddField(b, ref s, "Created", dto.CreatedUtc.ToString("yyyy-MM-dd"));
        // Content preview
        b.OpenElement(s++, "div"); b.AddAttribute(s++, "class", "we-entity-form__field");
        b.OpenElement(s++, "label"); b.AddContent(s++, "Content"); b.CloseElement();
        b.OpenElement(s++, "div"); b.AddAttribute(s++, "class", "we-entity-form__content-preview");
        b.AddContent(s++, dto.Content.Length > 500 ? dto.Content[..500] + "…" : dto.Content);
        b.CloseElement(); b.CloseElement();
        b.CloseElement();
    }

    // ── Trait ────────────────────────────────────────────────────────
    private static void RenderTraitEditor(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b, TraitDefinitionDto dto)
    {
        int s = 0;
