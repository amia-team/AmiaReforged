    }

    private async Task IeCaptureCurrentScriptGraph()
    {
        if (_ieScriptEditorModule == null || !_ieScriptEditorReady) return;
        try
        {
            string json = await _ieScriptEditorModule.InvokeAsync<string>("getGraphJson");
            _iePipelineGraphJson = json;
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to capture IE pipeline graph"); }
    }

    private async Task IeLoadInteractionScripts(string interactionTag)
    {
        try
        {
            if (_ieNodeCatalog.Count == 0)
                _ieNodeCatalog = await GlyphApi.GetNodeCatalogAsync();

            List<InteractionGlyphBindingDto> bindings = await GlyphApi.GetInteractionBindingsAsync(interactionTag);
            foreach (InteractionGlyphBindingDto binding in bindings)
            {
                GlyphDefinitionDto? def = await GlyphApi.GetDefinitionAsync(binding.GlyphDefinitionId);
                if (def == null) continue;
                if (def.EventType == IePipelineEventType ||
                    def.EventType.StartsWith("OnInteraction", StringComparison.OrdinalIgnoreCase))
                {
                    _iePipelineGraphJson = def.GraphJson ?? "{}";
                    _iePipelineScript = def;
                    break;
                }
            }

            // Re-init the glyph editor with the loaded graph
            await IeDestroyScriptEditor();
            await Task.Delay(50);
            await IeInitScriptEditor();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load IE scripts for {Tag}", interactionTag);
        }
    }

