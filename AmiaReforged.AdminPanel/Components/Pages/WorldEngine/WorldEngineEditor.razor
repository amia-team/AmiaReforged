                .Where(n => n.ContextSourceTypeId == sourceTypeId)
                .ToList();

            // Derive a friendly display name from the first context node's category
            _ieContextSourceDisplayName = _ieContextNodes.Count > 0
                ? _ieContextNodes[0].Category.Replace("Context: ", "")
                : sourceTypeId;

            // Focus the Context Nodes tab in GL
            if (_ieBridgeModule != null)
            {
                _ = _ieBridgeModule.InvokeVoidAsync("focusPanel", InteractionGlInstanceId, "ie-context");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[WE] OnShowContextNodes failed for {SourceTypeId}", sourceTypeId);
