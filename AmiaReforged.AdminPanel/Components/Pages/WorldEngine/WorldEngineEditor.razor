    private void IeRemoveResponse(int index)
    {
        if (index >= 0 && index < _ieEditItem.Responses.Count)
            _ieEditItem.Responses.RemoveAt(index);
    }

    private void IeAddEffect(int responseIndex)
    {
        if (responseIndex >= 0 && responseIndex < _ieEditItem.Responses.Count)
            _ieEditItem.Responses[responseIndex].Effects.Add(new InteractionResponseEffectDto());
    }

    private void IeRemoveEffect(int responseIndex, int effectIndex)
    {
        if (responseIndex >= 0 && responseIndex < _ieEditItem.Responses.Count)
        {
            List<InteractionResponseEffectDto> effects = _ieEditItem.Responses[responseIndex].Effects;
            if (effectIndex >= 0 && effectIndex < effects.Count)
                effects.RemoveAt(effectIndex);
        }
    }

