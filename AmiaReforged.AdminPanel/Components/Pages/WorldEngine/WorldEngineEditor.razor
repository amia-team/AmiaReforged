    private async Task IeInitLayout()
    {
        try
        {
            _ieBridgeModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/golden-layout-bridge.js");
            _ieDotNetRef ??= DotNetObjectReference.Create(this);

            string layoutConfig = IeBuildDefaultLayoutConfig();
            await _ieBridgeModule.InvokeVoidAsync("init", InteractionGlInstanceId, "we-interaction-gl-container", layoutConfig, _ieDotNetRef);

            // Load node catalog if needed
            if (_ieNodeCatalog.Count == 0)
            {
                try { _ieNodeCatalog = await GlyphApi.GetNodeCatalogAsync(); }
                catch (Exception ex) { Logger.LogWarning(ex, "Failed to load node catalog for IE"); }
            }

            // Wait for GL to position the canvas panel, then init glyph editor
            await Task.Delay(100);
            await IeInitScriptEditor();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize Interaction GL layout");
            _interactionEditorError = "Layout initialization failed. Try closing and reopening.";
        }
    }

