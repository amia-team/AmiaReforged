    private async Task OpenNewCodexEditor(CodexSubType subType)
    {
        if (_codexEditorOpen) await CloseCodexEditor();

        _codexEditorOpen = true;
        _codexEditorLoading = true;
        _codexEditorError = null;
        _ceError = null;
        _ceSuccess = null;
        _ceIsCreating = true;
        _ceSubType = subType;
        _ceLoreItem = new LoreDefinitionDto();
        _ceQuestItem = new QuestDefinitionDto { Stages = [] };
        StateHasChanged();

        try
        {
            await CeLoadList();
            if (subType == CodexSubType.Quest) await CeEnsureIndustriesLoaded();
            StateHasChanged();
            await Task.Delay(50); // Let DOM render GL host + panel divs

            await CeInitLayout();

            _codexEditorLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to open new codex editor");
            _codexEditorError = $"Failed to load: {ex.Message}";
            _codexEditorLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenCodexEditor(string entityId, CodexSubType subType)
    {
        if (_codexEditorOpen) await CloseCodexEditor();

        _codexEditorOpen = true;
        _codexEditorLoading = true;
        _codexEditorError = null;
        _ceError = null;
        _ceSuccess = null;
        _ceIsCreating = false;
        _ceSubType = subType;
        StateHasChanged();

        try
        {
            if (subType == CodexSubType.Lore)
            {
                LoreDefinitionDto? loaded = await LoreApi.GetByIdAsync(entityId);
                if (loaded == null)
                {
                    _codexEditorError = $"Lore entry '{entityId}' not found.";
                    _codexEditorLoading = false;
                    StateHasChanged();
                    return;
                }
                _ceLoreItem = loaded;
            }
            else
            {
                QuestDefinitionDto? loaded = await QuestApi.GetByIdAsync(entityId);
                if (loaded == null)
                {
                    _codexEditorError = $"Quest entry '{entityId}' not found.";
                    _codexEditorLoading = false;
                    StateHasChanged();
                    return;
                }
                _ceQuestItem = loaded;
            }

            await CeLoadList();
            StateHasChanged();
            await Task.Delay(50);

            await CeInitLayout();

            _codexEditorLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to open codex editor for {Id}", entityId);
            _codexEditorError = $"Failed to load: {ex.Message}";
            _codexEditorLoading = false;
            StateHasChanged();
        }
    }

    private async Task CloseCodexEditor()
    {
        try
        {
            if (_ceBridgeModule != null)
            {
                await _ceBridgeModule.InvokeVoidAsync("destroy", CodexGlInstanceId);
            }
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Error destroying Codex GL layout"); }

        _codexEditorOpen = false;
        _codexEditorLoading = false;
        _codexEditorError = null;
        _ceError = null;
        _ceSuccess = null;
        _ceShowViewMenu = false;
        _ceListItems = [];
        StateHasChanged();
    }

