        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    // OnNodeSelectionChanged: called by glyph-editor.js when selected node changes
    [JSInvokable]
    public Task OnNodeSelectionChanged(string? json)
    {
        if (string.IsNullOrEmpty(json) || json == "null")
        {
            _ieSelectedNodeInfo = null;
        }
        else
        {
            try
            {
                _ieSelectedNodeInfo = JsonSerializer.Deserialize<IeSelectedNodeInfo>(json, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
            }
            catch { _ieSelectedNodeInfo = null; }
        }
        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

