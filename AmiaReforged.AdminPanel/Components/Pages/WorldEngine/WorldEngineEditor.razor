    private async Task IeSave()
    {
        _ieIsSaving = true;
        _ieError = null;
        _ieSuccess = null;
        try
        {
            await IeCaptureCurrentScriptGraph();

            if (_ieIsCreating)
                await InteractionApi.CreateAsync(_ieEditItem);
            else
                await InteractionApi.UpdateAsync(_ieEditItem.Tag, _ieEditItem);

            await IeSaveEventScripts(_ieEditItem.Tag);

            _ieSuccess = $"Interaction '{_ieEditItem.Name}' saved.";
        }
        catch (Exception ex)
        {
            _ieError = ex.Message;
            Logger.LogError(ex, "Failed to save interaction from IE");
        }
        finally
        {
            _ieIsSaving = false;
            StateHasChanged();
        }
    }

    private async Task IeCancel()
    {
        await CloseInteractionEditor();
    }

    private async Task IeSaveEventScripts(string interactionTag)
    {
        string graphJson = _iePipelineGraphJson;
        bool hasGraph = IeGraphHasNodes(graphJson);
        GlyphDefinitionDto? existingDef = _iePipelineScript;

        if (hasGraph)
        {
            if (existingDef != null)
            {
                GlyphDefinitionDto? updated = await GlyphApi.UpdateDefinitionAsync(existingDef.Id,
                    new UpdateGlyphRequest(GraphJson: graphJson, IsActive: true));
                if (updated != null) _iePipelineScript = updated;
            }
            else
            {
                List<InteractionGlyphBindingDto> existingBindings = await GlyphApi.GetInteractionBindingsAsync(interactionTag);
                InteractionGlyphBindingDto? matchingBinding = existingBindings.FirstOrDefault();

                if (matchingBinding != null)
                {
                    GlyphDefinitionDto? updated = await GlyphApi.UpdateDefinitionAsync(
                        matchingBinding.GlyphDefinitionId,
                        new UpdateGlyphRequest(GraphJson: graphJson, IsActive: true));
                    if (updated != null) _iePipelineScript = updated;
                }
                else
                {
                    string name = $"{interactionTag}/InteractionPipeline";
                    GlyphDefinitionDto? created = await GlyphApi.CreateDefinitionAsync(new CreateGlyphRequest(
                        Name: name,
                        EventType: IePipelineEventType,
                        Category: "Interaction",
                        Description: $"Pipeline script for interaction '{interactionTag}'",
                        GraphJson: graphJson,
                        IsActive: true));

                    if (created != null)
                    {
                        _iePipelineScript = created;
                        await GlyphApi.CreateInteractionBindingAsync(
                            new CreateInteractionGlyphBindingRequest(
                                InteractionTag: interactionTag,
                                GlyphDefinitionId: created.Id));
                    }
                }
            }
        }
        else if (existingDef != null)
        {
            await GlyphApi.UpdateDefinitionAsync(existingDef.Id, new UpdateGlyphRequest(IsActive: false));
            _iePipelineScript = null;
        }
    }

