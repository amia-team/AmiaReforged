    private async Task CeSave()
    {
        _ceIsSaving = true;
        _ceError = null;
        _ceSuccess = null;
        StateHasChanged();

        try
        {
            if (_ceSubType == CodexSubType.Lore)
            {
                if (_ceIsCreating)
                    await LoreApi.CreateAsync(_ceLoreItem);
                else
                    await LoreApi.UpdateAsync(_ceLoreItem.LoreId, _ceLoreItem);
                _ceSuccess = _ceIsCreating ? "Lore entry created." : "Lore entry updated.";
            }
            else
            {
                if (_ceIsCreating)
                    await QuestApi.CreateAsync(_ceQuestItem);
                else
                    await QuestApi.UpdateAsync(_ceQuestItem.QuestId, _ceQuestItem);
                _ceSuccess = _ceIsCreating ? "Quest entry created." : "Quest entry updated.";
            }

            _ceIsCreating = false;
            await CeLoadList();

            // Refresh the main entity list too
            await LoadEntityList(reset: true);
        }
        catch (Exception ex)
        {
            _ceError = ex.Message;
            Logger.LogError(ex, "Failed to save codex entry");
        }
        finally
        {
            _ceIsSaving = false;
            StateHasChanged();
        }
    }

    private async Task CeCancel()
    {
        await CloseCodexEditor();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Codex Editor — Delete
    // ═══════════════════════════════════════════════════════════════════

    private async Task CeDelete()
    {
        _ceError = null;
        _ceSuccess = null;

        try
        {
            if (_ceSubType == CodexSubType.Lore)
            {
                await LoreApi.DeleteAsync(_ceLoreItem.LoreId);
                _ceSuccess = "Lore entry deleted.";
            }
            else
            {
                await QuestApi.DeleteAsync(_ceQuestItem.QuestId);
                _ceSuccess = "Quest entry deleted.";
            }

            _ceIsCreating = true;
            _ceLoreItem = new LoreDefinitionDto();
            _ceQuestItem = new QuestDefinitionDto { Stages = [] };
            await CeLoadList();
            await LoadEntityList(reset: true);
        }
        catch (Exception ex)
        {
            _ceError = ex.Message;
            Logger.LogError(ex, "Failed to delete codex entry");
        }
        finally { StateHasChanged(); }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Codex Editor — Entity List (inner panel)
    // ═══════════════════════════════════════════════════════════════════

    private async Task CeLoadList()
    {
        _ceListLoading = true;
        StateHasChanged();

        try
        {
            string? search = string.IsNullOrWhiteSpace(_ceListSearch) ? null : _ceListSearch.Trim();
            _ceListItems = [];

            if (_ceSubType == CodexSubType.Lore)
            {
                PagedResult<LoreDefinitionDto> result = await LoreApi.GetAllAsync(search, page: 1, pageSize: 200);
                _ceListItems = result.Items.Select(i => new CeListEntry
                {
                    Id = i.LoreId, Title = i.Title,
                    SubLabel = i.CategoryName ?? $"Category {i.Category}",
                    SubType = CodexSubType.Lore,
                }).ToList();
            }
            else
            {
                PagedResult<QuestDefinitionDto> result = await QuestApi.GetAllAsync(search, page: 1, pageSize: 200);
                _ceListItems = result.Items.Select(i => new CeListEntry
                {
                    Id = i.QuestId, Title = i.Title,
                    SubLabel = i.QuestGiver ?? i.Location,
                    SubType = CodexSubType.Quest,
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load codex entity list");
        }
        finally
        {
            _ceListLoading = false;
        }
    }

    private void CeSearchChanged()
    {
        _ceSearchCts?.Cancel();
        _ceSearchCts = new CancellationTokenSource();
        CancellationToken ct = _ceSearchCts.Token;

        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(300, ct);
                if (!ct.IsCancellationRequested)
                {
                    await CeLoadList();
                    StateHasChanged();
                }
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task CeOnSubTypeChanged()
    {
        _ceListSearch = "";
        await CeLoadList();
        StateHasChanged();
    }

    private async Task CeSelectListItem(CeListEntry entry)
    {
        // Deselect all
        foreach (CeListEntry item in _ceListItems) item.IsSelected = false;
        entry.IsSelected = true;

        _ceIsCreating = false;
        _ceError = null;
        _ceSuccess = null;

        try
        {
            if (entry.SubType == CodexSubType.Lore)
            {
                _ceSubType = CodexSubType.Lore;
                LoreDefinitionDto? loaded = await LoreApi.GetByIdAsync(entry.Id);
                if (loaded != null) _ceLoreItem = loaded;
            }
            else
            {
                _ceSubType = CodexSubType.Quest;
                QuestDefinitionDto? loaded = await QuestApi.GetByIdAsync(entry.Id);
                if (loaded != null) _ceQuestItem = loaded;
                await CeEnsureIndustriesLoaded();
            }
        }
        catch (Exception ex)
        {
            _ceError = $"Failed to load: {ex.Message}";
        }
        StateHasChanged();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Codex Editor — Stage Helpers
    // ═══════════════════════════════════════════════════════════════════

    private void CeAddStage()
    {
        if (_ceQuestItem.Stages.Any(s => s.StageId == _ceNewStageId)) return;
        _ceQuestItem.Stages.Add(new QuestStageDto
        {
            StageId = _ceNewStageId,
            JournalText = "",
            IsCompletionStage = false,
            Hints = []
        });
        _ceExpandedStageIds.Add(_ceNewStageId);
        // Suggest next stage id: last + 10
        _ceNewStageId = _ceQuestItem.Stages.Max(s => s.StageId) + 10;
    }

    private void CeRemoveStage(int stageId)
    {
        _ceQuestItem.Stages.RemoveAll(s => s.StageId == stageId);
        _ceExpandedStageIds.Remove(stageId);
    }

    private void CeToggleStageExpand(int stageId)
    {
        if (!_ceExpandedStageIds.Add(stageId))
            _ceExpandedStageIds.Remove(stageId);
    }

    private void CeAddHintToStage(int stageId)
    {
        var stage = _ceQuestItem.Stages.FirstOrDefault(s => s.StageId == stageId);
        stage?.Hints.Add("");
    }

    private void CeRemoveHintFromStage(int stageId, int hintIndex)
    {
        var stage = _ceQuestItem.Stages.FirstOrDefault(s => s.StageId == stageId);
        if (stage != null && hintIndex >= 0 && hintIndex < stage.Hints.Count)
            stage.Hints.RemoveAt(hintIndex);
    }

    private static string CeGetLoreCategoryName(int category) => category switch
    {
        0 => "General",
        1 => "History",
        2 => "Geography",
        3 => "Religion",
        4 => "Arcana",
        5 => "Nature",
        6 => "Faction",
        7 => "Character",
        8 => "Item",
        9 => "Quest",
        10 => "Miscellaneous",
        _ => $"Unknown ({category})"
    };

    private static string CeGetLoreTierName(int tier) => tier switch
    {
        0 => "Common",
        1 => "Uncommon",
        2 => "Rare",
        3 => "Legendary",
        _ => $"Unknown ({tier})"
    };

    // ═══════════════════════════════════════════════════════════════════
    //  Codex Editor — Objective Group Helpers
    // ═══════════════════════════════════════════════════════════════════

    private void CeAddObjectiveGroup(int stageId)
    {
        QuestStageDto? stage = _ceQuestItem.Stages.FirstOrDefault(s => s.StageId == stageId);
        if (stage == null) return;
        stage.ObjectiveGroups.Add(new ObjectiveGroupDto
        {
            DisplayName = "",
            CompletionMode = "All",
            Objectives = []
        });
        string grpKey = $"{stageId}_{stage.ObjectiveGroups.Count - 1}";
        _ceExpandedGroupKeys.Add(grpKey);
    }

    private void CeRemoveObjectiveGroup(int stageId, int groupIdx)
    {
        QuestStageDto? stage = _ceQuestItem.Stages.FirstOrDefault(s => s.StageId == stageId);
        if (stage != null && groupIdx >= 0 && groupIdx < stage.ObjectiveGroups.Count)
            stage.ObjectiveGroups.RemoveAt(groupIdx);
    }

    private void CeToggleGroupExpand(string grpKey)
    {
        if (!_ceExpandedGroupKeys.Add(grpKey))
            _ceExpandedGroupKeys.Remove(grpKey);
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Codex Editor — Objective Helpers
    // ═══════════════════════════════════════════════════════════════════

    private void CeAddObjective(int stageId, int groupIdx)
    {
        QuestStageDto? stage = _ceQuestItem.Stages.FirstOrDefault(s => s.StageId == stageId);
        if (stage == null || groupIdx < 0 || groupIdx >= stage.ObjectiveGroups.Count) return;

        ObjectiveGroupDto grp = stage.ObjectiveGroups[groupIdx];
        grp.Objectives.Add(new ObjectiveDefinitionDto
        {
            ObjectiveId = Guid.NewGuid().ToString("N")[..12],
            TypeTag = "kill",
            DisplayText = "",
            RequiredCount = 1
        });
        string objKey = $"{stageId}_{groupIdx}_{grp.Objectives.Count - 1}";
        _ceExpandedObjectiveKeys.Add(objKey);
    }

    private void CeRemoveObjective(int stageId, int groupIdx, int objIdx)
    {
        QuestStageDto? stage = _ceQuestItem.Stages.FirstOrDefault(s => s.StageId == stageId);
        if (stage == null || groupIdx < 0 || groupIdx >= stage.ObjectiveGroups.Count) return;

        ObjectiveGroupDto grp = stage.ObjectiveGroups[groupIdx];
        if (objIdx >= 0 && objIdx < grp.Objectives.Count)
            grp.Objectives.RemoveAt(objIdx);
    }

    private void CeToggleObjectiveExpand(string objKey)
    {
        if (!_ceExpandedObjectiveKeys.Add(objKey))
            _ceExpandedObjectiveKeys.Remove(objKey);
    }

