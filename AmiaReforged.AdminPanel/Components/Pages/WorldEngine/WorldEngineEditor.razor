    {
        if (_ieScriptEditorModule == null) return;
        try { await _ieScriptEditorModule.InvokeVoidAsync("destroy"); }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to destroy IE script editor"); }
        _ieScriptEditorReady = false;
    }

