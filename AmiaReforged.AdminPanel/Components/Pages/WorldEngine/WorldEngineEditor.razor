    [JSInvokable]
    public Task OnRegionParentSelected(string regionTag)
    {
        RegionDefinitionDto? region = _rgRegions.FirstOrDefault(r =>
            string.Equals(r.Tag, regionTag, StringComparison.OrdinalIgnoreCase));
        if (region != null)
        {
            RgSelectRegionForEdit(region);
