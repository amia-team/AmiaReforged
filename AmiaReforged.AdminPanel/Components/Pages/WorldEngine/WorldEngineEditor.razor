    //  Interaction Editor — Script Editor Lifecycle
    // ═══════════════════════════════════════════════════════════════════

    private async Task IeInitScriptEditor()
    {
        try
        {
            _ieScriptEditorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/glyph-editor.js");
            _ieDotNetRef ??= DotNetObjectReference.Create(this);

            string catalogJson = JsonSerializer.Serialize(_ieNodeCatalog);
            string graphJson = _iePipelineGraphJson;

            if (string.IsNullOrEmpty(graphJson) || graphJson == "{}" || !IeGraphHasNodes(graphJson))
            {
                graphJson = IeBuildEmptyPipelineGraphJson();
            }

            await _ieScriptEditorModule.InvokeVoidAsync("initGlyphEditor", "we-interaction-glyph-canvas", catalogJson, graphJson, _ieDotNetRef);
            _ieScriptEditorReady = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "IE script editor init failed");
            _ieScriptEditorReady = false;
        }
    }

    private async Task IeDestroyScriptEditor()
    {
        if (_ieScriptEditorModule == null) return;
        try { await _ieScriptEditorModule.InvokeVoidAsync("destroy"); }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to destroy IE script editor"); }
        _ieScriptEditorReady = false;
    }

    private void IeResetScriptState()
    {
        _iePipelineGraphJson = "{}";
        _iePipelineScript = null;
        _ieScriptNodeSearchFilter = "";
        _ieScriptEditorReady = false;
        _ieSelectedNodeInfo = null;
    }

    private async Task IeCaptureCurrentScriptGraph()
    {
        if (_ieScriptEditorModule == null || !_ieScriptEditorReady) return;
        try
        {
            string json = await _ieScriptEditorModule.InvokeAsync<string>("getGraphJson");
            _iePipelineGraphJson = json;
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to capture IE pipeline graph"); }
    }

    private async Task IeLoadInteractionScripts(string interactionTag)
    {
        try
        {
            if (_ieNodeCatalog.Count == 0)
                _ieNodeCatalog = await GlyphApi.GetNodeCatalogAsync();

            List<InteractionGlyphBindingDto> bindings = await GlyphApi.GetInteractionBindingsAsync(interactionTag);
            foreach (InteractionGlyphBindingDto binding in bindings)
            {
                GlyphDefinitionDto? def = await GlyphApi.GetDefinitionAsync(binding.GlyphDefinitionId);
                if (def == null) continue;
                if (def.EventType == IePipelineEventType ||
                    def.EventType.StartsWith("OnInteraction", StringComparison.OrdinalIgnoreCase))
                {
                    _iePipelineGraphJson = def.GraphJson ?? "{}";
                    _iePipelineScript = def;
                    break;
                }
            }

            // Re-init the glyph editor with the loaded graph
            await IeDestroyScriptEditor();
            await Task.Delay(50);
            await IeInitScriptEditor();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load IE scripts for {Tag}", interactionTag);
        }
    }

